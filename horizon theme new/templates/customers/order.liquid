<div class="order-page-container">
  
  
  <div class="order-header-bar">
    <div class="order-title-block">
      <h1>Order {{ order.name }}</h1>
      <p>Placed on {{ order.created_at | date: "%d %B, %Y at %I:%M %p" }}</p>
    </div>
    <a href="{{ routes.account_url }}#orders" class="back-to-account-link">
      &larr; Back to Account
    </a>
  </div>

  {%- if order.cancelled -%}
    <div class="auth-form" style="margin-bottom: 32px;">
      <div class="errors" style="background-color: rgba(242, 92, 94, 0.08); border-color: var(--color-accent); color: var(--color-primary);">
        <strong style="text-transform: uppercase; font-size: 12px; display: block; margin-bottom: 4px;">Cancelled</strong>
        This order was cancelled on {{ order.cancelled_at | date: "%d %B, %Y" }}. Reason: {{ order.cancel_reason_label }}.
      </div>
    </div>
  {%- endif -%}

  
  <div class="order-meta-grid">
    
    
    <div class="meta-block">
      <h4>Billing Address</h4>
      <div style="margin-top: 8px;">
        <p><strong>Status:</strong> <span class="badge {% if order.financial_status == 'paid' %}badge-success{% else %}badge-neutral{% endif %}">{{ order.financial_status_label }}</span></p>
        <div style="margin-top: 12px;">
          {{ order.billing_address | format_address }}
        </div>
      </div>
    </div>

    
    <div class="meta-block">
      <h4>Shipping Address</h4>
      <div style="margin-top: 8px;">
        <p><strong>Status:</strong> <span class="badge {% if order.fulfillment_status == 'fulfilled' %}badge-success{% else %}badge-neutral{% endif %}">{{ order.fulfillment_status_label }}</span></p>
        <div style="margin-top: 12px;">
          {%- if order.shipping_address -%}
            {{ order.shipping_address | format_address }}
          {%- else -%}
            <p>No shipping address provided.</p>
          {%- endif -%}
        </div>
      </div>
    </div>

    
    <div class="meta-block">
      <h4>Contact Details</h4>
      <div style="margin-top: 8px; line-height: 1.6;">
        <p><strong>Email:</strong> {{ order.email }}</p>
        {%- if order.phone != blank -%}
          <p><strong>Phone:</strong> {{ order.phone }}</p>
        {%- endif -%}
        {%- if order.shipping_method != blank -%}
          <p style="margin-top: 8px;"><strong>Shipping Method:</strong> {{ order.shipping_method.title }}</p>
        {%- endif -%}
      </div>
    </div>

  </div>

  
  <div class="section-title-bar">
    <h2>Items Ordered</h2>
  </div>

  <div class="order-items-table">
    {%- for line_item in order.line_items -%}
      <div class="order-item-row">
        
        
        {%- if line_item.image != blank -%}
          <img src="{{ line_item.image | image_url: width: 140 }}" class="order-item-img" alt="{{ line_item.title | escape }}" width="140" height="140" loading="lazy">
        {%- else -%}
          <div class="order-item-img" style="background:#f5f5f5; display:flex; align-items:center; justify-content:center; color:#ccc;">
            <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1"><rect x="3" y="3" width="18" height="18" rx="2"/><circle cx="8.5" cy="8.5" r="1.5"/><polyline points="21 15 16 10 5 21"/></svg>
          </div>
        {%- endif -%}

        
        <div class="order-item-details">
          <span class="order-item-vendor">{{ line_item.vendor }}</span>
          <h3 class="order-item-title">{{ line_item.product.title }}</h3>
          
          {%- unless line_item.variant.title contains 'Default' -%}
            <div class="order-item-meta">{{ line_item.variant.title }}</div>
          {%- endunless -%}
          
          {%- if line_item.sku != blank -%}
            <div class="order-item-meta" style="margin-top: 2px;">SKU: {{ line_item.sku }}</div>
          {%- endif -%}
        </div>

        
        <div class="order-item-pricing">
          <div class="order-item-total">{{ line_item.final_line_price | money }}</div>
          <div class="order-item-qty">{{ line_item.quantity }} &times; {{ line_item.final_price | money }}</div>
        </div>

      </div>
    {%- endfor -%}
  </div>

  
  <div class="order-totals-card">
    
    <div class="total-summary-row">
      <span class="details-label">Subtotal</span>
      <span class="details-value">{{ order.line_items_subtotal_price | money }}</span>
    </div>

    {%- for discount_application in order.discount_applications -%}
      <div class="total-summary-row" style="color: var(--color-accent);">
        <span class="details-label">Discount ({{ discount_application.title }})</span>
        <span class="details-value">-{{ discount_application.total_allocated_amount | money }}</span>
      </div>
    {%- endfor -%}

    {%- for shipping_method in order.shipping_methods -%}
      <div class="total-summary-row">
        <span class="details-label">Shipping ({{ shipping_method.title }})</span>
        <span class="details-value">{{ shipping_method.price | money }}</span>
      </div>
    {%- endfor -%}

    {%- for tax_line in order.tax_lines -%}
      <div class="total-summary-row">
        <span class="details-label">Tax ({{ tax_line.title }} {{ tax_line.rate | times: 100 }}%)</span>
        <span class="details-value">{{ tax_line.price | money }}</span>
      </div>
    {%- endfor -%}

    <div class="total-summary-row grand-total">
      <span>Total</span>
      <span>{{ order.total_price | money }}</span>
    </div>

  </div>

</div>
