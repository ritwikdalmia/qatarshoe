<!doctype html>
<html
  {% if request.design_mode %}
    class="shopify-design-mode"
  {% endif %}
  lang="{{ request.locale.iso_code }}"
  dir="{{ request.locale.direction }}"
>
  <head>
    {%- if settings.favicon != blank -%}
      <link
        rel="icon"
        type="image/png"
        href="{{ settings.favicon | image_url: width: 32, height: 32 }}"
      >
    {%- endif -%}

    {% comment %} This a way to wait for main content to load when navigating to a new page so that the view transitions can work consistently {% endcomment %}
    {% if settings.transition_to_main_product or settings.page_transition_enabled %}
      <link
        rel="expect"
        href="#MainContent"
        blocking="render"
        id="view-transition-render-blocker"
      >
    {% endif %}

    {%- render 'meta-tags' -%}
    {%- render 'stylesheets' -%}
    {%- render 'fonts' -%}
    {%- render 'scripts' -%}
    {%- render 'theme-styles-variables' -%}
    {%- render 'color-palette' -%}

    {%- comment -%} Custom theme CSS variables — editable from Theme Editor {%- endcomment -%}
    <style>
      :root {
        /* ─── Brand Colors ─── */
        --color-bg: {{ settings.color_palette.background }};
        --color-text: {{ settings.color_palette.foreground }};
        --color-primary: {{ settings.color_primary }};
        --color-accent: {{ settings.color_primary }};
        --color-border: {{ settings.color_primary }};
        --color-border-rgb: {{ settings.color_primary | color_extract: 'red' }}, {{ settings.color_primary | color_extract: 'green' }}, {{ settings.color_primary | color_extract: 'blue' }};
        --color-input-border: {{ settings.color_primary }};
        --color-muted: {{ settings.color_palette.foreground }};
        --color-dark-teal: {{ settings.color_primary }};
        --color-green: {{ settings.color_primary }};
        --color-drawer-bg: {{ settings.color_palette.background }};
        --color-drawer-footer-bg: {{ settings.color_palette.background }};
        --color-white: #ffffff;
        --color-secondary-text: {{ settings.color_secondary_text | default: '#ffffff' }};
        --color-card-bg: {{ settings.color_card_bg | default: '#ffffff' }};
        --color-card-border: {{ settings.color_card_border | default: settings.color_primary }};
        --color-card-image-bg: {{ settings.color_card_image_bg | default: '#f9f9f9' }};
        --scroll-reveal-distance: {{ settings.scroll_reveal_distance | default: 20 }}px;
        --scroll-reveal-duration: {{ settings.scroll_reveal_duration | default: 0.4 }}s;

        /* ─── Font Tokens ─── */
        --font-body: var(--font-body--family), 'Inter', sans-serif;
        --font-serif: var(--font-heading--family), 'Inter', sans-serif;
        --font-size-small: {{ settings.font_size_small }}px;
        --font-size-body-small: {{ settings.font_size_body_small }}px;
        --font-size-body: {{ settings.font_size_body }}px;
        --font-size-heading-medium: {{ settings.font_size_heading_medium }}px;
        --font-size-heading-large: {{ settings.font_size_heading_large }}px;

        /* ─── Layout Tokens ─── */
        --products-per-row: {{ settings.products_per_row | default: 4 }};
        --collections-per-row: {{ settings.collections_per_row | default: 3 }};
        --radius-card: {{ settings.radius_card }}px;
        --radius-large: {{ settings.radius_large }}px;
        --radius-button: {{ settings.radius_button }}px;
        --page-width: {{ settings.custom_page_width }}px;
        --spacing-sections: {{ settings.spacing_sections }}px;

        /* ─── Horizon Style-Variable Bridges ─── */
        --style-border-radius-buttons-primary: {{ settings.button_border_radius_primary | default: settings.radius_button }}px;
        --style-border-radius-buttons-secondary: {{ settings.button_border_radius_secondary | default: settings.radius_button }}px;
        --style-border-radius-pills: {{ settings.pills_border_radius | default: settings.radius_button }}px;
        --style-border-radius-inputs: {{ settings.inputs_border_radius | default: settings.radius_button }}px;
        --style-border-radius-popover: var(--radius-large);
        --style-border-radius-drawer: var(--radius-large);
        --font-paragraph--size: var(--font-size-body);
        --font-h1--size: var(--font-size-heading-large);
        --font-h2--size: var(--font-size-heading-medium);
      }

      /* Card & Button Hover Animations Bridge */
      {% if settings.hover_effect == 'vertical' %}
        .product-card, .btn, .luxury-cta, .auth-submit-btn, .show-all-brands-btn, .brand-item, .page-card, .overview-card {
          transition: transform 0.25s ease, box-shadow 0.25s ease !important;
        }
        .product-card:hover, .btn:hover, .luxury-cta:hover, .auth-submit-btn:hover, .show-all-brands-btn:hover, .brand-item:hover, .page-card:hover, .overview-card:hover {
          transform: translateY(-4px) !important;
          box-shadow: 0 10px 20px rgba(45,31,31,0.08) !important;
        }
      {% elsif settings.hover_effect == '3d' %}
        .product-card, .btn, .luxury-cta, .auth-submit-btn, .show-all-brands-btn, .brand-item, .page-card, .overview-card {
          transition: transform 0.25s cubic-bezier(0.25, 0.46, 0.45, 0.94), box-shadow 0.25s ease !important;
        }
        .product-card:hover, .btn:hover, .luxury-cta:hover, .auth-submit-btn:hover, .show-all-brands-btn:hover, .brand-item:hover, .page-card:hover, .overview-card:hover {
          transform: translateY(-6px) scale(1.02) !important;
          box-shadow: 0 15px 30px rgba(45,31,31,0.12) !important;
        }
      {% endif %}

      /* Scroll Reveal Dynamic Settings Bridge */
      {% if settings.enable_scroll_reveal == false %}
        .scroll-reveal,
        #MainContent .shopify-section {
          opacity: 1 !important;
          transform: none !important;
          transition: none !important;
        }
      {% endif %}
    </style>
    {{ 'theme.css' | asset_url | stylesheet_tag }}

    {% if request.design_mode %}
      {%- render 'theme-editor' -%}
    {% endif %}

    {{ content_for_header }}
  </head>

  <body class="page-width-{{ settings.page_width }} card-hover-effect-{{ settings.hover_effect }}">
    {% render 'skip-to-content-link', href: '#MainContent', text: 'accessibility.skip_to_text' %}

    {% render 'chat-drawer' %}

    <div class="page-wrapper">
      <div id="header-group">
        {% sections 'header-group' %}
      </div>

      <script>
        // Inline header height and menu style calculations to prevent layout shift
        // Note: Updates in calculateHeaderGroupHeight(), updateTransparentHeaderOffset() and setHeaderMenuStyle() utilities.js should be kept in sync with this function
        (function setHeaderHeighCustomProperties() {
          /*
           * Header calculation functions for maintaining CSS variables
           * Mimic calculateHeaderGroupHeight() in utilities.js
           */
          const header = document.querySelector('header-component');
          const headerGroup = document.querySelector('#header-group');
          const hasHeaderSection = headerGroup?.querySelector('.header-section');

          if (!header || !headerGroup) return;

          const headerTopRow = header.querySelector('.header__row--top');
          const headerHeight = header.offsetHeight;

          // Calculate the total height of the header group
          let headerGroupHeight = 0;
          const children = headerGroup.children;
          for (let i = 0; i < children.length; i++) {
            const element = children[i];
            if (element === header || !(element instanceof HTMLElement)) continue;
            headerGroupHeight += element.offsetHeight;
          }

          // Check for transparent header special case
          if (header.hasAttribute('transparent') && header.parentElement?.nextElementSibling) {
            headerGroupHeight += headerHeight;
          }

          // Set CSS variables
          document.body.style.setProperty('--header-height', `${headerHeight}px`);
          document.body.style.setProperty('--header-group-height', `${headerGroupHeight}px`);

          if (headerTopRow) {
            window.requestAnimationFrame(function () {
              document.body.style.setProperty('--top-row-height', `${headerTopRow.offsetHeight}px`);
            });
          }

          /**
           * Updates CSS custom properties for transparent header offset calculation
           * Mimic updateTransparentHeaderOffset() in utilities.js
           */

          if (!hasHeaderSection || !header?.hasAttribute('transparent')) {
            document.body.style.setProperty('--transparent-header-offset-boolean', '0');
            return;
          }

          const hasImmediateSection = hasHeaderSection.nextElementSibling?.classList.contains('shopify-section');

          const shouldApplyOffset = !hasImmediateSection ? '1' : '0';
          document.body.style.setProperty('--transparent-header-offset-boolean', shouldApplyOffset);
        })();

        (function setHeaderMenuStyle() {
          const headerComponent = document.querySelector('#header-component');
          if (headerComponent) {
            const isTouchDevice = 'ontouchstart' in window && navigator.maxTouchPoints > 0;
            const overflowList = headerComponent?.querySelector('overflow-list');
            const hasReachedMinimum = overflowList && overflowList.hasAttribute('minimum-reached');
            headerComponent.dataset.menuStyle = isTouchDevice || hasReachedMinimum ? 'drawer' : 'menu';
          }
        })();
      </script>

      <main
        id="MainContent"
        class="content-for-layout"
        role="main"
        data-page-transition-enabled="{{ settings.page_transition_enabled }}"
        data-product-transition="{{ settings.transition_to_main_product }}"
        data-template="{{ template }}"
      >
        {{ content_for_layout }}
      </main>

      <footer>
        {% sections 'footer-group' %}
      </footer>
    </div>

    {% render 'cart-drawer', render_wrapper: true %}
    {% render 'theme-drawer' %}

    {% render 'search-modal' %}

    {% if settings.quick_add or settings.mobile_quick_add %}
      {% render 'quick-add-modal' %}
    {% endif %}

    <script>
      // Scroll Reveal Animations
      (function() {
        if ('IntersectionObserver' in window) {
          var observerOptions = {
            root: null,
            rootMargin: '0px 0px -10px 0px',
            threshold: 0
          };
          
          var scrollRevealObserver = new IntersectionObserver(function(entries, observer) {
            entries.forEach(function(entry) {
              if (entry.isIntersecting) {
                entry.target.classList.add('in-view');
                observer.unobserve(entry.target);
              }
            });
          }, observerOptions);

          function checkSingleProductGrids() {
            document.querySelectorAll('.product-grid').forEach(function(grid) {
              var cards = grid.querySelectorAll('.product-card');
              if (cards.length === 1) {
                grid.classList.add('product-grid--single');
              } else {
                grid.classList.remove('product-grid--single');
              }
            });
          }

          function initScrollReveal() {
            checkSingleProductGrids();
            var revealElements = document.querySelectorAll('.scroll-reveal, .product-card, #MainContent .shopify-section');
            revealElements.forEach(function(el) {
              scrollRevealObserver.observe(el);
            });
          }

          if (document.readyState === 'loading') {
            document.addEventListener('DOMContentLoaded', initScrollReveal);
          } else {
            initScrollReveal();
          }

          // MutationObserver to auto-observe AJAX-loaded product cards and sections (filtering/sorting)
          var mainContent = document.getElementById('MainContent');
          if (mainContent) {
            var mutationObserver = new MutationObserver(function(mutations) {
              checkSingleProductGrids();
              mutations.forEach(function(mutation) {
                mutation.addedNodes.forEach(function(node) {
                  if (node.nodeType === Node.ELEMENT_NODE) {
                    if (node.matches('.scroll-reveal, .product-card, .shopify-section')) {
                      scrollRevealObserver.observe(node);
                    }
                    var children = node.querySelectorAll('.scroll-reveal, .product-card, .shopify-section');
                    children.forEach(function(child) {
                      scrollRevealObserver.observe(child);
                    });
                  }
                });
              });
            });
            mutationObserver.observe(mainContent, { childList: true, subtree: true });
          }
          
          document.addEventListener('shopify:section:load', function(event) {
            checkSingleProductGrids();
            var section = event.target;
            if (section.closest('#MainContent')) {
              scrollRevealObserver.observe(section);
            }
            var newRevealElements = section.querySelectorAll('.scroll-reveal, .product-card');
            newRevealElements.forEach(function(el) {
              scrollRevealObserver.observe(el);
            });
          });
        } else {
          // Fallback for browsers without IntersectionObserver
          var revealElements = document.querySelectorAll('.scroll-reveal');
          revealElements.forEach(function(el) {
            el.classList.add('in-view');
          });
        }
      })();
    </script>
  </body>
</html>
