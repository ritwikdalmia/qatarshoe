<a href="{{ product.url }}" class="product-card" aria-label="{{ product.title }}">
  <div class="product-card-img" 
       data-images="{%- if product.images.size > 1 -%}{%- for img in product.images -%}{{ img | image_url: width: 600, height: 900, crop: 'center' }}{% unless forloop.last %},{% endunless %}{%- endfor -%}{%- endif -%}">
    {%- if product.featured_image != blank -%}
      <img src="{{ product.featured_image | image_url: width: 600, height: 900, crop: 'center' }}"
           alt="{{ product.featured_image.alt | escape }}"
           width="600" height="900"
           loading="lazy">
    {%- else -%}
      <div class="product-card-placeholder" style="background:#f9f9f9;display:flex;align-items:center;justify-content:center;">
        <svg width="40" height="40" viewBox="0 0 24 24" fill="none" stroke="#ccc" stroke-width="1"><rect x="3" y="3" width="18" height="18" rx="2"/><circle cx="8.5" cy="8.5" r="1.5"/><polyline points="21 15 16 10 5 21"/></svg>
      </div>
    {%- endif -%}

    <button type="button" class="product-wishlist-btn" aria-label="Add to wishlist"
            data-id="{{ product.id }}"
            data-title="{{ product.title | escape }}"
            data-image="{{ product.featured_image | image_url: width: 300 }}"
            data-price="{{ product.price }}"
            data-url="{{ product.url }}"
            data-vendor="{{ product.vendor | escape }}"
            data-variant-id="{{ product.selected_or_first_available_variant.id }}"
            onclick="toggleWishlist(event, '{{ product.id }}')">
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
        <path d="M19 14c1.49-1.46 3-3.21 3-5.5A5.5 5.5 0 0 0 16.5 3c-1.76 0-3 .5-4.5 2-1.5-1.5-2.74-2-4.5-2A5.5 5.5 0 0 0 2 8.5c0 2.3 1.5 4.05 3 5.5l7 7Z"/>
      </svg>
    </button>
    {%- if settings.quick_add and product.available -%}
    <button type="button" class="product-quick-add-btn{% unless settings.mobile_quick_add %} mobile-hide-quick-add{% endunless %}" aria-label="Add to cart"
            data-variant-id="{{ product.selected_or_first_available_variant.id }}"
            onclick="window.quickAddCardToCart(event, '{{ product.selected_or_first_available_variant.id }}')">
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
        <path d="M6 2L3 6v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2V6l-3-4z"></path>
        <line x1="3" y1="6" x2="21" y2="6"></line>
        <path d="M16 10a4 4 0 0 1-8 0"></path>
      </svg>
    </button>
    {%- endif -%}
    
    {%- if product.compare_at_price > product.price -%}
      <div class="product-badge-sale-new color-custom-badge-sale product-badge--{{ settings.badge_position }}">
        <span class="badge-text">SALE</span>
      </div>
    {%- else -%}
      <div class="product-badge-new color-custom-badge-new product-badge--{{ settings.badge_position }}">
        <span class="badge-text">NEW</span>
      </div>
    {%- endif -%}
  </div>
  
  <div class="product-card-body">
    <div class="text-wrapper">
      <div class="product-brand">{{ product.vendor }}</div>
      <div class="product-model">{{ product.title }}</div>
    </div>
    {%- assign price_cent = product.price | modulo: 100 -%}
    {%- assign price_main = product.price | divided_by: 100 -%}
    {%- if price_cent < 10 -%}{%- assign price_cent = '0' | append: price_cent -%}{%- endif -%}
    {%- if settings.currency_code_enabled_product_cards -%}
      {%- assign price_qar_formatted = 'QAR ' | append: price_main | append: '.' | append: price_cent -%}
    {%- else -%}
      {%- assign qtr_symbol = settings.currency_qar_symbol | default: 'QR' -%}
      {%- assign price_qar_formatted = qtr_symbol | append: ' ' | append: price_main | append: '.' | append: price_cent -%}
    {%- endif -%}
    
    {%- assign compare_qar_formatted = blank -%}
    {%- if product.compare_at_price > product.price -%}
      {%- assign compare_cent = product.compare_at_price | modulo: 100 -%}
      {%- assign compare_main = product.compare_at_price | divided_by: 100 -%}
      {%- if compare_cent < 10 -%}{%- assign compare_cent = '0' | append: compare_cent -%}{%- endif -%}
      {%- if settings.currency_code_enabled_product_cards -%}
        {%- assign compare_qar_formatted = 'QAR ' | append: compare_main | append: '.' | append: compare_cent -%}
      {%- else -%}
        {%- assign qtr_symbol = settings.currency_qar_symbol | default: 'QR' -%}
        {%- assign compare_qar_formatted = qtr_symbol | append: ' ' | append: compare_main | append: '.' | append: compare_cent -%}
      {%- endif -%}
    {%- endif -%}

    <div class="product-price-row"
         data-price-qar="{{ price_qar_formatted }}"
         {%- if product.compare_at_price > product.price -%}
         data-compare-qar="{{ compare_qar_formatted }}"
         {%- endif -%}
         {%- for curr_raw in currencies -%}
           {%- assign curr = curr_raw | strip | upcase -%}
           {%- if curr != blank and curr != 'QAR' -%}
             {%- assign curr_down = curr | downcase -%}
             {%- assign price_key = curr_down | append: '_price' -%}
             {%- assign compare_key = curr_down | append: '_compare' -%}
             {%- assign custom_price = product.metafields.pricing[price_key] -%}
             {%- assign custom_compare = product.metafields.pricing[compare_key] -%}
             
             {%- assign symbol = curr -%}
             {%- for sym_pair_raw in custom_symbols -%}
               {%- assign sym_pair = sym_pair_raw | split: ':' -%}
               {%- assign sym_code = sym_pair[0] | strip | upcase -%}
               {%- if sym_code == curr -%}
                 {%- assign symbol = sym_pair[1] | strip -%}
                 {%- break -%}
               {%- endif -%}
             {%- endfor -%}
             
             {%- if custom_price != blank -%}
               data-price-{{ curr_down }}="{{ symbol }} {{ custom_price }}"
             {%- endif -%}
             {%- if custom_compare != blank -%}
               data-compare-{{ curr_down }}="{{ symbol }} {{ custom_compare }}"
             {%- endif -%}
             {%- endif -%}
         {%- endfor -%}>
      {%- if product.compare_at_price > product.price -%}
        {%- if settings.currency_code_enabled_product_cards -%}
          <span class="product-price-compare">{{ product.compare_at_price | money_with_currency }}</span>
          <span class="product-price sale-price">{{ product.price | money_with_currency }}</span>
        {%- else -%}
          <span class="product-price-compare">{{ product.compare_at_price | money | remove: ' QAR' | remove: 'QAR ' }}</span>
          <span class="product-price sale-price">{{ product.price | money | remove: ' QAR' | remove: 'QAR ' }}</span>
        {%- endif -%}
      {%- else -%}
        {%- if settings.currency_code_enabled_product_cards -%}
          <span class="product-price">{{ product.price | money_with_currency }}</span>
        {%- else -%}
          <span class="product-price">{{ product.price | money | remove: ' QAR' | remove: 'QAR ' }}</span>
        {%- endif -%}
      {%- endif -%}
    </div>
  </div>
</a>
