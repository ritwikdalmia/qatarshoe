          const href = pill.getAttribute('href') || '';
          const handle = href.split('/').pop().split('?')[0];
          if (handle) activePillHandles.push(handle.toLowerCase());
        });
        if (activePillHandles.some(handle => productCols.includes(handle))) {
          matchesType = true;
        }
      }
      
      const vendor = (card.getAttribute('data-vendor') || '').toLowerCase();
      const matchesVendor = activeVendors.length === 0 || activeVendors.includes(vendor);
      
      const available = card.getAttribute('data-available') === 'true';
      let matchesAvailability = true;
      if (activeAvailability.length > 0) {
        const matchesInStock = activeAvailability.includes('1') && available;
        const matchesOutOfStock = activeAvailability.includes('0') && !available;
        matchesAvailability = matchesInStock || matchesOutOfStock;
      }
      
      const priceCents = parseInt(card.getAttribute('data-price-cents') || '0');
      const price = priceCents / 100;
      let matchesPrice = true;
      if (minPrice !== null && price < minPrice) matchesPrice = false;
      if (maxPrice !== null && price > maxPrice) matchesPrice = false;
      
      let matchesOptions = true;
      for (const [optName, optValues] of Object.entries(optionFilters)) {
        const prodOptAttr = card.getAttribute(`data-opt-${optName}`) || '';
        const prodOptValues = prodOptAttr.split(',').map(v => v.trim().toLowerCase()).filter(v => v !== '');
        const hasMatch = optValues.some(val => prodOptValues.includes(val));
        if (!hasMatch) {
          matchesOptions = false;
          break;
        }
      }
      
      const isOnSale = card.getAttribute('data-on-sale') === 'true';
      const isNewIn = card.getAttribute('data-new-in') === 'true';
