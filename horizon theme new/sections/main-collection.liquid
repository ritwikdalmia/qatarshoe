          cb.checked = activeCols.includes(handle.toLowerCase());
        }
      });
      const allCb = document.querySelector('.collection-nav-all');
      if (allCb) allCb.checked = false;
    } else {
      const currentHandle = "{{ collection.handle }}".toLowerCase();
      let matched = false;
      document.querySelectorAll('.collection-nav-cb:not(.collection-nav-all)').forEach(cb => {
        const handle = cb.getAttribute('data-collection-handle') || '';
        if (handle && handle.toLowerCase() === currentHandle) {
          cb.checked = true;
          matched = true;
        } else {
          cb.checked = false;
        }
      });
      const allCb = document.querySelector('.collection-nav-all');
      if (allCb) allCb.checked = !matched;
    }
  }

