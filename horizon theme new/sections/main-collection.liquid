  function initTypeFilters() {
    const params = new URLSearchParams(window.location.search);
    const activeTypes = params.getAll('filter.p.product_type');
    const pills = document.querySelectorAll('.filter-pill-type');
    
    let anyActive = false;
    pills.forEach(pill => {
      const val = pill.getAttribute('data-type-value');
      const isAll = pill.getAttribute('data-is-all') === 'true';
      
      if (!isAll && val && activeTypes.includes(val)) {
        pill.classList.add('active');
        anyActive = true;
      } else {
        pill.classList.remove('active');
      }
    });
    
    if (!anyActive) {
      pills.forEach(pill => {
        const isAll = pill.getAttribute('data-is-all') === 'true';
        if (isAll) {
          const parentUrl = pill.getAttribute('data-parent-url');
          if (window.location.pathname === parentUrl) {
            pill.classList.add('active');
          }
        } else {
          const href = pill.getAttribute('href');
          if (href && window.location.pathname === new URL(href, window.location.origin).pathname) {
            pill.classList.add('active');
          }
        }
      });
    }
  }

  function toggleTypeFilter(pill, event) {
    event.preventDefault();
    const isAll = pill.getAttribute('data-is-all') === 'true';
    
    let targetCb = null;
    if (isAll) {
      targetCb = document.querySelector('.collection-nav-all');
      if (targetCb) {
        targetCb.checked = true;
        targetCb.dispatchEvent(new Event('change', { bubbles: true }));
      }
    } else {
      const labelText = pill.textContent.trim().toLowerCase();
      document.querySelectorAll('.collection-nav-cb:not(.collection-nav-all)').forEach(cb => {
        const textEl = cb.closest('label').querySelector('.filter-value-text');
        if (textEl && textEl.textContent.trim().toLowerCase() === labelText) {
          targetCb = cb;
        }
      });
      
      if (targetCb) {
        targetCb.checked = !targetCb.checked;
        targetCb.dispatchEvent(new Event('change', { bubbles: true }));
      }
    }
    
    applyFilters();
  }
  
  function initCategoryTypeFilters() {
    const params = new URLSearchParams(window.location.search);
    const activeTypes = params.getAll('filter.p.product_type').map(t => t.trim().toLowerCase());
    const pills = document.querySelectorAll('.filter-pill-category-type');
    
    let activePillFound = false;
    
    if (activeTypes.length > 0) {
      let remainingTypes = [...activeTypes];
      
      const pillData = Array.from(pills).map(pill => {
        const valuesAttr = pill.getAttribute('data-type-values') || '';
        const values = valuesAttr.split(',').map(v => v.trim().toLowerCase()).filter(v => v !== '');
        return { pill, values };
      });
      
      pillData.sort((a, b) => b.values.length - a.values.length);
      
      pillData.forEach(item => {
        if (item.values.length === 0) return;
        
        const isMatch = item.values.every(v => remainingTypes.includes(v));
        if (isMatch) {
          item.pill.classList.add('active');
          activePillFound = true;
          remainingTypes = remainingTypes.filter(v => !item.values.includes(v));
        } else {
          item.pill.classList.remove('active');
        }
      });
    }
    
    const allPill = document.querySelector('.filter-pill[data-is-brand-all="true"]');
    if (allPill) {
      if (activePillFound) {
        allPill.classList.remove('active');
      } else {
        allPill.classList.add('active');
      }
    }
  }

