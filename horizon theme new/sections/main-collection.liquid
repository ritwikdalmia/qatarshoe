  let isFetchingBackgroundPages = false;
  function loadAllCollectionPages() {
    if (isFetchingBackgroundPages) return;
    const totalPages = window.collectionPagination?.totalPages || 1;
    if (totalPages <= 1) {
      filterProductsDOM(false);
      return;
    }
    
    isFetchingBackgroundPages = true;
    
    const paginationContainer = document.querySelector('.pagination-container');
    if (paginationContainer) {
      paginationContainer.style.opacity = '0.5';
      paginationContainer.style.pointerEvents = 'none';
    }

    const currentParams = new URLSearchParams(window.location.search);
    const fetchPromises = [];
    
    for (let p = 2; p <= totalPages; p++) {
      const pageParams = new URLSearchParams(currentParams);
      pageParams.set('page', p);
      const url = `${window.location.pathname}?${pageParams.toString()}`;
      
      fetchPromises.push(
        fetch(url)
          .then(res => {
            if (!res.ok) throw new Error('Network error');
            return res.text();
          })
          .then(html => {
            const parser = new DOMParser();
            const doc = parser.parseFromString(html, 'text/html');
            const products = doc.querySelectorAll('.product-grid .product-card');
            return Array.from(products);
          })
      );
    }
    
    Promise.all(fetchPromises)
      .then(results => {
        const grid = document.querySelector('.product-grid');
        if (grid) {
          results.forEach(cards => {
            cards.forEach(card => {
              grid.appendChild(card);
            });
          });
        }
        
        if (paginationContainer && window.collectionPagination?.paginationType === 'show_all') {
          paginationContainer.style.display = 'none';
        } else if (paginationContainer) {
          paginationContainer.style.opacity = '1';
          paginationContainer.style.pointerEvents = 'auto';
        }
        
        if (typeof initCollectionProductImageSlideshows === 'function') {
          initCollectionProductImageSlideshows();
        }
        
        var savedCurrency = localStorage.getItem('qtr_currency') || 'QAR';
        if (typeof window.applyStoreCurrency === 'function') {
          window.applyStoreCurrency(savedCurrency);
        }
        
        isFetchingBackgroundPages = false;
        filterProductsDOM(false);
      })
      .catch(err => {
        console.error('Error fetching background pages:', err);
        isFetchingBackgroundPages = false;
        filterProductsDOM(false);
      });
  }

  function applyFilters() {
    const currentParams = new URLSearchParams(window.location.search);
    const newParams = new URLSearchParams();
    
    // Preserve other params (like q)
    for (const [key, value] of currentParams.entries()) {
      if (!key.startsWith('filter.p.') && !key.startsWith('filter.v.') && key !== 'sort_by' && key !== 'q') {
        newParams.append(key, value);
      }
    }
    
    const query = currentParams.get('q');
    if (query) newParams.append('q', query);
    
    const desktopSort = currentParams.get('sort_by');
    const mobileSortSelected = document.querySelector('input[name="sort_by_mobile"]:checked');
    if (mobileSortSelected && window.innerWidth <= 768) {
      newParams.append('sort_by', mobileSortSelected.value);
    } else if (desktopSort) {
      newParams.append('sort_by', desktopSort);
    }
    
    // Add collections
    const activeCols = getActiveCollections();
    activeCols.forEach(col => {
      newParams.append('filter.p.collection', col);
    });
    
    // Add active types
    const activeTypes = getActiveProductTypes();
    activeTypes.forEach(t => {
      newParams.append('filter.p.product_type', t);
    });
    
    // Add native checkboxes
    const checkboxes = document.querySelectorAll('.filter-drawer-checkbox:not(.collection-nav-cb):not(.brand-category-cb):not(.brand-collection-nav-all):not(.custom-brand-cb):checked');
    checkboxes.forEach(cb => {
      newParams.append(cb.name, cb.value);
    });
    
    // Add custom brands
    const customBrandCbs = document.querySelectorAll('.custom-brand-cb:checked');
    customBrandCbs.forEach(cb => {
      newParams.append(cb.name, cb.value);
    });
    
    // Add prices
    const priceInputs = document.querySelectorAll('.filter-price-input');
    priceInputs.forEach(input => {
      if (input.value !== '') {
        newParams.append(input.name, input.value);
      }
    });
    
    newParams.delete('page');
    
    const newSearch = newParams.toString();
    const newUrl = `${window.location.pathname}${newSearch ? '?' + newSearch : ''}`;
    window.history.pushState({ path: newUrl }, '', newUrl);
    
    filterProductsDOM(true);
    closeFiltersDrawer();
  }

  // Handle all checkbox and pill synchronization/realtime changes
  document.addEventListener('change', function(e) {
    if (e.target.classList.contains('filter-drawer-checkbox')) {
      // Handle collections specific mutual exclusivity logic
      if (e.target.classList.contains('collection-nav-cb')) {
        const isAll = e.target.getAttribute('data-is-all') === 'true';
        
        if (isAll) {
          if (e.target.checked) {
            document.querySelectorAll('.collection-nav-cb:not(.collection-nav-all)').forEach(cb => cb.checked = false);
          } else {
            const anyChecked = Array.from(document.querySelectorAll('.collection-nav-cb:not(.collection-nav-all)')).some(cb => cb.checked);
            if (!anyChecked) e.target.checked = true;
          }
        } else {
          if (e.target.checked) {
            const allCb = document.querySelector('.collection-nav-all');
            if (allCb) allCb.checked = false;
          } else {
            const anyChecked = Array.from(document.querySelectorAll('.collection-nav-cb:not(.collection-nav-all)')).some(cb => cb.checked);
            if (!anyChecked) {
              const allCb = document.querySelector('.collection-nav-all');
              if (allCb) allCb.checked = true;
            }
          }
        }
        
        // Sync pills
        const allCb = document.querySelector('.collection-nav-all');
        const isAllChecked = allCb ? allCb.checked : false;
        
        const pills = document.querySelectorAll('.filter-pill-type');
        pills.forEach(pill => {
          const pillIsAll = pill.getAttribute('data-is-all') === 'true';
          if (pillIsAll) {
            pill.classList.toggle('active', isAllChecked);
          } else {
            const pillText = pill.textContent.trim().toLowerCase();
            let cbForPill = null;
            document.querySelectorAll('.collection-nav-cb:not(.collection-nav-all)').forEach(cb => {
              const textEl = cb.closest('label').querySelector('.filter-value-text');
              if (textEl && textEl.textContent.trim().toLowerCase() === pillText) {
                cbForPill = cb;
              }
            });
            if (cbForPill) {
              pill.classList.toggle('active', cbForPill.checked);
            } else {
              pill.classList.remove('active');
            }
          }
        });
      }
      
      // Handle brand categories specific mutual exclusivity logic
      if (e.target.classList.contains('brand-category-cb') || e.target.classList.contains('brand-collection-nav-all')) {
        const isAll = e.target.classList.contains('brand-collection-nav-all');
        
        if (isAll) {
          if (e.target.checked) {
            document.querySelectorAll('.brand-category-cb').forEach(cb => cb.checked = false);
          } else {
            const anyChecked = Array.from(document.querySelectorAll('.brand-category-cb')).some(cb => cb.checked);
            if (!anyChecked) e.target.checked = true;
          }
        } else {
          if (e.target.checked) {
            const allCb = document.querySelector('.brand-collection-nav-all');
            if (allCb) allCb.checked = false;
          } else {
            const anyChecked = Array.from(document.querySelectorAll('.brand-category-cb')).some(cb => cb.checked);
            if (!anyChecked) {
              const allCb = document.querySelector('.brand-collection-nav-all');
              if (allCb) allCb.checked = true;
            }
          }
        }
        
        // Sync pills
        const allCb = document.querySelector('.brand-collection-nav-all');
        const isAllChecked = allCb ? allCb.checked : false;
        
        const pills = document.querySelectorAll('.filter-pill-category-type');
        pills.forEach(pill => {
          const pillIsAll = pill.getAttribute('data-is-brand-all') === 'true';
          if (pillIsAll) {
            pill.classList.toggle('active', isAllChecked);
          } else {
            const pillText = pill.textContent.trim().toLowerCase();
            let cbForPill = null;
            document.querySelectorAll('.brand-category-cb').forEach(cb => {
              const textEl = cb.closest('label').querySelector('.filter-value-text');
              if (textEl && textEl.textContent.trim().toLowerCase() === pillText) {
                cbForPill = cb;
              }
            });
            if (cbForPill) {
              pill.classList.toggle('active', cbForPill.checked);
            } else {
              pill.classList.remove('active');
            }
          }
        });
        
        const brandAllPill = document.querySelector('.filter-pill[data-is-brand-all="true"]');
        if (brandAllPill) {
          brandAllPill.classList.toggle('active', isAllChecked);
        }
      }
      
      updateDrawerResultCount();
    }
  });

