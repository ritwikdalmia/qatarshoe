  function initCollectionFilters() {
    const params = new URLSearchParams(window.location.search);
    const activeCols = params.getAll('filter.p.collection').map(c => c.trim().toLowerCase());
    
    if (activeCols.length > 0) {
      document.querySelectorAll('.collection-nav-cb:not(.collection-nav-all)').forEach(cb => {
        const handle = cb.getAttribute('data-collection-handle') || '';
