{%- style -%}
  body.contact-page-body {
      background: var(--color-bg);
  }

  .contact-page-wrap {
      padding: 24px 150px 48px;
      background: var(--color-bg);
  }

  .contact-page-header {
      display: flex;
      flex-direction: column;
      gap: 12px;
      padding-bottom: 32px;
  }

  .contact-page-header h1 {
      font-family: var(--font-body);
      font-size: 64px;
      font-weight: 400;
      line-height: 100%;
      letter-spacing: -2%;
      color: var(--color-primary);
      margin: 0;
      text-transform: none;
  }

  .contact-page-header p {
      font-family: var(--font-body);
      font-size: 16px;
      font-weight: 400;
      line-height: 150%;
      color: rgba(45, 31, 31, 0.7);
      margin: 0;
  }

  .contact-page-card {
      background: var(--color-bg);
  }

  .contact-mobile-br {
      display: none;
  }

  .contact-info-section {
      padding: 0;
      background: transparent;
  }

  .contact-cards {
      display: grid;
      grid-template-columns: repeat(2, 1fr);
      border-bottom: 1px solid #E5E5E5;
  }

  .contact-card {
      display: flex;
      flex-direction: column;
      justify-content: space-between;
      padding: 32px;
      gap: 48px;
      background: var(--color-bg);
      border-right: 1px solid #E5E5E5;
  }

  .contact-card:last-child {
      border-right: none;
  }

  .contact-card-text {
      display: flex;
      flex-direction: column;
      gap: 16px;
  }

  .contact-card-title {
      font-family: var(--font-body);
      font-size: 20px;
      font-weight: 600;
      line-height: 100%;
      letter-spacing: -2%;
      color: var(--color-primary);
      margin: 0;
  }

  .contact-card-desc {
      font-family: var(--font-body);
      font-size: 16px;
      font-weight: 400;
      line-height: 150%;
      letter-spacing: 0;
      color: rgba(45, 31, 31, 0.7);
      margin: 0;
  }

  .contact-card-link {
      display: inline-flex;
      align-items: center;
      justify-content: center;
      gap: 8px;
      width: 100%;
      height: 48px;
      padding: 0 18px;
      background: #fff;
      color: var(--color-primary);
      border: 1px solid var(--color-primary);
      border-radius: var(--style-border-radius-buttons-primary);
      font-family: var(--font-body);
      font-size: 16px;
      font-weight: 500;
      line-height: 100%;
      letter-spacing: 0;
      text-transform: none;
      text-decoration: none;
      box-sizing: border-box;
      transition: background 0.2s ease, color 0.2s ease;
  }

  .contact-card-link:hover {
      background: var(--color-primary);
      color: #fff;
  }

  .contact-card-link-icon {
      flex-shrink: 0;
      width: 20px;
      height: 20px;
      display: block;
  }

  .contact-form-section {
      background: var(--color-bg);
      padding: 24px 150px;
      position: relative;
      width: 100%;
      box-sizing: border-box;
  }

  .contact-form-section::before {
      content: "";
      position: absolute;
      top: 0;
      left: 0;
      right: 0;
      height: 1px;
      background: #e5e5e5;
  }

  .contact-form-inner {
      max-width: 1620px;
      margin: 0 auto;
      display: flex;
      align-items: flex-start;
      gap: 80px;
  }

  .contact-form-intro {
      flex: 0 0 488px;
      display: flex;
      flex-direction: column;
      gap: 12px;
  }

  .contact-form-intro h2 {
      font-family: var(--font-body);
      font-size: 38px;
      font-weight: 400;
      line-height: 100%;
      margin: 0;
      color: var(--color-primary);
  }

  .contact-form-intro p {
      font-family: var(--font-body);
      font-size: 16px;
      color: #000000;
      margin: 0;
  }

  .contact-form-wrapper {
      flex: 1;
      display: flex;
      flex-direction: column;
      gap: 12px;
  }

  .contact-form-wrapper form {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 20px 12px;
  }

  .contact-field-group {
      display: flex;
      flex-direction: column;
      gap: 6px;
      align-items: flex-start;
  }

  .contact-field-group.full-width {
      grid-column: 1 / -1;
  }

  .contact-field-group label {
      font-family: var(--font-body);
      font-size: 14px;
      font-weight: 500;
      color: var(--color-primary);
      margin: 0;
  }

  .contact-field-group label .required {
      color: #FF0000;
      margin-left: 2px;
  }

  .contact-form-wrapper input[type="text"],
  .contact-form-wrapper input[type="email"],
  .contact-form-wrapper input[type="tel"],
  .contact-form-wrapper textarea {
      width: 100%;
      background: var(--color-bg);
      border: 1px solid rgba(0, 0, 0, 0.2);
      border-radius: var(--style-border-radius-inputs);
      color: #000000;
      font-family: var(--font-body);
      font-size: 14px;
      box-sizing: border-box;
      outline: none;
  }

  .contact-form-wrapper input[type="text"],
  .contact-form-wrapper input[type="email"],
  .contact-form-wrapper input[type="tel"] {
      height: 44px;
      padding: 0 12px;
  }

  .contact-form-wrapper textarea {
      height: 108px;
      padding: 12px;
      resize: vertical;
  }

  .contact-submit-custom {
      width: 100%;
      height: 48px;
      display: inline-flex;
      align-items: center;
      justify-content: center;
      gap: 8px;
      background: var(--color-bg);
      color: var(--color-primary);
      border: 1px solid var(--color-primary);
      border-radius: var(--style-border-radius-buttons-primary);
      font-family: var(--font-body);
      font-size: 16px;
      font-weight: 600;
      cursor: pointer;
      transition: all 0.2s ease-in-out;
  }

  .contact-submit-custom:hover {
      background: var(--color-primary);
      color: var(--color-bg);
  }

  .wpcf7-response-output {
      padding: 12px;
      margin: 12px 0;
      border: 1px solid;
      border-radius: 4px;
  }

  .wpcf7-response-output.sent {
      border-color: #28a745;
      color: #1e7a35;
      background-color: rgba(40, 167, 69, 0.05);
  }

  .wpcf7-response-output.invalid {
      border-color: #d93b3d;
      color: #b1282a;
      background-color: rgba(217, 59, 61, 0.05);
  }

  body.contact-page-body .contact-form-section {
      padding: 0;
  }

  body.contact-page-body .contact-form-inner {
      padding: 32px 32px;
      margin: 0 auto;
      max-width: 1620px;
      gap: 80px;
  }

  @media (max-width: 1023px) {
      .contact-page-wrap {
          padding: 24px 40px 32px;
      }
      body.contact-page-body .contact-form-inner {
          gap: 40px;
          padding: 32px 32px;
          flex-direction: column;
      }
  }

  @media (max-width: 767px) {
      .contact-page-wrap {
          padding: 24px 24px 24px;
      }
      body.contact-page-body .contact-form-inner {
          padding: 32px 20px;
          gap: 32px;
          flex-direction: column;
      }
      .contact-form-wrapper form {
          grid-template-columns: 1fr;
          gap: 8px;
      }
  }
  {%- if section.settings.override_button_style -%}
    .contact-card-link,
    .contact-submit-custom {
      border-width: {{ section.settings.btn_thickness }}px !important;
      border-style: solid !important;
      border-color: color-mix(in srgb, var(--color-primary) {{ section.settings.btn_opacity }}%, transparent) !important;
      border-radius: {{ section.settings.btn_radius }}px !important;
      box-shadow: {{ section.settings.btn_shadow_h }}px {{ section.settings.btn_shadow_v }}px {{ section.settings.btn_shadow_blur }}px rgba(0, 0, 0, {{ section.settings.btn_shadow_opacity | divided_by: 100.0 }}) !important;
    }
  {%- endif -%}
{%- endstyle -%}

<script>
  // Add body class for contact page
  document.body.classList.add('contact-page-body');
</script>

<main class="contact-page-wrap">
    <!-- Page header -->
    <header class="contact-page-header">
        <h1>{{ section.settings.heading | default: page.title }}</h1>
        <p>{{ section.settings.subheading | default: "We're here to help. Choose the option that fits you best." }}</p>
    </header>

    <!-- White card container -->
    <div class="contact-page-card">
        <!-- Section 1 — Contact Info Cards -->
        <section class="contact-info-section">
            <div class="contact-cards">
                <!-- Card 1: Qatar -->
                <div class="contact-card">
                    <div class="contact-card-text">
                        <h3 class="contact-card-title">{{ section.settings.card_1_title | default: "Qatar" }}</h3>
                        <p class="contact-card-desc">{{ section.settings.card_1_desc | default: "For all orders within Qatar" }}</p>
                    </div>
                    <a class="contact-card-link" href="https://wa.me/{{ section.settings.card_1_phone_raw | default: "97455289397" }}" target="_blank" rel="noopener">
                        <svg class="contact-card-link-icon" width="20" height="20" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/></svg>
                        <span>{{ section.settings.card_1_phone | default: "+974 5528 9397" }}</span>
                    </a>
                </div>



                <!-- Card 3: Email Us -->
                <div class="contact-card">
                    <div class="contact-card-text">
                        <h3 class="contact-card-title">{{ section.settings.card_3_title | default: "Email Us" }}</h3>
                        <p class="contact-card-desc">{{ section.settings.card_3_desc | default: "General inquiries, documentation & follow-ups" }}</p>
                    </div>
                    <a class="contact-card-link" href="mailto:{{ section.settings.card_3_email | default: "info@amirivibes.com" }}">
                        <svg class="contact-card-link-icon" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><rect x="2" y="4" width="20" height="16" rx="2"/><path d="M22 4l-10 8L2 4"/></svg>
                        <span>{{ section.settings.card_3_email | default: "info@amirivibes.com" }}</span>
                    </a>
                </div>
            </div>
        </section>

        <!-- Section 2 — Send Us A Message form -->
        <section class="contact-form-section">
            <div class="contact-form-inner">
                <div class="contact-form-intro">
                    <h2>{{ section.settings.form_heading | default: "Send Us A Message" }}</h2>
                    <p>{{ section.settings.form_subheading | default: "Fill out the form and we'll get back to you as quickly as possible." }}</p>
                </div>

                <div class="contact-form-wrapper">
                    {%- form 'contact', id: 'ContactForm' -%}
                        {%- if form.posted_successfully? -%}
                            <div class="wpcf7-response-output sent" role="status">
                                Thanks for contacting us! We'll get back to you as soon as possible.
                            </div>
                        {%- elsif form.errors -%}
                            <div class="wpcf7-response-output invalid" role="alert">
                                {{ form.errors | default_errors }}
                            </div>
                        {%- endif -%}

                        <div class="contact-field-group">
                            <label for="ContactFormFirstName">First Name <span class="required">*</span></label>
                            <input type="text" id="ContactFormFirstName" name="contact[first_name]" placeholder="First Name" value="{% if form.first_name %}{{ form.first_name }}{% elsif customer %}{{ customer.first_name }}{% endif %}" required aria-required="true" />
                        </div>
                        <div class="contact-field-group">
                            <label for="ContactFormLastName">Last Name <span class="required">*</span></label>
                            <input type="text" id="ContactFormLastName" name="contact[last_name]" placeholder="Last Name" value="{% if form.last_name %}{{ form.last_name }}{% elsif customer %}{{ customer.last_name }}{% endif %}" required aria-required="true" />
                        </div>
                        <div class="contact-field-group">
                            <label for="ContactFormEmail">Email <span class="required">*</span></label>
                            <input type="email" id="ContactFormEmail" name="contact[email]" placeholder="Email" value="{% if form.email %}{{ form.email }}{% elsif customer %}{{ customer.email }}{% endif %}" required aria-required="true" />
                        </div>
                        <div class="contact-field-group">
                            <label for="ContactFormPhone">Phone Number (optional)</label>
                            <input type="tel" id="ContactFormPhone" name="contact[phone]" placeholder="Phone Number (optional)" value="{% if form.phone %}{{ form.phone }}{% elsif customer %}{{ customer.phone }}{% endif %}" pattern="^[34567][0-9]{7}$" title="Please enter a valid 8-digit Qatar phone number (starting with 3, 4, 5, 6, or 7)." />
                        </div>
                        <div class="contact-field-group full-width">
                            <label for="ContactFormMessage">Your Message <span class="required">*</span></label>
                            <textarea cols="40" rows="10" id="ContactFormMessage" name="contact[body]" placeholder="Your Message" required aria-required="true">{% if form.body %}{{ form.body }}{% endif %}</textarea>
                        </div>
                        <input type="hidden" name="contact[customer_type]" value="qatar" id="contact-customer-type" />
                        
                        <div class="contact-field-group full-width" style="margin-top: 12px;">
                            <button type="submit" class="contact-submit-custom">
                                <svg class="contact-submit-icon" width="20" height="20" viewBox="0 0 20 20" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
                                    <path d="M17.5 2.5L9.16667 10.8333" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
                                    <path d="M17.5 2.5L12.0833 17.5L9.16667 10.8333L2.5 7.91667L17.5 2.5Z" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
                                </svg>
                                <span>Send a Message</span>
                            </button>
                        </div>
                    {%- endform -%}
                </div>
            </div>
        </section>
    </div>
</main>


{% schema %}
{
  "name": "Contact Page",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Contact Us"
    },
    {
      "type": "text",
      "id": "subheading",
      "label": "Subheading",
      "default": "We're here to help. Choose the option that fits you best."
    },
    {
      "type": "header",
      "content": "Qatar Card"
    },
    {
      "type": "text",
      "id": "card_1_title",
      "label": "Qatar Card Title",
      "default": "Qatar"
    },
    {
      "type": "text",
      "id": "card_1_desc",
      "label": "Qatar Card Description",
      "default": "For all orders within Qatar"
    },
    {
      "type": "text",
      "id": "card_1_phone",
      "label": "Qatar Display Phone",
      "default": "+974 5528 9397"
    },
    {
      "type": "text",
      "id": "card_1_phone_raw",
      "label": "Qatar Raw Phone (for WhatsApp link)",
      "default": "97455289397"
    },
    {
      "type": "header",
      "content": "International Card"
    },
    {
      "type": "text",
      "id": "card_2_title",
      "label": "International Card Title",
      "default": "International"
    },
    {
      "type": "text",
      "id": "card_2_desc",
      "label": "International Card Description",
      "default": "For all orders outside Qatar"
    },
    {
      "type": "text",
      "id": "card_2_phone",
      "label": "International Display Phone",
      "default": "+974 3390 3967"
    },
    {
      "type": "text",
      "id": "card_2_phone_raw",
      "label": "International Raw Phone (for WhatsApp link)",
      "default": "97433903967"
    },
    {
      "type": "header",
      "content": "Email Card"
    },
    {
      "type": "text",
      "id": "card_3_title",
      "label": "Email Card Title",
      "default": "Email Us"
    },
    {
      "type": "text",
      "id": "card_3_desc",
      "label": "Email Card Description",
      "default": "General inquiries, documentation & follow-ups"
    },
    {
      "type": "text",
      "id": "card_3_email",
      "label": "Email Address",
      "default": "info@amirivibes.com"
    },
    {
      "type": "header",
      "content": "Form Settings"
    },
    {
      "type": "text",
      "id": "form_heading",
      "label": "Form Heading",
      "default": "Send Us A Message"
    },
    {
      "type": "text",
      "id": "form_subheading",
      "label": "Form Subheading",
      "default": "Fill out the form and we'll get back to you as quickly as possible."
    },
    {
      "type": "header",
      "content": "Button Style Override"
    },
    {
      "type": "checkbox",
      "id": "override_button_style",
      "label": "Override global button style",
      "default": false
    },
    {
      "type": "range",
      "id": "btn_thickness",
      "label": "Border Thickness",
      "min": 0,
      "max": 12,
      "step": 1,
      "default": 1,
      "unit": "px"
    },
    {
      "type": "range",
      "id": "btn_opacity",
      "label": "Border Opacity",
      "min": 0,
      "max": 100,
      "step": 5,
      "default": 100,
      "unit": "%"
    },
    {
      "type": "range",
      "id": "btn_radius",
      "label": "Corner Radius",
      "min": 0,
      "max": 50,
      "step": 2,
      "default": 50,
      "unit": "px"
    },
    {
      "type": "range",
      "id": "btn_shadow_opacity",
      "label": "Shadow Opacity",
      "min": 0,
      "max": 100,
      "step": 5,
      "default": 0,
      "unit": "%"
    },
    {
      "type": "range",
      "id": "btn_shadow_h",
      "label": "Shadow Horizontal Offset",
      "min": -20,
      "max": 20,
      "step": 1,
      "default": 0,
      "unit": "px"
    },
    {
      "type": "range",
      "id": "btn_shadow_v",
      "label": "Shadow Vertical Offset",
      "min": -20,
      "max": 20,
      "step": 1,
      "default": 4,
      "unit": "px"
    },
    {
      "type": "range",
      "id": "btn_shadow_blur",
      "label": "Shadow Blur",
      "min": 0,
      "max": 40,
      "step": 1,
      "default": 5,
      "unit": "px"
    }
  ]
}
{% endschema %}
