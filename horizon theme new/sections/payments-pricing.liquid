{%- style -%}
  /* Shared Info-section CSS */
  .pp-content {
    padding: 24px 150px;
    background: var(--color-bg);
    display: flex;
    flex-direction: column;
    gap: 24px;
  }

  .pp-content-block {
    display: flex;
    flex-direction: column;
    gap: 12px;
  }

  .pp-block-title {
    font-family: "Inter", sans-serif;
    font-size: 20px;
    font-weight: 400;
    line-height: 100%;
    letter-spacing: 0;
    color: var(--color-primary);
    margin: 0;
  }

  .pp-block-title--upper {
    font-size: 16px;
    font-weight: 500;
    text-transform: uppercase;
  }

  .pp-block-body {
    display: flex;
    flex-direction: column;
    gap: 8px;
  }

  .pp-block-intro {
    font-family: "Inter", sans-serif;
    font-size: 14px;
    font-weight: 400;
    line-height: 150%;
    color: #000000;
    margin: 0;
  }

  .pp-method-items {
    display: flex;
    flex-direction: column;
    gap: 8px;
  }

  .pp-method-item {
    font-family: "Inter", sans-serif;
    font-size: 14px;
    font-weight: 400;
    line-height: 150%;
    color: #000000;
    margin: 0;
  }

  .pp-method-item u {
    text-decoration: underline;
    text-underline-offset: 2px;
  }

  .pp-block-bullets {
    margin: 0;
    padding-inline-start: 40px;
    list-style: none;
    font-family: "Inter", sans-serif;
    font-size: 14px;
    font-weight: 400;
    line-height: 150%;
    color: #000000;
  }

  .pp-block-bullets li {
    position: relative;
    margin: 0;
    padding-inline-start: 18px;
  }

  .pp-block-bullets li::before {
    content: "";
    position: absolute;
    inset-inline-start: 0;
    top: 9px;
    width: 6px;
    height: 6px;
    background: #000000;
    border-radius: 50%;
  }

  .pp-block-bullets li + li {
    margin-top: 2px;
  }

  .pp-block-intro + .pp-block-bullets {
    margin-top: -8px;
  }

  /* Payments & Pricing specific hero styling */
  .payments-hero {
      padding: 24px 150px 12px;
      background: var(--color-bg);
      display: flex;
      flex-direction: column;
      align-items: flex-start;
      gap: 12px;
  }

  .payments-hero-title {
      font-family: var(--font-body);
      font-size: 64px;
      font-weight: 400;
      color: var(--color-primary);
      margin: 0;
      line-height: 1.1;
      text-transform: capitalize;
  }

  .payments-hero-subtitle {
      font-family: var(--font-body);
      font-size: 16px;
      font-weight: 400;
      color: #000000;
      margin: 0;
      line-height: 1.5;
  }

  /* Contact Form Section */
  .contact-form-section {
      background: var(--color-bg);
      padding: 24px 150px;
      position: relative;
      width: 100%;
      box-sizing: border-box;
  }

  .contact-form-section::before {
      content: "";
      position: absolute;
      top: 0;
      left: 0;
      right: 0;
      height: 1px;
      background: #e5e5e5;
  }

  .contact-form-inner {
      max-width: 1620px;
      margin: 0 auto;
      display: flex;
      align-items: flex-start;
      gap: 80px;
  }

  .contact-form-intro {
      flex: 0 0 488px;
      display: flex;
      flex-direction: column;
      gap: 12px;
  }

  .contact-form-intro h2 {
      font-family: var(--font-body);
      font-size: 38px;
      font-weight: 400;
      line-height: 100%;
      margin: 0;
      color: var(--color-primary);
  }

  .contact-form-intro p {
      font-family: var(--font-body);
      font-size: 16px;
      color: #000000;
      margin: 0;
  }

  .contact-form-wrapper {
      flex: 1;
      display: flex;
      flex-direction: column;
      gap: 12px;
  }

  .contact-form-wrapper .contact-form-text {
      font-family: var(--font-body);
      font-size: 14px;
      line-height: 1.6;
      color: #000000;
      margin-bottom: 24px;
  }

  .contact-form-wrapper .contact-form-text h4 {
      font-size: 18px;
      font-weight: 600;
      margin-top: 24px;
      margin-bottom: 12px;
      color: var(--color-primary);
  }

  .contact-form-wrapper .contact-form-text p {
      margin-bottom: 12px;
  }

  .contact-form-wrapper form {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 20px 12px;
  }

  .contact-field-group {
      display: flex;
      flex-direction: column;
      gap: 6px;
      align-items: flex-start;
  }

  .contact-field-group.full-width {
      grid-column: 1 / -1;
  }

  .contact-field-group label {
      font-family: var(--font-body);
      font-size: 14px;
      font-weight: 500;
      color: var(--color-primary);
      margin: 0;
  }

  .contact-field-group label .required {
      color: #FF0000;
      margin-left: 2px;
  }

  .contact-form-wrapper input[type="text"],
  .contact-form-wrapper input[type="email"],
  .contact-form-wrapper input[type="tel"],
  .contact-form-wrapper textarea {
      width: 100%;
      background: var(--color-bg);
      border: 1px solid rgba(0, 0, 0, 0.2);
      border-radius: var(--style-border-radius-inputs);
      color: #000000;
      font-family: var(--font-body);
      font-size: 14px;
      box-sizing: border-box;
      outline: none;
  }

  .contact-form-wrapper input[type="text"],
  .contact-form-wrapper input[type="email"],
  .contact-form-wrapper input[type="tel"] {
      height: 44px;
      padding: 0 12px;
  }

  .contact-form-wrapper textarea {
      height: 108px;
      padding: 12px;
      resize: vertical;
  }

  .contact-submit-custom {
      width: 100%;
      height: 48px;
      display: inline-flex;
      align-items: center;
      justify-content: center;
      gap: 8px;
      background: var(--color-bg);
      color: var(--color-primary);
      border: 1px solid var(--color-primary);
      border-radius: var(--style-border-radius-buttons-primary);
      font-family: var(--font-body);
      font-size: 16px;
      font-weight: 600;
      cursor: pointer;
      transition: all 0.2s ease-in-out;
  }

  .contact-submit-custom:hover {
      background: var(--color-primary);
      color: var(--color-bg);
  }

  .wpcf7-response-output {
      grid-column: 1 / -1;
      margin: 12px 0 0;
      padding: 14px 18px;
      font-size: 14px;
      border-radius: 4px;
      color: #000000;
      border: 1px solid rgba(0, 0, 0, 0.2);
  }

  .wpcf7-response-output.sent {
      border-color: #28a745;
      color: #1e7a35;
      background-color: rgba(40, 167, 69, 0.05);
  }

  .wpcf7-response-output.invalid {
      border-color: #d93b3d;
      color: #b1282a;
      background-color: rgba(217, 59, 61, 0.05);
  }

  @media (max-width: 1023px) {
      .payments-hero {
          padding: 24px 40px 12px;
      }
      .pp-content,
      .contact-form-section {
          padding: 32px 40px;
      }
      .contact-form-inner {
          flex-direction: column;
          gap: 40px;
      }
  }

  @media (max-width: 767px) {
      .payments-hero {
          padding: 24px 24px 12px;
      }
      .pp-content,
      .contact-form-section {
          padding: 24px 24px;
      }
      .payments-hero-title {
          font-size: 32px;
      }
      .contact-form-wrapper form {
          grid-template-columns: 1fr;
      }
      .contact-bottom-row {
          flex-direction: column;
          align-items: stretch;
      }
      .contact-toggle {
          justify-content: center;
      }
  }
{%- endstyle -%}

<script>
  document.body.classList.add('payments-pricing-page-body');
</script>

<main class="payments-main">
    <!-- Hero Section -->
    <header class="payments-hero">
        <h1 class="payments-hero-title">{{ section.settings.heading | default: page.title }}</h1>
        <p class="payments-hero-subtitle">{{ section.settings.subheading | default: "We offer secure, convenient payment options tailored for you." }}</p>
    </header>

    <!-- Content Blocks (Text First) -->
    <section class="pp-content">
        {%- for block in section.blocks -%}
            {%- if block.type == 'content_block' -%}
                <div class="pp-content-block" {{ block.shopify_attributes }}>
                    {%- if block.settings.title != blank -%}
                        <h2 class="pp-block-title{% if block.settings.uppercase %} pp-block-title--upper{% endif %}">
                            {{ block.settings.title }}
                        </h2>
                    {%- endif -%}
                    
                    {%- if block.settings.intro != blank or block.settings.bullets != blank -%}
                        <div class="pp-block-body">
                            {%- if block.settings.intro != blank -%}
                                <p class="pp-block-intro">{{ block.settings.intro | newline_to_br }}</p>
                            {%- endif -%}
                            
                            {%- if block.settings.bullets != blank -%}
                                <ul class="pp-block-bullets">
                                    {%- assign bullet_items = block.settings.bullets | split: '||' -%}
                                    {%- for item in bullet_items -%}
                                        {%- if item != blank -%}
                                            <li>{{ item | strip }}</li>
                                        {%- endif -%}
                                    {%- endfor -%}
                                </ul>
                            {%- endif -%}
                        </div>
                    {%- endif -%}
                </div>
            {%- elsif block.type == 'methods_block' -%}
                <div class="pp-content-block" {{ block.shopify_attributes }}>
                    {%- if block.settings.title != blank -%}
                        <h2 class="pp-block-title">
                            {{ block.settings.title }}
                        </h2>
                    {%- endif -%}
                    <div class="pp-block-body">
                        {%- if block.settings.intro != blank -%}
                            <p class="pp-block-intro">{{ block.settings.intro | newline_to_br }}</p>
                        {%- endif -%}
                        <div class="pp-method-items">
                            {%- if block.settings.method_1 != blank -%}
                                <p class="pp-method-item">{{ block.settings.method_1 }}</p>
                            {%- endif -%}
                            {%- if block.settings.method_2 != blank -%}
                                <p class="pp-method-item">{{ block.settings.method_2 }}</p>
                            {%- endif -%}
                            {%- if block.settings.method_3 != blank -%}
                                <p class="pp-method-item">{{ block.settings.method_3 }}</p>
                            {%- endif -%}
                        </div>
                    </div>
                </div>
            {%- endif -%}
        {%- endfor -%}
    </section>

    <!-- Contact Form Section -->
    <section class="contact-form-section">
        <div class="contact-form-inner">
            <div class="contact-form-intro">
                <h2>{{ section.settings.form_heading | default: "Send Us A Message" }}</h2>
                <p>{{ section.settings.form_subheading | default: "Fill out the form and we'll get back to you as quickly as possible." }}</p>
            </div>

            <div class="contact-form-wrapper">
                {%- form 'contact', id: 'ContactForm' -%}
                    {%- if form.posted_successfully? -%}
                        <div class="wpcf7-response-output sent" role="status">
                            Thanks for contacting us! We'll get back to you as soon as possible.
                        </div>
                    {%- elsif form.errors -%}
                        <div class="wpcf7-response-output invalid" role="alert">
                            {{ form.errors | default_errors }}
                        </div>
                    {%- endif -%}

                    <div class="contact-field-group">
                        <label for="ContactFormFirstName">First Name <span class="required">*</span></label>
                        <input type="text" id="ContactFormFirstName" name="contact[first_name]" placeholder="First Name" value="{% if form.first_name %}{{ form.first_name }}{% elsif customer %}{{ customer.first_name }}{% endif %}" required aria-required="true" />
                    </div>
                    <div class="contact-field-group">
                        <label for="ContactFormLastName">Last Name <span class="required">*</span></label>
                        <input type="text" id="ContactFormLastName" name="contact[last_name]" placeholder="Last Name" value="{% if form.last_name %}{{ form.last_name }}{% elsif customer %}{{ customer.last_name }}{% endif %}" required aria-required="true" />
                    </div>
                    <div class="contact-field-group">
                        <label for="ContactFormEmail">Email <span class="required">*</span></label>
                        <input type="email" id="ContactFormEmail" name="contact[email]" placeholder="Email" value="{% if form.email %}{{ form.email }}{% elsif customer %}{{ customer.email }}{% endif %}" required aria-required="true" />
                    </div>
                    <div class="contact-field-group">
                        <label for="ContactFormPhone">Phone Number (optional)</label>
                        <input type="tel" id="ContactFormPhone" name="contact[phone]" placeholder="Phone Number (optional)" value="{% if form.phone %}{{ form.phone }}{% elsif customer %}{{ customer.phone }}{% endif %}" pattern="^[34567][0-9]{7}$" title="Please enter a valid 8-digit Qatar phone number (starting with 3, 4, 5, 6, or 7)." />
                    </div>
                    <div class="contact-field-group full-width">
                        <label for="ContactFormMessage">Your Message <span class="required">*</span></label>
                        <textarea cols="40" rows="10" id="ContactFormMessage" name="contact[body]" placeholder="Your Message" required aria-required="true">{% if form.body %}{{ form.body }}{% endif %}</textarea>
                    </div>
                    
                    <div class="contact-field-group full-width" style="margin-top: 12px;">
                        <button type="submit" class="contact-submit-custom">
                            <svg class="contact-submit-icon" width="20" height="20" viewBox="0 0 20 20" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
                                <path d="M17.5 2.5L9.16667 10.8333" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
                                <path d="M17.5 2.5L12.0833 17.5L9.16667 10.8333L2.5 7.91667L17.5 2.5Z" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
                            </svg>
                            <span>Send a Message</span>
                        </button>
                    </div>
                {%- endform -%}
            </div>
        </div>
    </section>
</main>

{% schema %}
{
  "name": "Payments & Pricing",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Payments & Pricing"
    },
    {
      "type": "textarea",
      "id": "subheading",
      "label": "Subheading",
      "default": "We offer secure, convenient payment options tailored for you."
    },
    {
      "type": "header",
      "content": "Contact Form Settings"
    },
    {
      "type": "text",
      "id": "form_heading",
      "label": "Form Heading",
      "default": "Send Us A Message"
    },
    {
      "type": "text",
      "id": "form_subheading",
      "label": "Form Subheading",
      "default": "Fill out the form and we'll get back to you as quickly as possible."
    },
    {
      "type": "richtext",
      "id": "form_text",
      "label": "Form Descriptive Text"
    }
  ],
  "blocks": [
    {
      "type": "content_block",
      "name": "Pricing/Content Block",
      "settings": [
        {
          "type": "text",
          "id": "title",
          "label": "Block Title",
          "default": "PRICING"
        },
        {
          "type": "checkbox",
          "id": "uppercase",
          "label": "Uppercase Heading",
          "default": true
        },
        {
          "type": "textarea",
          "id": "intro",
          "label": "Intro Paragraph"
        },
        {
          "type": "textarea",
          "id": "bullets",
          "label": "Bullet Items (separated by ||)",
          "default": "All product prices are displayed clearly on the website. The price you see is the price you pay — no hidden charges are added to listed items.||Shipping fees are calculated at checkout based on your delivery destination. The exact cost is shown before you confirm your order.||Any customs duties or import taxes applicable to your order are not included in the displayed price. These remain the sole responsibility of the customer.||Prices are subject to change. The price confirmed at checkout is the final price for your order."
        }
      ]
    },
    {
      "type": "methods_block",
      "name": "Payment Methods Block",
      "settings": [
        {
          "type": "text",
          "id": "title",
          "label": "Block Title",
          "default": "Payment Methods"
        },
        {
          "type": "textarea",
          "id": "intro",
          "label": "Intro Paragraph",
          "default": "We offer three convenient ways to pay for your order within Qatar."
        },
        {
          "type": "textarea",
          "id": "method_1",
          "label": "Method 1 text",
          "default": "<u>Cash on Delivery</u> — Pay at the moment your order arrives. Our courier will collect payment in cash at your door — no advance payment required."
        },
        {
          "type": "textarea",
          "id": "method_2",
          "label": "Method 2 text",
          "default": "<u>Bank Transfer</u> — For clients who prefer to settle in advance. Transfer details are shared promptly upon order confirmation, and your order is processed as soon as payment is received."
        },
        {
          "type": "textarea",
          "id": "method_3",
          "label": "Method 3 text",
          "default": "<u>POS</u> — Point-of-sale payment is available for in-person transactions where applicable."
        }
      ]
    }
  ]
}
{% endschema %}
