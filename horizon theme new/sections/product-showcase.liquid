{%- liquid
  assign heading = section.settings.heading | default: 'Featured'
  assign max_products = section.settings.max_products | default: 6

  assign view_all_url_women = section.settings.view_all_url_women
  if view_all_url_women == blank
    assign view_all_url_women = section.settings.view_all_url | default: '/collections/all'
  endif

  assign view_all_url_men = section.settings.view_all_url_men
  if view_all_url_men == blank
    assign view_all_url_men = section.settings.view_all_url | default: '/collections/all'
  endif

  comment
    Resolve collections from Customizer settings directly. No fallback logic.
  endcomment
  assign col_women_handle = section.settings.collection_handle_women.handle | default: section.settings.collection_handle.handle | default: section.settings.collection_handle_women | default: section.settings.collection_handle | default: ''
  assign col_men_handle = section.settings.collection_handle_men.handle | default: section.settings.collection_handle.handle | default: section.settings.collection_handle_men | default: section.settings.collection_handle | default: ''

  assign col_women = blank
  if col_women_handle != blank
    assign col_women = collections[col_women_handle]
  endif

  assign col_men = blank
  if col_men_handle != blank
    assign col_men = collections[col_men_handle]
  endif
-%}

{%- if col_women != blank or col_men != blank -%}
<!-- DEBUG:
  section.id: {{ section.id }}
  col_women handle: {{ col_women.handle }} products count: {{ col_women.products.size }}
  col_men handle: {{ col_men.handle }} products count: {{ col_men.products.size }}
-->
<div class="qtr-section product-showcase-section" id="section-{{ section.id }}" data-active-dept="women">
  <div class="section-heading-row">
    <h2 class="section-heading">{{ heading }}</h2>
    
    <!-- View All Link (Women) -->
    {%- if col_women != blank and col_women.products.size > 0 -%}
      <a href="{{ view_all_url_women }}" class="view-more-link" data-dept-link="women">
        {%- if request.locale.iso_code == 'ar' -%}عرض المزيد{%- else -%}View more{%- endif -%}
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><polyline points="9 18 15 12 9 6"/></svg>
      </a>
    {%- endif -%}

    <!-- View All Link (Men) -->
    {%- if col_men != blank and col_men.products.size > 0 -%}
      <a href="{{ view_all_url_men }}" class="view-more-link" data-dept-link="men">
        {%- if request.locale.iso_code == 'ar' -%}عرض المزيد{%- else -%}View more{%- endif -%}
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><polyline points="9 18 15 12 9 6"/></svg>
      </a>
    {%- endif -%}
  </div>

  {%- capture currency_data -%}{%- render 'currency-helper' -%}{%- endcapture -%}
  {%- assign currency_data_parts = currency_data | split: '|||' -%}
  {%- assign currencies = currency_data_parts[0] | split: ',' -%}
  {%- assign custom_symbols = currency_data_parts[1] | split: ',' -%}

  <!-- Women Product Grid -->
  <div class="product-grid" data-dept-grid="women">
    {%- if col_women != blank and col_women.products.size > 0 -%}
      {%- for product in col_women.products limit: max_products -%}
        {%- render 'product-showcase-card', product: product, currencies: currencies, custom_symbols: custom_symbols -%}
      {%- endfor -%}
    {%- endif -%}
  </div>

  <!-- Men Product Grid -->
  <div class="product-grid" data-dept-grid="men">
    {%- if col_men != blank and col_men.products.size > 0 -%}
      {%- for product in col_men.products limit: max_products -%}
        {%- render 'product-showcase-card', product: product, currencies: currencies, custom_symbols: custom_symbols -%}
      {%- endfor -%}
    {%- endif -%}
  </div>
</div>
{%- endif -%}

<style>
  /* Dynamic Display Logic based on active department */
  #section-{{ section.id }}[data-active-dept="women"] [data-dept-grid="men"],
  #section-{{ section.id }}[data-active-dept="women"] [data-dept-link="men"] {
    display: none !important;
  }
  #section-{{ section.id }}[data-active-dept="men"] [data-dept-grid="women"],
  #section-{{ section.id }}[data-active-dept="men"] [data-dept-link="women"] {
    display: none !important;
  }
</style>

<script>
  (function() {
    function updateShowcaseDept() {
      const sectionEl = document.getElementById('section-{{ section.id }}');
      if (!sectionEl) return;
      const dept = localStorage.getItem('amirivibes_department') || 'women';
      sectionEl.setAttribute('data-active-dept', dept);
    }

    document.addEventListener('DOMContentLoaded', function() {
      updateShowcaseDept();
      
      var syncUI = window.syncWishlistUI || window.syncWishlistHearts || function() {};
      syncUI();
      window.addEventListener('wishlistChanged', syncUI);
      
      {%- if settings.slideshow_enabled_homepage -%}
      if (typeof initCollectionProductImageSlideshows === 'function') {
        initCollectionProductImageSlideshows();
      }
      {%- endif -%}

      var savedCurrency = localStorage.getItem('qtr_currency') || 'QAR';
      if (typeof window.applyStoreCurrency === 'function') {
        window.applyStoreCurrency(savedCurrency);
      }
    });

    window.addEventListener('departmentChanged', updateShowcaseDept);
  })();
</script>

{% schema %}
{
  "name": "Product Showcase",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Section Heading",
      "default": "Featured"
    },
    {
      "type": "collection",
      "id": "collection_handle",
      "label": "Default/Fallback Collection"
    },
    {
      "type": "url",
      "id": "view_all_url",
      "label": "Default/Fallback View All Link"
    },
    {
      "type": "header",
      "content": "Women's Collection Settings"
    },
    {
      "type": "collection",
      "id": "collection_handle_women",
      "label": "Women Collection"
    },
    {
      "type": "url",
      "id": "view_all_url_women",
      "label": "Women View All Link"
    },
    {
      "type": "header",
      "content": "Men's Collection Settings"
    },
    {
      "type": "collection",
      "id": "collection_handle_men",
      "label": "Men Collection"
    },
    {
      "type": "url",
      "id": "view_all_url_men",
      "label": "Men View All Link"
    },
    {
      "type": "range",
      "id": "max_products",
      "label": "Max Products",
      "min": 2,
      "max": 12,
      "step": 1,
      "default": 6
    }
  ],
  "presets": [
    { "name": "Product Showcase" }
  ]
}
{% endschema %}
