<div class="home-search-overlay" id="home-search-overlay" onclick="closeSearch()"
     data-show-vendor="{{ settings.show_search_vendor | default: false }}"
     data-show-price="{{ settings.show_search_price | default: true }}">
  <div class="home-search-overlay-content" onclick="event.stopPropagation()">
    <div class="search-overlay-header">
      <span class="search-overlay-icon">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
          <circle cx="11" cy="11" r="8"></circle>
          <line x1="21" y1="21" x2="16.65" y2="16.65"></line>
        </svg>
      </span>
      <input type="text" class="search-overlay-input" id="home-search-input"
             placeholder="{% if request.locale.iso_code == 'ar' %}ابحث عن المنتجات...{% else %}Search products...{% endif %}" autocomplete="off">
      <button class="search-overlay-clear" id="home-search-clear" style="display:none;" onclick="clearSearchInput(event)">
        {%- if request.locale.iso_code == 'ar' -%}مسح{%- else -%}Clear{%- endif -%}
      </button>
      <span class="search-overlay-divider"></span>
      <button class="search-overlay-close" onclick="closeSearch()" aria-label="Close search">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
          <line x1="18" y1="6" x2="6" y2="18"></line>
          <line x1="6" y1="6" x2="18" y2="18"></line>
        </svg>
      </button>
    </div>
    
    <div class="search-overlay-body">
      {%- if settings.enable_search_suggestions -%}
        <div class="search-suggestions" id="search-suggestions">
          {%- assign suggestion_count = 0 -%}
          {%- for collection in collections -%}
            {%- unless collection.handle == 'all' or collection.handle == 'frontpage' -%}
              {%- if suggestion_count < 3 -%}
                <button class="suggestion-tag" onclick="useSuggestionTag('{{ collection.title | escape }}')">{{ collection.title }}</button>
                {%- assign suggestion_count = suggestion_count | plus: 1 -%}
              {%- endif -%}
            {%- endunless -%}
          {%- endfor -%}
          {%- if suggestion_count == 0 -%}
            <button class="suggestion-tag" onclick="useSuggestionTag('bags')">bags</button>
            <button class="suggestion-tag" onclick="useSuggestionTag('shoes')">shoes</button>
            <button class="suggestion-tag" onclick="useSuggestionTag('boots')">boots</button>
          {%- endif -%}
        </div>
      {%- endif -%}
      
      <div class="search-overlay-results-wrap" id="search-results-wrap" style="display:none;">
        <div id="collections-results-wrap" style="margin-bottom: 24px; display: none;">
          <h4 class="search-results-title">{% if request.locale.iso_code == 'ar' %}المجموعات{% else %}Collections{% endif %}</h4>
          <div class="search-suggestions" id="home-collections-results" style="margin-bottom: 0;"></div>
        </div>

        <h4 class="search-results-title">{% if request.locale.iso_code == 'ar' %}المنتجات{% else %}Products{% endif %}</h4>
        <div class="search-overlay-results" id="home-search-results"></div>
        <div class="search-overlay-view-all-wrap">
          <a href="{{ routes.search_url }}?q=" class="search-view-all-btn" id="search-view-all-btn">
            {%- if request.locale.iso_code == 'ar' -%}عرض الكل{%- else -%}View all{%- endif -%}
          </a>
        </div>
      </div>
    </div>
  </div>
</div>



