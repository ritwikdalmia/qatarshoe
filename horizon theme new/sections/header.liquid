

{%- if template != 'index' -%}
  <style>
    #homepage-desktop-header { display: none !important; }
    #homepage-sticky-header {
      position: sticky !important;
      top: 0 !important;
      z-index: 9999 !important;
      transform: translateY(0) !important;
      pointer-events: auto !important;
      opacity: 1 !important;
      visibility: visible !important;
      box-shadow: 0 1px 6px rgba(0,0,0,0.06) !important;
      background: var(--color-primary, #8c1638) !important;
    }
  </style>
{%- endif -%}

<style>
  .logo-circle-layout img {
    width: {{ settings.logo_width | default: 90 }}px !important;
    height: {{ settings.logo_width | default: 90 }}px !important;
    border-radius: 50% !important;
    object-fit: cover !important;
    overflow: hidden !important;
    max-width: 100%;
  }
  .logo-circle-layout:not(.mobile-header-logo) {
    display: inline-flex !important;
    align-items: center !important;
    justify-content: center !important;
    border-radius: 50% !important;
    overflow: hidden !important;
    background: transparent !important;
  }
  .mobile-header-logo {
    display: none !important;
  }
  .two-panel-dropdown {
    min-width: 360px !important;
  }
  .two-panel-dropdown .panel-left {
    display: block !important;
    column-count: 2 !important;
    column-gap: 32px !important;
  }
  .two-panel-dropdown .panel-left .panel-item {
    display: block !important;
    break-inside: avoid-column !important;
    page-break-inside: avoid !important;
    margin-bottom: 10px !important;
  }

  .three-panel-dropdown {
    min-width: 540px !important;
  }
  .three-panel-dropdown .panel-left {
    display: block !important;
    column-count: 3 !important;
    column-gap: 32px !important;
  }
  .three-panel-dropdown .panel-left .panel-item {
    display: block !important;
    break-inside: avoid-column !important;
    page-break-inside: avoid !important;
    margin-bottom: 10px !important;
  }
  
  .hover-box:has(.panel-left *:nth-child(2)) {
    min-width: 360px !important;
  }
  .hover-box:has(.panel-left *:nth-child(2)) .panel-left {
    display: block !important;
    column-count: 2 !important;
    column-gap: 32px !important;
  }
  .hover-box:has(.panel-left *:nth-child(2)) .panel-left .panel-item {
    display: block !important;
    break-inside: avoid-column !important;
    page-break-inside: avoid !important;
    margin-bottom: 10px !important;
  }

  .hover-box:has(.panel-left *:nth-child(13)) {
    min-width: 540px !important;
  }
  .hover-box:has(.panel-left *:nth-child(13)) .panel-left {
    display: block !important;
    column-count: 3 !important;
    column-gap: 32px !important;
  }
  .hover-box:has(.panel-left *:nth-child(13)) .panel-left .panel-item {
    display: block !important;
    break-inside: avoid-column !important;
    page-break-inside: avoid !important;
    margin-bottom: 10px !important;
  }
</style>


<header class="homepage-desktop-header" id="homepage-desktop-header">

  
  <div class="desktop-header-row1">

    
    <div class="desktop-header-left">
      <div class="dept-toggle">
        <a href="javascript:void(0)" class="dept-link active" data-dept="women" onclick="switchDept('women');return false;">
          {%- if request.locale.iso_code == 'ar' -%}نساء{%- else -%}Women{%- endif -%}
        </a>
        <a href="javascript:void(0)" class="dept-link" data-dept="men" onclick="switchDept('men');return false;">
          {%- if request.locale.iso_code == 'ar' -%}رجال{%- else -%}Men{%- endif -%}
        </a>
      </div>
    </div>

    
    <div class="desktop-header-center">
      <a href="{{ routes.root_url }}" class="desktop-header-logo{% if settings.logo != blank or section.settings.logo_image != blank %} logo-circle-layout{% endif %}" aria-label="{{ shop.name }}">
        {%- assign header_logo = settings.logo | default: section.settings.logo_image -%}
        {%- if header_logo != blank -%}
          <img src="{{ header_logo | image_url: width: 200 }}" alt="{{ shop.name }}" loading="lazy" width="200" height="200">
        {%- else -%}
          <span class="logo-text-fallback">{{ section.settings.logo_text | default: shop.name }}</span>
        {%- endif -%}
      </a>
    </div>

    
    <div class="desktop-header-right">

      
      <div class="delivery-mode-wrapper" id="desktop-delivery-wrapper">
        <button type="button" class="delivery-mode-selector" id="desktop-delivery-btn"
                aria-label="Delivery location: Qatar" style="cursor: default; pointer-events: none;">
          <span class="delivery-flag">
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="5 1 26 26" class="flag-svg flag-qatar" aria-hidden="true">
              <rect x="0" width="40" height="28" fill="#fff"/>
              <path d="M12,0 L16,1.556 L12,3.111 L16,4.667 L12,6.222 L16,7.778 L12,9.333 L16,10.889 L12,12.444 L16,14 L12,15.556 L16,17.111 L12,18.667 L16,20.222 L12,21.778 L16,23.333 L12,24.889 L16,26.444 L12,28 L40,28 L40,0Z" fill="#8A1538"/>
            </svg>
          </span>
          <span class="delivery-label">Qatar</span>
        </button>
      </div>

      
      <div class="header-search-lang-group">
        
        <button class="header-icon-btn header-desktop-search" onclick="openSearch()" aria-label="Search" id="desktop-search-btn">
          <svg width="20" height="20" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.4" fill="none" stroke-linecap="round">
            <circle cx="11" cy="11" r="8"/>
            <line x1="21" y1="21" x2="16.65" y2="16.65"/>
          </svg>
        </button>

        <span class="header-v-sep" aria-hidden="true"></span>

        
        <div class="lang-selector-wrapper" id="desktop-lang-wrapper">
          <button type="button" class="lang-selector" id="desktop-lang-btn" aria-expanded="false" aria-label="Language">
            <span class="lang-label">{{ request.locale.iso_code | upcase }}</span>
            <svg class="lang-chevron" width="12" height="12" viewBox="0 0 12 12" fill="none" stroke="currentColor" stroke-width="1.4" stroke-linecap="round">
              <path d="M2.5 4L6 7.5L9.5 4"/>
            </svg>
          </button>
          <div class="lang-dropdown" id="desktop-lang-dropdown" aria-hidden="true">
            <div class="lang-option {% if request.locale.iso_code == 'en' %}is-active{% endif %}" data-lang="en">
              <span>EN</span>
              <svg class="lang-check" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="2 8 6 12 14 4"/></svg>
            </div>
            <div class="lang-option {% if request.locale.iso_code == 'ar' %}is-active{% endif %}" data-lang="ar">
              <span>AR</span>
              <svg class="lang-check" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="2 8 6 12 14 4"/></svg>
            </div>
          </div>
        </div>
      </div>

      <span class="header-v-sep" aria-hidden="true" style="background:rgba(255,255,255,0.2);display:block;width:1px;height:20px;"></span>

      
      <div class="header-icon-group">
        
        <button type="button" class="header-icon-btn wishlist-trigger" id="homepage-wishlist-btn"
                aria-label="Wishlist" style="position:relative;">
          <svg viewBox="0 0 24 24" width="22" height="22" stroke="currentColor" stroke-width="1.4" fill="none">
            <path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z"/>
          </svg>
          <span class="wishlist-count" style="display:none;">0</span>
        </button>

        
        <a href="{{ routes.cart_url }}" class="header-icon-btn cart-link" id="desktop-header-cart" aria-label="Cart" style="position:relative;">
          <svg viewBox="0 0 24 24" width="22" height="22" stroke="currentColor" stroke-width="1.4" fill="none">
            <path d="M6 2L3 6v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2V6l-3-4z"/>
            <line x1="3" y1="6" x2="21" y2="6"/>
            <path d="M16 10a4 4 0 0 1-8 0"/>
          </svg>
          <span class="cart-count-badge" id="desktop-header-cart-count" style="display:none;">{{ cart.item_count }}</span>
        </a>

        
        {%- if customer -%}
          <a href="{{ routes.account_url }}" class="header-icon-btn" aria-label="My Account">
            <svg viewBox="0 0 24 24" width="22" height="22" stroke="currentColor" stroke-width="1.4" fill="none">
              <path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"/><circle cx="12" cy="7" r="4"/>
            </svg>
          </a>
        {%- else -%}
          <a href="{{ routes.account_login_url }}" class="header-icon-btn" aria-label="Sign In">
            <svg viewBox="0 0 24 24" width="22" height="22" stroke="currentColor" stroke-width="1.4" fill="none">
              <path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"/><circle cx="12" cy="7" r="4"/>
            </svg>
          </a>
        {%- endif -%}
      </div>

    </div>
  </div>

  
  <div class="desktop-header-row2">
    <div class="nav-menu-wrapper" id="desktop-nav-menu">
      
            
      <div class="navigation-menu-wrapper" data-dept="women" id="desktop-nav-women">
        {%- assign women_menu = section.settings.women_main_menu -%}
        {%- assign menu_item_blocks = section.blocks | where: "type", "menu_item" -%}
        
        {%- if women_menu != blank and linklists[women_menu] != blank -%}
          {%- for link in linklists[women_menu].links -%}
            <div class="nav-item-wrapper">
              <a class="nav-link {% if link.title contains 'Sale' or link.title contains 'sale' %}sale-link{% endif %}" href="{{ link.url }}">
                <span class="nav-link-text">{{ link.title }}</span>
              </a>
              {%- if link.links.size > 0 -%}
                <div class="hover-box{% if link.links.size >= 2 and link.links.size <= 12 %} two-panel-dropdown{% elsif link.links.size > 12 %} three-panel-dropdown{% endif %}">
                  <div class="panel-container">
                    <div class="panel-left">
                      {%- for child_link in link.links -%}
                        <a class="panel-item" href="{{ child_link.url }}">{{ child_link.title }}</a>
                      {%- endfor -%}
                    </div>
                  </div>
                </div>
              {%- endif -%}
            </div>
          {%- endfor -%}
        {%- endif -%}

        {%- for block in menu_item_blocks -%}
          {%- if block.settings.gender == 'women' -%}
            <div class="nav-item-wrapper" {{ block.shopify_attributes }}>
              <a class="nav-link {% if block.settings.is_sale %}sale-link{% endif %}" href="{{ block.settings.url | default: '#' }}">
                <span class="nav-link-text">{{ block.settings.title }}</span>
              </a>
              {%- assign sub_menu = block.settings.dropdown_menu -%}
              {%- if sub_menu != blank and linklists[sub_menu].links.size > 0 -%}
                {%- assign sub_menu_size = linklists[sub_menu].links.size -%}
                <div class="hover-box{% if sub_menu_size >= 2 and sub_menu_size <= 12 %} two-panel-dropdown{% elsif sub_menu_size > 12 %} three-panel-dropdown{% endif %}">
                  <div class="panel-container">
                    <div class="panel-left">
                      {%- for child_link in linklists[sub_menu].links -%}
                        <a class="panel-item" href="{{ child_link.url }}">{{ child_link.title }}</a>
                      {%- endfor -%}
                    </div>
                  </div>
                </div>
              {%- endif -%}
            </div>
          {%- endif -%}
        {%- endfor -%}

        {%- if women_menu == blank and menu_item_blocks.size == 0 -%}
