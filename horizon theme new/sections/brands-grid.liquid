

<section class="brands-on-amirivibes homepage-section" id="section-{{ section.id }}" data-section="featured-brands" data-has-women="true" data-has-men="true" data-active-dept="women">
  <style>
    .brands-on-amirivibes {
      padding: 128px 40px;
      background: var(--color-bg);
      max-width: 100%;
      display: flex;
      flex-direction: column;
      align-items: center;
      gap: 32px;
      position: relative;
      z-index: 1;
    }
    .brands-on-amirivibes .brands-header {
      display: flex;
      justify-content: center;
      align-items: center;
      margin: 0;
      padding: 0;
    }
    .brands-on-amirivibes .brands-header h2 {
      font-size: 32px;
      font-weight: 600;
      margin: 0;
      color: var(--color-primary);
      font-family: var(--font-body);
      text-transform: capitalize;
      line-height: 28px;
      text-align: center;
    }
    .brands-on-amirivibes .brands-grid {
      align-self: stretch;
      padding: 1px;
      display: flex;
      flex-wrap: wrap;
      justify-content: center;
      gap: 24px;
    }
    .brands-on-amirivibes .brand-item {
      width: calc((100% - (24px * ({{ section.settings.brands_per_row | default: 5 }} - 1))) / {{ section.settings.brands_per_row | default: 5 }});
      max-width: 140px;
      max-height: 140px;
      aspect-ratio: 1/1;
      height: auto;
      background: var(--color-card-bg, #ffffff);
      overflow: hidden;
      border-radius: var(--radius-card, 12px);
      outline: 1px solid var(--color-border);
      outline-offset: -1px;
      display: flex;
      align-items: center;
      justify-content: center;
      text-decoration: none;
      transition: background-color 0.2s ease;
    }
    .brands-on-amirivibes .brand-item:hover {
      background: var(--color-card-image-bg, #f9f9f9);
    }
    .brands-on-amirivibes .brand-image-container {
      width: 100%;
      height: 100%;
      padding: 5px;
      display: flex;
      align-items: center;
      justify-content: center;
      box-sizing: border-box;
    }
    .brands-on-amirivibes .brand-image-container img {
      max-width: 120%;
      max-height: 120%;
      object-fit: contain;
    }
    .brands-on-amirivibes .brand-name-text {
      color: var(--color-primary);
      text-align: center;
    }
    
    
    .brand-font-hms {
      font-family: var(--font-serif);
      text-transform: uppercase;
      font-size: 26px;
      font-weight: 400;
      letter-spacing: 0.5px;
    }
    .brand-font-coco {
      font-family: var(--font-body);
      text-transform: lowercase;
      font-weight: 800;
      font-size: 25px;
      letter-spacing: -1px;
    }
    .brand-font-gyd {
      font-family: var(--font-body);
      text-transform: uppercase;
      font-weight: 600;
      font-size: 22px;
      letter-spacing: 0.5px;
    }
    .brand-font-lp {
      font-family: var(--font-serif);
      font-style: italic;
      font-weight: 400;
      font-size: 32px;
      text-transform: uppercase;
      letter-spacing: 2px;
    }
    .brand-font-dr {
      font-family: var(--font-serif);
      text-transform: uppercase;
      font-size: 26px;
      font-weight: 400;
    }
    .brand-font-lvn {
      font-family: var(--font-serif);
      text-transform: uppercase;
      font-size: 26px;
      font-weight: 400;
    }
    .brand-font-crt {
      font-family: var(--font-serif);
      font-style: italic;
      font-weight: 400;
      font-size: 30px;
      text-transform: capitalize;
    }
    .brand-font-msk {
      font-family: var(--font-body);
      text-transform: uppercase;
      font-size: 24px;
      font-weight: 500;
    }

    .brands-on-amirivibes .show-all-brands-btn {
      display: inline-flex;
      align-items: center;
      justify-content: center;
      font-size: 11px;
      font-weight: 600;
      text-transform: uppercase;
      letter-spacing: 1.5px;
      color: var(--color-bg, #faf9f5);
      background: var(--color-primary, var(--color-primary));
      border: 1px solid var(--color-primary, var(--color-primary));
      border-radius: var(--style-border-radius-buttons-primary, 14px);
      padding: 12px 32px;
      text-decoration: none;
      transition: all 0.2s ease;
      margin-top: 16px;
    }
    .brands-on-amirivibes .show-all-brands-btn:hover {
      background: color-mix(in srgb, var(--color-primary) 85%, black);
      border-color: color-mix(in srgb, var(--color-primary) 85%, black);
      color: var(--color-bg, #faf9f5);
    }

    @media (max-width: 1023px) {
      .brands-on-amirivibes {
        padding: 40px 15px;
        gap: 20px;
      }
      .brands-on-amirivibes .brands-header h2 {
        font-size: 22px;
      }
      .brands-on-amirivibes .brands-grid {
        display: flex;
        flex-wrap: wrap;
        justify-content: center;
        gap: 16px !important;
      }
      .brands-on-amirivibes .brand-item {
        flex: 0 0 auto;
        width: calc((100% - (16px * 3)) / 4) !important;
        height: auto;
        aspect-ratio: 1/1;
        border-radius: calc(var(--radius-card, 12px) * 0.6);
        outline: none;
        border: 1px solid var(--color-border);
        min-width: 0;
        max-width: none;
      }
      .brand-font-lp { font-size: 26px; }
      .brand-font-crt { font-size: 24px; }
      .brand-font-hms, .brand-font-coco, .brand-font-dr, .brand-font-lvn, .brand-font-msk { font-size: 20px; }
      .brand-font-gyd { font-size: 18px; }
    }
    
    @media (max-width: 767px) {
      .brands-on-amirivibes .brands-grid {
        gap: 8px !important;
      }
      .brands-on-amirivibes .brand-item {
        width: calc((100% - (8px * 1)) / 2) !important;
      }
    }
        max-width: none;
      }
    }

    /* Department Switching Logic for House of Brands */
    #section-{{ section.id }}[data-active-dept="women"] [data-dept-grid="men"],
    #section-{{ section.id }}[data-active-dept="women"] [data-dept-link="men"] {
      display: none !important;
    }
    #section-{{ section.id }}[data-active-dept="men"] [data-dept-grid="women"],
    #section-{{ section.id }}[data-active-dept="men"] [data-dept-link="women"] {
      display: none !important;
    }
  </style>

  <div class="brands-header">
    <h2>{{ section.settings.title | default: "House Of Brands" }}</h2>
  </div>
  
  <!-- Women Brands Grid -->
  <div class="brands-grid" data-dept-grid="women">
    {%- assign max_brands = section.settings.max_brands | default: 10 -%}
    {%- assign w_collections = section.settings.women_brands_list -%}
    
    {%- if w_collections != blank -%}
      {%- for col in w_collections limit: max_brands -%}
        {%- assign brand_class = col.title | downcase | replace: ' ', '' | prepend: 'brand-font-' -%}
        <a href="{{ col.url }}" class="brand-item">
          <div class="brand-image-container">
            {%- if col.image != blank -%}
              <img src="{{ col.image | image_url: width: 300 }}" alt="{{ col.title | escape }}" width="300" height="300" loading="lazy">
            {%- else -%}
              <span class="brand-name-text {{ brand_class }}">{{ col.title }}</span>
            {%- endif -%}
          </div>
        </a>
      {%- endfor -%}
    {%- endif -%}
  </div>

  <!-- Men Brands Grid -->
  <div class="brands-grid" data-dept-grid="men">
    {%- assign max_brands = section.settings.max_brands | default: 10 -%}
    {%- assign m_collections = section.settings.men_brands_list -%}
    
    {%- if m_collections != blank -%}
      {%- for col in m_collections limit: max_brands -%}
        {%- assign brand_class = col.title | downcase | replace: ' ', '' | prepend: 'brand-font-' -%}
        <a href="{{ col.url }}" class="brand-item">
          <div class="brand-image-container">
            {%- if col.image != blank -%}
              <img src="{{ col.image | image_url: width: 300 }}" alt="{{ col.title | escape }}" width="300" height="300" loading="lazy">
            {%- else -%}
              <span class="brand-name-text {{ brand_class }}">{{ col.title }}</span>
            {%- endif -%}
          </div>
        </a>
      {%- endfor -%}
    {%- endif -%}
  </div>
</section>

<script>
  (function() {
    function updateBrandsDept() {
      const sectionEl = document.getElementById('section-{{ section.id }}');
      if (!sectionEl) return;
      const dept = localStorage.getItem('amirivibes_department') || 'women';
      sectionEl.setAttribute('data-active-dept', dept);
    }
    
    // Run inline immediately for dynamic editor re-renders
    updateBrandsDept();
    
    document.addEventListener('DOMContentLoaded', updateBrandsDept);
    window.addEventListener('departmentChanged', updateBrandsDept);
    
    // Listen to theme customizer reload events
    document.addEventListener('shopify:section:load', function(e) {
      if (e.target.contains(document.getElementById('section-{{ section.id }}')) || e.target.id === 'shopify-section-{{ section.id }}') {
        updateBrandsDept();
      }
    });
  })();
</script>

{% schema %}
{
  "name": "House Of Brands",
  "settings": [
    {
      "type": "text",
      "id": "title",
      "label": "Heading",
      "default": "House Of Brands"
    },
    {
      "type": "collection_list",
      "id": "women_brands_list",
      "label": "Women Brands Collection List"
    },
    {
      "type": "collection_list",
      "id": "men_brands_list",
      "label": "Men Brands Collection List"
    },
    {
      "type": "range",
      "id": "max_brands",
      "label": "Max Brands to Show",
      "min": 4,
      "max": 25,
      "step": 1,
      "default": 10
    },
    {
      "type": "range",
      "id": "brands_per_row",
      "label": "Brands per Row (Desktop)",
      "min": 3,
      "max": 6,
      "step": 1,
      "default": 5
    }
  ],
  "presets": [
    {
      "name": "House Of Brands"
    }
  ]
}
{% endschema %}
