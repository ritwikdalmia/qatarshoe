[
  {
    "name": "theme_info",
    "theme_name": "Qatar Shoes",
    "theme_version": "1.0.0",
    "theme_author": "AlgoGuru Technologies",
    "theme_documentation_url": "https://www.algogurutechnologies.com/ecommere-qatar",
    "theme_support_url": "https://www.algogurutechnologies.com"
  },
  {
    "name": "Logo",
    "settings": [
      {
        "type": "image_picker",
        "id": "logo",
        "label": "Logo"
      },
      {
        "type": "range",
        "id": "logo_width",
        "label": "Width",
        "min": 50,
        "max": 250,
        "step": 10,
        "default": 90,
        "unit": "px"
      },
      {
        "type": "image_picker",
        "id": "favicon",
        "label": "Favicon",
        "info": "Displayed at 32 x 32px"
      }
    ]
  },
  {
    "name": "Colors",
    "settings": [
      {
        "type": "color",
        "id": "color_bg",
        "label": "Background Color",
        "default": "#faf9f5"
      },
      {
        "type": "color",
        "id": "color_text",
        "label": "Text Color",
        "default": "#2d1f1f"
      },
      {
        "type": "color",
        "id": "color_primary",
        "label": "Primary Accent",
        "default": "#2d1f1f"
      },
      {
        "type": "color",
        "id": "color_accent",
        "label": "Accent / Sale Color",
        "default": "#f25c5e"
      },
      {
        "type": "color",
        "id": "color_border",
        "label": "Border Color",
        "default": "#e0dcd3"
      },
      {
        "type": "color",
        "id": "color_muted",
        "label": "Muted Text Color",
        "default": "#000000"
      },
      {
        "type": "color",
        "id": "color_dark_teal",
        "label": "Dark Teal Accent",
        "default": "#304854"
      },
      {
        "type": "color",
        "id": "color_green",
        "label": "Green Accent",
        "default": "#1e3524"
      },
      {
        "type": "color",
        "id": "color_drawer_bg",
        "label": "Drawer Background Color",
        "default": "#ffffff"
      },
      {
        "type": "color",
        "id": "color_drawer_footer_bg",
        "label": "Drawer Footer Background Color",
        "default": "#faf9f5"
      },
      {
        "type": "color",
        "id": "color_white",
        "label": "White / Light Accent",
        "default": "#ffffff"
      }
    ]
  },
  {
    "name": "Font Sizes",
    "settings": [
      {
        "type": "range",
        "id": "font_size_small",
        "label": "Small Text (Badges, Labels)",
        "min": 10,
        "max": 16,
        "step": 1,
        "default": 11,
        "unit": "px"
      },
      {
        "type": "range",
        "id": "font_size_body_small",
        "label": "Body Small (Prices, Meta)",
        "min": 11,
        "max": 18,
        "step": 1,
        "default": 13,
        "unit": "px"
      },
      {
        "type": "range",
        "id": "font_size_body",
        "label": "Base Body Text",
        "min": 12,
        "max": 20,
        "step": 1,
        "default": 15,
        "unit": "px"
      },
      {
        "type": "range",
        "id": "font_size_heading_medium",
        "label": "Medium Heading",
        "min": 14,
        "max": 28,
        "step": 1,
        "default": 18,
        "unit": "px"
      },
      {
        "type": "range",
        "id": "font_size_heading_large",
        "label": "Large Heading (Section Titles)",
        "min": 18,
        "max": 48,
        "step": 1,
        "default": 24,
        "unit": "px"
      }
    ]
  },
  {
    "name": "Corner Roundness",
    "settings": [
      {
        "type": "range",
        "id": "radius_card",
        "label": "Card Corner Radius",
        "min": 0,
        "max": 32,
        "step": 2,
        "default": 12,
        "unit": "px"
      },
      {
        "type": "range",
        "id": "radius_large",
        "label": "Large Element Corner Radius",
        "min": 0,
        "max": 48,
        "step": 2,
        "default": 20,
        "unit": "px"
      },
      {
        "type": "range",
        "id": "radius_button",
        "label": "Button Corner Radius",
        "min": 0,
        "max": 50,
        "step": 2,
        "default": 50,
        "unit": "px"
      }
    ]
  },
  {
    "name": "Typography",
    "settings": [
      {
        "type": "font_picker",
        "id": "font_body",
        "label": "Body Font",
        "default": "assistant_n4"
      },
      {
        "type": "font_picker",
        "id": "font_heading",
        "label": "Heading Font",
        "default": "assistant_n4"
      }
    ]
  },
  {
    "name": "Slideshow Settings",
    "settings": [
      {
        "type": "checkbox",
        "id": "slideshow_enabled_homepage",
        "label": "Enable Slideshow on Homepage Showcase",
        "default": true
      },
      {
        "type": "checkbox",
        "id": "slideshow_enabled_collections",
        "label": "Enable Slideshow on Collection Pages",
        "default": true
      },
      {
        "type": "checkbox",
        "id": "slideshow_enabled_products",
        "label": "Enable Slideshow on Product Detail Pages",
        "default": true
      },
      {
        "type": "range",
        "id": "slideshow_interval",
        "label": "Slideshow Interval (Seconds)",
        "min": 2,
        "max": 10,
        "step": 1,
        "default": 5,
        "unit": "s"
      }
    ]
  }
]
