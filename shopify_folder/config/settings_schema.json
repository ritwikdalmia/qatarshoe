        "max": 150,
        "step": 5,
        "unit": "%",
        "default": 100,
        "label": "Heading scale"
      },
      {
        "type": "range",
        "id": "body_scale",
        "min": 90,
        "max": 130,
        "step": 5,
        "unit": "%",
        "default": 100,
        "label": "Body scale"
      }
    ]
  },
  {
