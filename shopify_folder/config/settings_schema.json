[
  {
    "name": "theme_info",
    "theme_name": "Qatar Shoes",
    "theme_version": "1.0.0",
    "theme_author": "AlgoGuru Technologies",
    "theme_documentation_url": "https://www.algogurutechnologies.com/ecommere-qatar",
    "theme_support_url": "https://www.algogurutechnologies.com"
  },
  {
    "name": "Logo",
    "settings": [
      {
        "type": "image_picker",
        "id": "logo",
        "label": "Logo"
      },
      {
        "type": "range",
        "id": "logo_width",
        "label": "Width",
        "min": 50,
        "max": 250,
        "step": 10,
        "default": 90,
        "unit": "px"
      },
      {
        "type": "image_picker",
        "id": "favicon",
        "label": "Favicon",
        "info": "Displayed at 32 x 32px"
      }
    ]
  },
  {
    "name": "Colors",
    "settings": [
      {
        "type": "color",
        "id": "color_bg",
        "label": "Background Color",
        "default": "#faf9f5"
      },
      {
        "type": "color",
        "id": "color_text",
        "label": "Text Color",
        "default": "#2d1f1f"
      },
      {
        "type": "color",
        "id": "color_primary",
        "label": "Primary Accent",
        "default": "#2d1f1f"
      },
      {
        "type": "color",
        "id": "color_accent",
        "label": "Accent / Sale Color",
        "default": "#f25c5e"
      },
      {
        "type": "color",
        "id": "color_border",
        "label": "Border Color",
        "default": "#e0dcd3"
      },
      {
        "type": "color",
        "id": "color_muted",
        "label": "Muted Text Color",
        "default": "#000000"
      },
      {
        "type": "color",
        "id": "color_dark_teal",
        "label": "Dark Teal Accent",
        "default": "#304854"
      },
      {
        "type": "color",
        "id": "color_green",
        "label": "Green Accent",
        "default": "#1e3524"
      },
      {
        "type": "color",
        "id": "color_drawer_bg",
        "label": "Drawer Background Color",
        "default": "#ffffff"
      },
      {
        "type": "color",
        "id": "color_drawer_footer_bg",
        "label": "Drawer Footer Background Color",
        "default": "#faf9f5"
      },
      {
        "type": "color",
        "id": "color_white",
        "label": "White / Light Accent",
        "default": "#ffffff"
      }
    ]
  },
  {
    "name": "Typography",
    "settings": [
      {
        "type": "font_picker",
        "id": "font_body",
        "label": "Body Font",
        "default": "assistant_n4"
      },
      {
        "type": "font_picker",
        "id": "font_heading",
        "label": "Heading Font",
        "default": "assistant_n4"
      }
    ]
  },
  {
    "name": "Slideshow Settings",
    "settings": [
      {
        "type": "checkbox",
        "id": "slideshow_enabled_homepage",
        "label": "Enable Slideshow on Homepage Showcase",
        "default": true
      },
      {
        "type": "checkbox",
        "id": "slideshow_enabled_collections",
        "label": "Enable Slideshow on Collection Pages",
        "default": true
      },
      {
        "type": "checkbox",
        "id": "slideshow_enabled_products",
        "label": "Enable Slideshow on Product Detail Pages",
        "default": true
      },
      {
        "type": "range",
        "id": "slideshow_interval",
        "label": "Slideshow Interval (Seconds)",
        "min": 2,
        "max": 10,
        "step": 1,
        "default": 5,
        "unit": "s"
      }
    ]
  }
]
