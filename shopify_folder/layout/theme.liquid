  <body class="template-{{ template | replace: '.', '-' }} dept-women" style="overflow-x:hidden;">

    {%- section 'header' -%}

    <main id="MainContent" class="content-for-layout" role="main" tabindex="-1">
      {{ content_for_layout }}
    </main>

    {%- sections 'footer-group' -%}

    <script>
      function initScrollReveal() {
        if ('IntersectionObserver' in window) {
          const observerOptions = {
            root: null,
            rootMargin: '0px 0px -50px 0px',
            threshold: 0.05
          };

          const observer = new IntersectionObserver((entries, observer) => {
            entries.forEach(entry => {
              if (entry.isIntersecting) {
                entry.target.classList.add('in-view');
                entry.target.classList.add('revealed');
                observer.unobserve(entry.target);
              }
            });
          }, observerOptions);

          const selectors = [
            '.qtr-hero',
            '.home-hero-content',
            '.hero-banner',
            '.product-showcase',
            '.qtr-section',
            '.product-card',
            '.testimonials',
            '.testimonial-section',
            '.image-with-text',
            '.luxury-showcase',
            '.above-footer-banner'
          ];

          selectors.forEach(selector => {
            document.querySelectorAll(selector).forEach(el => {
              // Exclude Header, Announcement bar, Cart drawer, Product main page info, and critical CTA buttons
              if (el.closest('header') || 
                  el.closest('#shopify-section-header') ||
                  el.closest('[id*="announcement-bar"]') ||
                  el.closest('.cart-drawer') || 
                  el.closest('.product-info') || 
                  el.closest('.product-details') ||
                  el.closest('.main-product-section') ||
                  el.classList.contains('buy-now-btn') ||
                  el.classList.contains('add-to-cart-btn') ||
                  el.classList.contains('wish-to-cart-btn') ||
                  el.classList.contains('btn-primary') ||
                  el.classList.contains('checkout-btn')) {
                return;
              }
              el.classList.add('scroll-reveal');
              observer.observe(el);
            });
          });
        }
      }

      if (document.readyState === 'loading') {
        document.addEventListener('DOMContentLoaded', initScrollReveal);
      } else {
        initScrollReveal();
      }
    </script>
  </body>
