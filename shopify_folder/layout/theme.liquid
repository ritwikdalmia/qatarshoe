{% comment %}
========================================================================
Theme Name: Qatar Shoes Clean Replica
Developed By: AlgoGuru Technologies (Ritwik Dalmia)
Contact: algogurutechnologies@gmail.com
All rights reserved. Unauthorized duplication or distribution is prohibited.
========================================================================
{% endcomment %}
<!doctype html>
<html class="no-js" lang="{{ request.locale.iso_code }}"
      dir="{% if request.locale.iso_code == 'ar' %}rtl{% else %}ltr{% endif %}">
  <head>
    <meta charset="utf-8">
    <meta http-equiv="X-UA-Compatible" content="IE=edge">
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <link rel="canonical" href="{{ canonical_url }}">
    <link rel="preconnect" href="https://cdn.shopify.com" crossorigin>

    {%- if settings.favicon != blank -%}
      <link rel="icon" type="image/png" href="{{ settings.favicon | image_url: width: 32, height: 32 }}">
    {%- endif -%}

    <title>
      {{ page_title }}
      {%- if current_tags %} &ndash; tagged "{{ current_tags | join: ', ' }}"{% endif -%}
      {%- if current_page != 1 %} &ndash; Page {{ current_page }}{% endif -%}
      {%- unless page_title contains shop.name -%} &ndash; {{ shop.name }}{%- endunless -%}
    </title>

    {% if page_description %}
      <meta name="description" content="{{ page_description | escape }}">
    {% endif %}

    {{ content_for_header }}

    
    {%- # theme-check-disable RemoteAsset -%}
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet">
    {%- if request.locale.iso_code == 'ar' -%}
    <link href="https://fonts.googleapis.com/css2?family=Cairo:wght@300;400;500;600;700&display=swap" rel="stylesheet">
    {%- endif -%}
    {%- # theme-check-enable RemoteAsset -%}

    
    <link rel="stylesheet" href="{{ 'theme.css' | asset_url }}&v=1.0.2" type="text/css" media="all">
    {%- if template contains 'customer' -%}
      {{ 'accounts.css' | asset_url | stylesheet_tag }}
    {%- endif -%}

    <style>
      :root {
        --color-bg: {{ settings.color_bg | default: '#faf9f5' }};
        --color-primary: {{ settings.color_primary | default: '#2d1f1f' }};
        --color-accent: {{ settings.color_accent | default: '#f25c5e' }};
        --color-border: {{ settings.color_border | default: '#e0dcd3' }};
        --color-muted: {{ settings.color_muted | default: '#000000' }};
        --color-dark-teal: {{ settings.color_dark_teal | default: '#304854' }};
        --color-green: {{ settings.color_green | default: '#1e3524' }};
        --color-drawer-bg: {{ settings.color_drawer_bg | default: '#ffffff' }};
        --color-drawer-footer-bg: {{ settings.color_drawer_footer_bg | default: '#faf9f5' }};

        /* Button Colors */
        --color-button-primary-bg: {{ settings.color_primary | default: '#8c1638' }};
        --color-button-primary-label: {{ settings.color_text | default: '#ffffff' }};
        --color-button-primary-hover-bg: {{ settings.color_bg | default: '#f9f2d5' }};
        --color-button-primary-hover-label: {{ settings.color_primary | default: '#8c1638' }};

        --color-button-secondary-bg: {{ settings.color_bg | default: '#f9f2d5' }};
        --color-button-secondary-label: {{ settings.color_primary | default: '#8c1638' }};
        --color-button-secondary-hover-bg: {{ settings.color_primary | default: '#8c1638' }};
        --color-button-secondary-hover-label: {{ settings.color_text | default: '#ffffff' }};

        /* Dynamic Layout spacing */
        --logo-width: {{ settings.logo_width | default: 150 }}px;
        --page-width: {{ settings.page_width | default: 1200 }}px;
        --spacing-sections: {{ settings.spacing_sections | default: 32 }}px;
        --spacing-grid-horizontal: {{ settings.spacing_grid_horizontal | default: 16 }}px;
        --spacing-grid-vertical: {{ settings.spacing_grid_vertical | default: 16 }}px;

        /* Dynamic Badges */
        --badge-corner-radius: {{ settings.badge_corner_radius | default: 4 }}px;

        /* Dynamic Buttons */
        --buttons-border-thickness: {{ settings.buttons_border_thickness | default: 1 }}px;
        --buttons-border-opacity: {{ settings.buttons_border_opacity | default: 100 | divided_by: 100.0 }};
        --buttons-radius: {{ settings.buttons_radius | default: 8 }}px;
        --buttons-shadow-opacity: {{ settings.buttons_shadow_opacity | default: 0 | divided_by: 100.0 }};
        --buttons-shadow-horizontal-offset: {{ settings.buttons_shadow_horizontal_offset | default: 0 }}px;
        --buttons-shadow-vertical-offset: {{ settings.buttons_shadow_vertical_offset | default: 0 }}px;
        --buttons-shadow-blur: {{ settings.buttons_shadow_blur | default: 0 }}px;

        /* Dynamic Input fields */
        --inputs-border-thickness: {{ settings.inputs_border_thickness | default: 1 }}px;
        --inputs-border-opacity: {{ settings.inputs_border_opacity | default: 100 | divided_by: 100.0 }};
        --inputs-radius: {{ settings.inputs_radius | default: 8 }}px;
        --inputs-shadow-opacity: {{ settings.inputs_shadow_opacity | default: 0 | divided_by: 100.0 }};
        --inputs-shadow-horizontal-offset: {{ settings.inputs_shadow_horizontal_offset | default: 0 }}px;
        --inputs-shadow-vertical-offset: {{ settings.inputs_shadow_vertical_offset | default: 0 }}px;
        --inputs-shadow-blur: {{ settings.inputs_shadow_blur | default: 0 }}px;

        /* Dynamic Popovers and Modals */
        --popovers-border-thickness: {{ settings.popovers_border_thickness | default: 1 }}px;
        --popovers-radius: {{ settings.popovers_radius | default: 8 }}px;
        --popovers-shadow-opacity: {{ settings.popovers_shadow_opacity | default: 10 | divided_by: 100.0 }};
        --popovers-shadow-horizontal-offset: {{ settings.popovers_shadow_horizontal_offset | default: 0 }}px;
        --popovers-shadow-vertical-offset: {{ settings.popovers_shadow_vertical_offset | default: 4 }}px;
        --popovers-shadow-blur: {{ settings.popovers_shadow_blur | default: 10 }}px;

        /* Dynamic Product cards */
        --card-image-padding: {{ settings.card_image_padding | default: 0 }}px;
        --card-text-alignment: {{ settings.card_text_alignment | default: 'left' }};
        --card-corner-radius: {{ settings.card_corner_radius | default: 12 }}px;
        --card-border-thickness: {{ settings.card_border_thickness | default: 1 }}px;
        --card-border-opacity: {{ settings.card_border_opacity | default: 100 | divided_by: 100.0 }};
        --card-shadow-opacity: {{ settings.card_shadow_opacity | default: 0 | divided_by: 100.0 }};
        --card-shadow-horizontal-offset: {{ settings.card_shadow_horizontal_offset | default: 0 }}px;
        --card-shadow-vertical-offset: {{ settings.card_shadow_vertical_offset | default: 0 }}px;
        --card-shadow-blur: {{ settings.card_shadow_blur | default: 0 }}px;
      }

      /* Global style overrides to enforce client background and accent colors */
      body {
        background-color: var(--color-bg) !important;
      }
      
      .site-footer,
      .site-footer-panel-left,
      .site-footer-panel-right,
      .site-footer-links-area,
      .site-footer-feature-item,
      .site-footer-bottom,
      .contact-form-section,
      .faq-main,
      .faq-sidebar-item,
      .pp-sidebar-item,
      .faq-search-wrap,
      .faq-item,
      .faq-mobile-bar,
      .faq-mobile-overlay-item,
      .pp-mobile-overlay-item,
      .pp-content,
      .contact-card,
      .cc-quick-help-card,
      .sd-hero,
      .sd-services,
      .sd-timeline-card,
      .sd-timelines,
      .rr-hero,
      .rr-eligibility,
      .rr-eligibility-card,
      .rr-side-card,
      .rr-non-returnable,
      .rr-refund,
      .rr-sides,
      .sitemap-main,
      .about-main,
      .contact-main,
      .care-main,
      .payments-main,
      .tos-main,
      .privacy-main,
      .contact-page-wrap,
      .contact-page-card,
      .cc-page,
      .rr-main,
      .sd-main,
      .ps-main,
      .about-main-wrapper,
      .collection-toolbar,
      .filter-pill,
      .cs-trigger,
      .cs-options,
      .filters-clear-btn {
        background-color: var(--color-bg) !important;
      }

      .site-footer-subscribe-form .wpcf7-submit,
      .contact-submit-custom {
        background-color: var(--color-button-secondary-bg) !important;
        border-color: var(--color-button-secondary-label) !important;
        color: var(--color-button-secondary-label) !important;
      }

      .wishlist-count,
      .cart-count-badge {
        background-color: var(--color-border) !important;
        color: var(--color-primary) !important;
      }

      .site-footer-subscribe-form .wpcf7-submit:hover,
      .contact-submit-custom:hover {
        background-color: var(--color-button-secondary-hover-bg) !important;
        color: var(--color-button-secondary-hover-label) !important;
        border-color: var(--color-button-secondary-hover-bg) !important;
      }

      .site-footer-legal {
        background-color: var(--color-primary) !important;
      }

      /* Home page section borders - use primary color */
      .section-heading-row {
        border: var(--card-border-thickness) solid var(--color-primary) !important;
        border-bottom: none !important;
      }
      .product-card {
        border: var(--card-border-thickness) solid var(--color-primary) !important;
        border-radius: var(--card-corner-radius) !important;
        overflow: hidden !important;
        box-shadow: var(--card-shadow-horizontal-offset) var(--card-shadow-vertical-offset) var(--card-shadow-blur) rgba(0,0,0,var(--card-shadow-opacity)) !important;
        text-align: var(--card-text-alignment) !important;
      }
      .product-card-img,
      .product-card-placeholder {
        border-radius: var(--card-corner-radius) var(--card-corner-radius) 0 0 !important;
      }
      .product-card-img img {
        padding: var(--card-image-padding) !important;
      }
      .brands-on-amirivibes .brand-item {
        outline: var(--card-border-thickness) solid var(--color-primary) !important;
        border: var(--card-border-thickness) solid var(--color-primary) !important;
        border-radius: var(--card-corner-radius) !important;
      }

      /* Footer border lines -> primary color */
      .site-footer-panel-right {
        border: 1px solid var(--color-primary) !important;
        border-radius: 12px !important;
        overflow: hidden !important;
      }
      .site-footer-features {
        border-top: 1px solid var(--color-primary) !important;
      }
      .site-footer-feature-item {
        border-right: 1px solid var(--color-primary) !important;
      }
      .site-footer-feature-item:last-child {
        border-right: none !important;
      }
      @media (max-width: 767px) {
        .site-footer-panel-right {
          border-color: var(--color-primary) !important;
        }
        .site-footer-bottom-inner {
          border-top: 1px solid var(--color-primary) !important;
        }
        .site-footer-feature-item {
          border-bottom: 1px solid var(--color-primary) !important;
          border-right: none !important;
        }
        .site-footer-feature-item:last-child {
          border-bottom: none !important;
        }
      }

      .product-thumbnails img:hover,
      .product-thumbnails img.active {
        border-color: var(--color-primary) !important;
      }
      .size-option {
        border-color: var(--color-primary) !important;
        border-radius: 8px !important;
      }
      .quantity-controls {
        border-color: var(--color-primary) !important;
        border-radius: 8px !important;
        overflow: hidden !important;
      }
      .quantity-controls input {
        border-left-color: var(--color-primary) !important;
        border-right-color: var(--color-primary) !important;
      }
      .cta-wrapper .checkout-btn {
        border-radius: var(--buttons-radius) !important;
      }
      .est-delivery {
        border-color: var(--color-primary) !important;
        border-radius: var(--card-corner-radius) !important;
        overflow: hidden !important;
      }
      .delivery-info-strip {
        border-top-color: var(--color-primary) !important;
        border-bottom-color: var(--color-primary) !important;
      }
      .product-accordions {
        border-top-color: var(--color-primary) !important;
      }
      .accordion-item {
        border-bottom-color: var(--color-primary) !important;
      }

      /* Department toggle buttons matching the brand theme */
      .dept-toggle .dept-link.active {
        color: #fff !important;
        background: var(--color-primary) !important;
        box-shadow: 0 2px 8px rgba(140, 22, 56, 0.3);
      }
      .dept-toggle .dept-link:hover:not(.active) {
        color: #fff !important;
        background: rgba(255, 255, 255, 0.12) !important;
      }

      /* Contact Us page border overrides */
      .contact-cards {
        border-bottom-color: var(--color-primary) !important;
      }
      .contact-card {
        border-right-color: var(--color-primary) !important;
      }
      .contact-card-link {
        border-color: var(--color-primary) !important;
        color: var(--color-primary) !important;
      }
      .contact-card-link:hover {
        background: var(--color-primary) !important;
        color: #fff !important;
      }
      .contact-field-group label {
        color: var(--color-primary) !important;
        font-family: 'Inter', sans-serif !important;
        font-weight: 500 !important;
      }
      .contact-field-group label .required {
        color: var(--color-primary) !important;
      }
      .contact-form-wrapper input[type="text"],
      .contact-form-wrapper input[type="email"],
      .contact-form-wrapper input[type="tel"],
      .contact-form-wrapper textarea {
        background-color: var(--color-bg) !important;
        border: 1.5px solid var(--color-primary) !important;
        border-radius: 8px !important;
        color: var(--color-primary) !important;
        font-family: 'Inter', sans-serif !important;
        font-size: 14px !important;
      }
      .contact-form-wrapper input[type="text"]:focus,
      .contact-form-wrapper input[type="email"]:focus,
      .contact-form-wrapper input[type="tel"]:focus,
      .contact-form-wrapper textarea:focus {
        border-color: var(--color-primary) !important;
        outline: none !important;
      }
      .contact-submit-custom {
        border: 1.5px solid var(--color-primary) !important;
        color: var(--color-primary) !important;
        background-color: var(--color-bg) !important;
      }
      .contact-submit-custom:hover {
        background-color: var(--color-primary) !important;
        color: var(--color-bg) !important;
      }
      @media (max-width: 767px) {
        .contact-card {
          border-bottom-color: var(--color-primary) !important;
        }
      }

      /* FAQs / Customer Care page border overrides */
      .faq-sidebar-nav {
        border-color: var(--color-primary) !important;
      }
      .faq-sidebar-item {
        border-bottom-color: var(--color-primary) !important;
      }
      .faq-search {
        border-color: var(--color-primary) !important;
      }
      .faq-items-container {
        background: var(--color-primary) !important;
      }
      .faq-mobile-bar {
        border-color: var(--color-primary) !important;
      }

      /* Internal footer pages borders - update all to theme primary color */
      
      /* Shipping & Delivery */
      .sd-services,
      .sd-services-card,
      .sd-timeline-card,
      .sd-timelines,
      .sd-timeline-card::after,
      .sd-timeline-card::before {
        border-color: var(--color-primary) !important;
      }

      /* Returns & Refunds */
      .rr-eligibility-card,
      .rr-side-card,
      .rr-non-returnable-card,
      .rr-refund,
      .rr-sides,
      .rr-non-returnable {
        border-color: var(--color-primary) !important;
      }
      .rr-eligibility,
      .rr-side-card {
        border-color: var(--color-primary) !important;
      }
      /* Non-returnable grid outer border and column separators */
      .rr-non-returnable-grid {
        border: 1.5px solid var(--color-primary) !important;
      }
      .rr-non-returnable-card {
        border-right: 1.5px solid var(--color-primary) !important;
      }
      @media (max-width: 1023px) {
        .rr-non-returnable-card {
          border-right: none !important;
          border-bottom: 1.5px solid var(--color-primary) !important;
        }
        .rr-non-returnable-card:last-child {
          border-bottom: none !important;
        }
      }
      /* Refund Processing section label bottom border */
      .rr-refund-label {
        border-bottom-color: var(--color-primary) !important;
      }
      /* Contact form section separator line */
      .contact-form-section::before {
        background: var(--color-primary) !important;
      }

      /* Payments & Pricing */
      .payments-main,
      .payments-card,
      .payments-method-card,
      .payments-grid-card {
        border-color: var(--color-primary) !important;
      }

      /* Customer Care page */
      .care-main,
      .cc-quick-help-card,
      .cc-quick-help-card-btn {
        border-color: var(--color-primary) !important;
        color: var(--color-primary) !important;
      }
      .cc-quick-help-card-btn:hover {
        background: var(--color-primary) !important;
        color: #fff !important;
      }

      /* About Us */
      .about-main,
      .about-history-card,
      .about-value-card,
      .about-team-card {
        border-color: var(--color-primary) !important;
      }

      /* Sitemap */
      .sitemap-main,
      .sitemap-card,
      .sitemap-col {
        border-color: var(--color-primary) !important;
      }
      .sitemap-card {
        border-color: var(--color-primary) !important;
      }
      .sitemap-link {
        border-bottom-color: var(--color-primary) !important;
        color: #2D1F1F !important;
      }
      .sitemap-link:hover {
        opacity: 1 !important;
        color: var(--color-primary) !important;
      }
      .sitemap-link:hover span {
        color: var(--color-primary) !important;
      }
      /* Sitemap nested heading border and hover */
      .sitemap-link-level-1 {
        border-bottom-color: var(--color-primary) !important;
        color: #2D1F1F !important;
      }
      .sitemap-link-level-1:hover {
        opacity: 1 !important;
        color: var(--color-primary) !important;
      }
      .sitemap-link-level-2:hover {
        opacity: 1 !important;
        color: var(--color-primary) !important;
      }
      .sitemap-link-level-3:hover {
        color: var(--color-primary) !important;
      }
      .sitemap-toggle-btn {
        border-bottom-color: var(--color-primary) !important;
      }
      .sitemap-toggle-btn:hover {
        opacity: 1 !important;
        color: var(--color-primary) !important;
      }

      /* Terms of Service & Privacy Policy */
      .tos-main,
      .privacy-main,
      .pp-content,
      .pp-mobile-overlay-card {
        border-color: var(--color-primary) !important;
      }

      /* Shopify default policy pages styling */
      .shopify-policy__container {
        max-width: 800px !important;
        margin: 80px auto !important;
        padding: 0 24px !important;
        background-color: var(--color-bg) !important;
      }
      .shopify-policy__title {
        margin-bottom: 40px !important;
        text-align: center !important;
      }
      .shopify-policy__title h1 {
        font-family: 'Canela Text', Georgia, serif !important;
        font-size: 48px !important;
        font-weight: 400 !important;
        color: var(--color-primary) !important;
        line-height: 1.2 !important;
        margin: 0 !important;
        text-transform: capitalize !important;
      }
      .shopify-policy__body {
        font-family: 'Inter', sans-serif !important;
        font-size: 16px !important;
        line-height: 1.6 !important;
        color: #000000 !important;
      }
      .shopify-policy__body p {
        margin-bottom: 12px !important;
        color: #000000 !important;
      }
      .shopify-policy__body ul,
      .shopify-policy__body ol {
        margin-bottom: 12px !important;
        padding-left: 20px !important;
      }
      .shopify-policy__body ul li,
      .shopify-policy__body ol li {
        margin-bottom: 6px !important;
        color: #000000 !important;
      }
      .shopify-policy__body li strong,
      .shopify-policy__body p strong {
        display: block !important;
        text-align: center !important;
        color: var(--color-primary) !important;
        font-size: 18px !important;
        margin-top: 16px !important;
        margin-bottom: 4px !important;
        font-weight: 600 !important;
      }
      .shopify-policy__body h2,
      .shopify-policy__body h3 {
        font-family: 'Inter', sans-serif !important;
        color: var(--color-primary) !important;
        margin-top: 2em !important;
        margin-bottom: 0.8em !important;
        font-weight: 600 !important;
      }

      /* Make internal page text uniform, solid black, and correctly sized */
      .faq-answer p, 
      .faq-answer div,
      .faq-subtitle,
      .pp-subtitle,
      .pp-section-body p,
      .pp-intro p,
      .contact-page-header p,
      .contact-card-desc,
      .contact-form-intro-text p,
      .cc-hero-subtitle,
      .cc-feature-desc,
      .cc-quick-help-desc,
      .cc-quick-help-card-desc,
      .cc-commitment-text,
      .payments-desc,
      .tos-desc,
      .privacy-desc,
      .sd-timeline-desc,
      .rr-eligibility-desc,
      .pp-block-intro,
      .pp-block-bullets,
      .pp-block-bullets li,
      .pp-block-richtext p,
      .pp-block-richtext ul li,
      .pp-method-item,
      .rr-refund-text,
      .sd-hero-subtitle,
      .rr-hero-subtitle,
      .ps-hero-subtitle,
      .about-intro-text,
      .about-offer-card-name,
      .sd-service-row-desc,
      .sd-timeline-label,
      .sd-timeline-value,
      .rr-eligibility-card-desc,
      .rr-side-card-list li {
        font-family: 'Inter', sans-serif !important;
        font-size: 15px !important;
        line-height: 1.6 !important;
        color: #000000 !important;
      }

      .about-offer-card-name {
        color: var(--color-primary) !important;
        font-weight: 600 !important;
      }

      /* Make internal page main headings uniform */
      .faq-title,
      .pp-title,
      .contact-page-header h1,
      .cc-hero-title,
      .sd-hero-title,
      .rr-hero-title,
      .about-hero h1,
      .about-hero-title,
      .payments-hero-title,
      .tos-hero-title,
      .privacy-hero-title,
      .ps-hero-title,
      .sitemap-main h1,
      .sitemap-hero-content h1,
      .shopify-policy__title h1 {
        font-family: 'Canela Text', Georgia, serif !important;
        font-size: 48px !important;
        font-weight: 400 !important;
        line-height: 1.2 !important;
        color: var(--color-primary) !important;
        text-align: center !important;
        margin-bottom: 16px !important;
        text-transform: capitalize !important;
      }

      /* Make internal page header/hero subheadings uniform and centered */
      .contact-page-header,
      .cc-hero-content,
      .sd-hero-content,
      .rr-hero-content,
      .payments-hero-content,
      .about-hero-content,
      .faq-header,
      .ps-hero-content,
      .sitemap-header,
      .sitemap-hero-content,
      .shopify-policy__title {
        text-align: center !important;
        align-items: center !important;
        display: flex !important;
        flex-direction: column !important;
        justify-content: center !important;
        padding-top: 40px !important; /* Push down to avoid sticky header cropping */
      }

      .contact-page-header p,
      .cc-hero-subtitle,
      .sd-hero-subtitle,
      .rr-hero-subtitle,
      .payments-desc,
      .about-hero-content p,
