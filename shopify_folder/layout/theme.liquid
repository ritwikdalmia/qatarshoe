{% comment %}
========================================================================
Theme Name: Qatar Shoes Clean Replica
Developed By: AlgoGuru Technologies (Ritwik Dalmia)
Contact: algogurutechnologies@gmail.com
All rights reserved. Unauthorized duplication or distribution is prohibited.
========================================================================
{% endcomment %}
<!doctype html>
<html class="no-js" lang="{{ request.locale.iso_code }}"
      dir="{% if request.locale.iso_code == 'ar' %}rtl{% else %}ltr{% endif %}">
  <head>
    <meta charset="utf-8">
    <meta http-equiv="X-UA-Compatible" content="IE=edge">
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <link rel="canonical" href="{{ canonical_url }}">
    <link rel="preconnect" href="https://cdn.shopify.com" crossorigin>

    {%- if settings.favicon != blank -%}
      <link rel="icon" type="image/png" href="{{ settings.favicon | image_url: width: 32, height: 32 }}">
    {%- endif -%}

    <title>
      {{ page_title }}
      {%- if current_tags %} &ndash; tagged "{{ current_tags | join: ', ' }}"{% endif -%}
      {%- if current_page != 1 %} &ndash; Page {{ current_page }}{% endif -%}
      {%- unless page_title contains shop.name -%} &ndash; {{ shop.name }}{%- endunless -%}
    </title>

    {% if page_description %}
      <meta name="description" content="{{ page_description | escape }}">
    {% endif %}

    {{ content_for_header }}

    
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet">

    
    {{ 'theme.css' | asset_url | stylesheet_tag }}
    {%- if template contains 'customer' -%}
      {{ 'accounts.css' | asset_url | stylesheet_tag }}
    {%- endif -%}

    <style>
      :root {
        --color-bg: {{ settings.color_bg | default: '#faf9f5' }};
        --color-primary: {{ settings.color_primary | default: '#2d1f1f' }};
        --color-accent: {{ settings.color_accent | default: '#f25c5e' }};
        --color-border: {{ settings.color_border | default: '#e0dcd3' }};
        --color-muted: {{ settings.color_muted | default: '#000000' }};
        --color-dark-teal: {{ settings.color_dark_teal | default: '#304854' }};
        --color-green: {{ settings.color_green | default: '#1e3524' }};
        --color-drawer-bg: {{ settings.color_drawer_bg | default: '#ffffff' }};
        --color-drawer-footer-bg: {{ settings.color_drawer_footer_bg | default: '#faf9f5' }};
      }

      /* Global style overrides to enforce client background and accent colors */
      body {
        background-color: var(--color-bg) !important;
      }
      
      .site-footer,
      .site-footer-panel-left,
      .site-footer-panel-right,
      .site-footer-links-area,
      .site-footer-feature-item,
      .site-footer-bottom,
      .contact-form-section,
      .faq-main,
      .faq-sidebar-item,
      .pp-sidebar-item,
      .faq-search-wrap,
      .faq-item,
      .faq-mobile-bar,
      .faq-mobile-overlay-item,
      .pp-mobile-overlay-item,
      .pp-content,
      .contact-card,
      .cc-quick-help-card,
      .sd-hero,
      .sd-services,
      .sd-timeline-card,
      .sd-timelines,
      .rr-hero,
      .rr-eligibility,
      .rr-eligibility-card,
      .rr-side-card,
      .rr-non-returnable,
      .rr-refund,
      .rr-sides,
      .sitemap-main,
      .about-main,
      .contact-main,
      .care-main,
      .payments-main,
      .tos-main,
      .privacy-main,
      .contact-page-wrap,
      .contact-page-card,
      .cc-page,
      .rr-main,
      .sd-main,
      .ps-main,
      .about-main-wrapper,
      .collection-toolbar,
      .filter-pill,
      .cs-trigger,
      .cs-options,
      .filters-clear-btn {
        background-color: var(--color-bg) !important;
      }

      .site-footer-subscribe-form .wpcf7-submit,
      .contact-submit-custom {
        background-color: var(--color-bg) !important;
        border-color: var(--color-primary) !important;
        color: var(--color-primary) !important;
      }

      .wishlist-count,
      .cart-count-badge {
        background-color: var(--color-border) !important;
        color: var(--color-primary) !important;
      }

      .site-footer-subscribe-form .wpcf7-submit:hover,
      .contact-submit-custom:hover {
        background-color: var(--color-primary) !important;
        color: var(--color-bg) !important;
      }

      .site-footer-legal {
        background-color: var(--color-primary) !important;
      }

      /* Home page section borders - use primary color */
      .section-heading-row {
        border: 1.5px solid var(--color-primary) !important;
        border-bottom: none !important;
      }
      .product-card {
        border: 1.5px solid var(--color-primary) !important;
      }
      .brands-on-amirivibes .brand-item {
        outline: 1px solid var(--color-primary) !important;
        border: 1px solid var(--color-primary) !important;
      }

      /* Footer border lines -> primary color */
      .site-footer-panel-right {
        border: 1px solid var(--color-primary) !important;
      }
      .site-footer-features {
        border-top: 1px solid var(--color-primary) !important;
      }
      .site-footer-feature-item {
        border-right: 1px solid var(--color-primary) !important;
      }
      @media (max-width: 767px) {
        .site-footer-panel-right {
          border-color: var(--color-primary) !important;
        }
        .site-footer-bottom-inner {
          border-top: 1px solid var(--color-primary) !important;
        }
        .site-footer-feature-item {
          border-bottom: 1px solid var(--color-primary) !important;
        }
      }

      /* Product detail page border lines -> primary color */
      .product-thumbnails img {
        border-color: var(--color-primary) !important;
      }
      .size-option {
        border-color: var(--color-primary) !important;
      }
      .quantity-controls {
        border-color: var(--color-primary) !important;
      }
      .quantity-controls input {
        border-left-color: var(--color-primary) !important;
        border-right-color: var(--color-primary) !important;
      }
      .delivery-info-strip {
        border-top-color: var(--color-primary) !important;
        border-bottom-color: var(--color-primary) !important;
      }
      .product-accordions {
        border-top-color: var(--color-primary) !important;
      }
      .accordion-item {
        border-bottom-color: var(--color-primary) !important;
      }

      /* Department toggle buttons matching the brand theme */
      .dept-toggle .dept-link.active {
        color: #fff !important;
        background: var(--color-primary) !important;
        box-shadow: 0 2px 8px rgba(140, 22, 56, 0.3);
      }
      .dept-toggle .dept-link:hover:not(.active) {
        color: #fff !important;
        background: rgba(255, 255, 255, 0.12) !important;
      }

      /* Contact Us page border overrides */
      .contact-cards {
        border-bottom-color: var(--color-primary) !important;
      }
      .contact-card {
        border-right-color: var(--color-primary) !important;
      }
      .contact-card-link {
        border-color: var(--color-primary) !important;
        color: var(--color-primary) !important;
      }
      .contact-card-link:hover {
        background: var(--color-primary) !important;
        color: #fff !important;
      }
      .contact-field-group label {
        color: var(--color-primary) !important;
        font-family: 'Inter', sans-serif !important;
        font-weight: 500 !important;
      }
      .contact-field-group label .required {
        color: var(--color-primary) !important;
      }
      .contact-form-wrapper input[type="text"],
      .contact-form-wrapper input[type="email"],
      .contact-form-wrapper input[type="tel"],
      .contact-form-wrapper textarea {
        background-color: var(--color-bg) !important;
        border: 1.5px solid var(--color-primary) !important;
        border-radius: 8px !important;
        color: var(--color-primary) !important;
        font-family: 'Inter', sans-serif !important;
        font-size: 14px !important;
      }
      .contact-form-wrapper input[type="text"]:focus,
      .contact-form-wrapper input[type="email"]:focus,
      .contact-form-wrapper input[type="tel"]:focus,
      .contact-form-wrapper textarea:focus {
        border-color: var(--color-primary) !important;
        outline: none !important;
      }
      .contact-submit-custom {
        border: 1.5px solid var(--color-primary) !important;
        color: var(--color-primary) !important;
        background-color: var(--color-bg) !important;
      }
      .contact-submit-custom:hover {
        background-color: var(--color-primary) !important;
        color: var(--color-bg) !important;
      }
      @media (max-width: 767px) {
        .contact-card {
          border-bottom-color: var(--color-primary) !important;
        }
      }

      /* FAQs / Customer Care page border overrides */
      .faq-sidebar-nav {
        border-color: var(--color-primary) !important;
      }
      .faq-sidebar-item {
        border-bottom-color: var(--color-primary) !important;
      }
      .faq-search {
        border-color: var(--color-primary) !important;
      }
      .faq-items-container {
        background: var(--color-primary) !important;
      }
      .faq-mobile-bar {
        border-color: var(--color-primary) !important;
      }

      /* Internal footer pages borders - update all to theme primary color */
      
      /* Shipping & Delivery */
      .sd-services,
      .sd-services-card,
      .sd-timeline-card,
      .sd-timelines,
      .sd-timeline-card::after,
      .sd-timeline-card::before {
        border-color: var(--color-primary) !important;
      }

      /* Returns & Refunds */
      .rr-eligibility-card,
      .rr-side-card,
      .rr-non-returnable-card,
      .rr-refund,
      .rr-sides,
      .rr-non-returnable {
        border-color: var(--color-primary) !important;
      }
      .rr-eligibility,
      .rr-side-card {
        border-color: var(--color-primary) !important;
      }
      /* Non-returnable grid outer border and column separators */
      .rr-non-returnable-grid {
        border: 1.5px solid var(--color-primary) !important;
      }
      .rr-non-returnable-card {
        border-right: 1.5px solid var(--color-primary) !important;
      }
      @media (max-width: 1023px) {
        .rr-non-returnable-card {
          border-right: none !important;
          border-bottom: 1.5px solid var(--color-primary) !important;
        }
        .rr-non-returnable-card:last-child {
          border-bottom: none !important;
        }
      }
      /* Refund Processing section label bottom border */
      .rr-refund-label {
        border-bottom-color: var(--color-primary) !important;
      }
      /* Contact form section separator line */
      .contact-form-section::before {
        background: var(--color-primary) !important;
      }

      /* Payments & Pricing */
      .payments-main,
      .payments-card,
      .payments-method-card,
      .payments-grid-card {
        border-color: var(--color-primary) !important;
      }

      /* Customer Care page */
      .care-main,
      .cc-quick-help-card,
      .cc-quick-help-card-btn {
        border-color: var(--color-primary) !important;
        color: var(--color-primary) !important;
      }
      .cc-quick-help-card-btn:hover {
        background: var(--color-primary) !important;
        color: #fff !important;
      }

      /* About Us */
      .about-main,
      .about-history-card,
      .about-value-card,
      .about-team-card {
        border-color: var(--color-primary) !important;
      }

      /* Sitemap */
      .sitemap-main,
      .sitemap-card,
      .sitemap-col {
        border-color: var(--color-primary) !important;
      }
      .sitemap-card {
        border-color: var(--color-primary) !important;
      }
      .sitemap-link {
        border-bottom-color: var(--color-primary) !important;
        color: #2D1F1F !important;
      }
      .sitemap-link:hover {
        opacity: 1 !important;
        color: var(--color-primary) !important;
      }
      .sitemap-link:hover span {
        color: var(--color-primary) !important;
      }
      /* Sitemap nested heading border and hover */
      .sitemap-link-level-1 {
        border-bottom-color: var(--color-primary) !important;
        color: #2D1F1F !important;
      }
      .sitemap-link-level-1:hover {
        opacity: 1 !important;
        color: var(--color-primary) !important;
      }
      .sitemap-link-level-2:hover {
        opacity: 1 !important;
        color: var(--color-primary) !important;
      }
      .sitemap-link-level-3:hover {
        color: var(--color-primary) !important;
      }
      .sitemap-toggle-btn {
        border-bottom-color: var(--color-primary) !important;
      }
      .sitemap-toggle-btn:hover {
        opacity: 1 !important;
        color: var(--color-primary) !important;
      }

      /* Terms of Service & Privacy Policy */
      .tos-main,
      .privacy-main,
      .pp-content,
      .pp-mobile-overlay-card {
        border-color: var(--color-primary) !important;
      }

      /* Shopify default policy pages styling */
      .shopify-policy__container {
        max-width: 800px !important;
        margin: 80px auto !important;
        padding: 0 24px !important;
        background-color: var(--color-bg) !important;
      }
      .shopify-policy__title {
        margin-bottom: 40px !important;
        text-align: center !important;
      }
      .shopify-policy__title h1 {
        font-family: 'Canela Text', Georgia, serif !important;
        font-size: 48px !important;
        font-weight: 400 !important;
        color: var(--color-primary) !important;
        line-height: 1.2 !important;
        margin: 0 !important;
        text-transform: capitalize !important;
      }
      .shopify-policy__body {
        font-family: 'Inter', sans-serif !important;
        font-size: 16px !important;
        line-height: 1.6 !important;
        color: #000000 !important;
      }
      .shopify-policy__body p {
        margin-bottom: 12px !important;
        color: #000000 !important;
      }
      .shopify-policy__body ul,
      .shopify-policy__body ol {
        margin-bottom: 12px !important;
        padding-left: 20px !important;
      }
      .shopify-policy__body ul li,
      .shopify-policy__body ol li {
        margin-bottom: 6px !important;
        color: #000000 !important;
      }
      .shopify-policy__body li strong,
      .shopify-policy__body p strong {
        display: block !important;
        text-align: center !important;
        color: var(--color-primary) !important;
        font-size: 18px !important;
        margin-top: 16px !important;
        margin-bottom: 4px !important;
        font-weight: 600 !important;
      }
      .shopify-policy__body h2,
      .shopify-policy__body h3 {
        font-family: 'Inter', sans-serif !important;
        color: var(--color-primary) !important;
        margin-top: 2em !important;
        margin-bottom: 0.8em !important;
        font-weight: 600 !important;
      }

      /* Make internal page text uniform, solid black, and correctly sized */
      .faq-answer p, 
      .faq-answer div,
      .faq-subtitle,
      .pp-subtitle,
      .pp-section-body p,
      .pp-intro p,
      .contact-page-header p,
      .contact-card-desc,
      .contact-form-intro-text p,
      .cc-hero-subtitle,
      .cc-feature-desc,
      .cc-quick-help-desc,
      .cc-quick-help-card-desc,
      .cc-commitment-text,
      .payments-desc,
      .tos-desc,
      .privacy-desc,
      .sd-timeline-desc,
      .rr-eligibility-desc,
      .pp-block-intro,
      .pp-block-bullets,
      .pp-block-bullets li,
      .pp-block-richtext p,
      .pp-block-richtext ul li,
      .pp-method-item,
      .rr-refund-text,
      .sd-hero-subtitle,
      .rr-hero-subtitle,
      .ps-hero-subtitle,
      .about-intro-text,
      .about-offer-card-name,
      .sd-service-row-desc,
      .sd-timeline-label,
      .sd-timeline-value,
      .rr-eligibility-card-desc,
      .rr-side-card-list li {
        font-family: 'Inter', sans-serif !important;
        font-size: 15px !important;
        line-height: 1.6 !important;
        color: #000000 !important;
      }

      .about-offer-card-name {
        color: var(--color-primary) !important;
        font-weight: 600 !important;
      }

      /* Make internal page main headings uniform */
      .faq-title,
      .pp-title,
      .contact-page-header h1,
      .cc-hero-title,
      .sd-hero-title,
      .rr-hero-title,
      .about-hero h1,
      .about-hero-title,
      .payments-hero-title,
      .tos-hero-title,
      .privacy-hero-title,
      .ps-hero-title,
      .sitemap-main h1,
      .sitemap-hero-content h1,
      .shopify-policy__title h1 {
        font-family: 'Canela Text', Georgia, serif !important;
        font-size: 48px !important;
        font-weight: 400 !important;
        line-height: 1.2 !important;
        color: var(--color-primary) !important;
        text-align: center !important;
        margin-bottom: 16px !important;
        text-transform: capitalize !important;
      }

      /* Make internal page header/hero subheadings uniform and centered */
      .contact-page-header,
      .cc-hero-content,
      .sd-hero-content,
      .rr-hero-content,
      .payments-hero-content,
      .about-hero-content,
      .faq-header,
      .ps-hero-content,
      .sitemap-header,
      .sitemap-hero-content,
      .shopify-policy__title {
        text-align: center !important;
        align-items: center !important;
        display: flex !important;
        flex-direction: column !important;
        justify-content: center !important;
        padding-top: 40px !important; /* Push down to avoid sticky header cropping */
      }

      .contact-page-header p,
      .cc-hero-subtitle,
      .sd-hero-subtitle,
      .rr-hero-subtitle,
      .payments-desc,
      .about-hero-content p,
      .faq-subtitle,
      .ps-hero-subtitle,
      .sitemap-header p,
      .sitemap-hero-content p,
      .tos-desc,
      .privacy-desc {
        text-align: center !important;
        max-width: 680px !important;
        margin: 0 auto !important;
        font-size: 16px !important;
        line-height: 1.6 !important;
        color: #000000 !important;
      }

      /* Force uniform contact form layout on all pages except the main Contact Us page */
      :not(.contact-page-body) .contact-form-section {
        background: var(--color-bg) !important;
        padding: 24px 150px !important;
        position: relative !important;
        width: 100% !important;
        box-sizing: border-box !important;
      }
      :not(.contact-page-body) .contact-form-inner {
        max-width: 1620px !important;
        margin: 0 auto !important;
        display: flex !important;
        align-items: flex-start !important;
        gap: 80px !important;
        padding: 0 !important;
      }

      /* Specific layout for the main Contact Us page (since it is inside a card) */
      .contact-page-body .contact-form-section {
        padding: 0 !important;
        background: transparent !important;
      }
      .contact-page-body .contact-form-inner {
        padding: 42px 64px !important;
        max-width: 1620px !important;
        margin: 0 auto !important;
        display: flex !important;
        align-items: flex-start !important;
        gap: 80px !important;
      }

      @media (max-width: 1023px) {
        :not(.contact-page-body) .contact-form-section {
          padding: 32px 40px !important;
        }
        :not(.contact-page-body) .contact-form-inner {
          flex-direction: column !important;
          gap: 40px !important;
        }
        .contact-page-body .contact-form-inner {
          flex-direction: column !important;
          gap: 40px !important;
          padding: 32px 40px !important;
        }
      }

      @media (max-width: 767px) {
        :not(.contact-page-body) .contact-form-section {
          padding: 32px 24px !important;
        }
        .contact-page-body .contact-form-inner {
          padding: 32px 24px !important;
          gap: 32px !important;
        }
      }

      /* Global button styles: make white/cream buttons use the brand's primary color */
      .contact-submit-custom,
      .contact-card-link,
      .cc-quick-help-card-btn {
        background: var(--color-primary) !important;
        color: var(--color-bg) !important;
        border: 1px solid var(--color-primary) !important;
      }
      .contact-submit-custom svg,
      .contact-card-link svg,
      .cc-quick-help-card-btn svg {
        color: var(--color-bg) !important;
        fill: currentColor !important;
      }
      .contact-submit-custom:hover,
      .contact-card-link:hover,
      .cc-quick-help-card-btn:hover {
        background: #ffffff !important;
        color: var(--color-primary) !important;
        border-color: var(--color-primary) !important;
      }
      .contact-submit-custom:hover svg,
      .contact-submit-custom:hover path,
      .contact-card-link:hover svg,
      .contact-card-link:hover path,
      .cc-quick-help-card-btn:hover svg,
      .cc-quick-help-card-btn:hover path {
        color: var(--color-primary) !important;
        fill: currentColor !important;
        stroke: currentColor !important;
      }
      .contact-submit-custom svg path {
        stroke: var(--color-bg) !important;
      }
      .contact-submit-custom:hover svg path {
        stroke: var(--color-primary) !important;
      }
      .contact-card-link svg[fill="none"] path {
        stroke: var(--color-bg) !important;
      }
      .contact-card-link:hover svg[fill="none"] path {
        stroke: var(--color-primary) !important;
      }
      .cc-quick-help-card-btn svg[fill="none"] path {
        stroke: var(--color-bg) !important;
      }
      .cc-quick-help-card-btn:hover svg[fill="none"] path {
        stroke: var(--color-primary) !important;
      }

      @media (max-width: 767px) {
        .faq-title,
        .pp-title,
        .contact-page-header h1,
        .cc-hero-title,
        .sd-hero-title,
        .rr-hero-title,
        .about-hero h1,
        .about-hero-title,
        .payments-hero-title,
        .tos-hero-title,
        .privacy-hero-title,
        .ps-hero-title,
        .sitemap-main h1,
        .sitemap-hero-content h1,
        .shopify-policy__title h1 {
          font-size: 32px !important;
        }
        .contact-page-header p,
        .cc-hero-subtitle,
        .sd-hero-subtitle,
        .rr-hero-subtitle,
        .payments-desc,
        .about-hero-content p,
        .faq-subtitle,
        .ps-hero-subtitle,
        .sitemap-header p,
        .sitemap-hero-content p,
        .tos-desc,
        .privacy-desc {
          font-size: 14px !important;
        }
      }
      /* Highlight all secondary headings in primary theme color */
      .pp-block-title,
      .pp-section-title,
      .pp-sub-title,
      .faq-section-title,
      .sd-services-title,
      .sd-service-row-title,
      .sd-timelines-title,
      .sd-timeline-card-title,
      .cc-feature-title,
      .cc-quick-help-title,
      .cc-quick-help-card-title,
      .cc-commitment-label,
      .contact-card-title,
      .contact-form-intro h2,
      .rr-refund-label,
      .about-offer-header h2,
      .brands-header h2,
      .rr-eligibility-title,
      .rr-side-title,
      .rr-non-returnable-title,
      .rr-eligibility-card-title,
      .rr-side-card-title,
      .about-intro-label {
        color: var(--color-primary) !important;
      }
      /* FAQ and Policy pages sidebar links style to match brand primary color */
      .faq-sidebar-item,
      .pp-sidebar-item {
        color: var(--color-primary) !important;
      }
      .faq-sidebar-item.active,
      .pp-sidebar-item.active {
        color: #fff !important;
        background: var(--color-primary) !important;
      }
      .faq-sidebar-item svg,
      .faq-sidebar-item svg path,
      .pp-sidebar-item svg,
      .pp-sidebar-item svg path {
        stroke: var(--color-primary) !important;
      }
      .faq-sidebar-item.active svg,
      .faq-sidebar-item.active svg path,
      .pp-sidebar-item.active svg,
      .pp-sidebar-item.active svg path {
        stroke: #ffffff !important;
      }

      /* Collection Filter Trigger Button - hover/active states */
      .filter-trigger-btn:hover {
        background: var(--color-primary) !important;
        color: var(--color-bg) !important;
        border-color: var(--color-primary) !important;
      }

      /* Collection Filter Pills - hover/active states */
      .filter-pill:hover,
      .filter-pill.active {
        background: var(--color-primary) !important;
        color: var(--color-bg) !important;
        border-color: var(--color-primary) !important;
      }

      /* Fix layout squish & spacing of contact forms at <= 1200px (including 1024px) and mobile */
      @media (max-width: 1200px) {
        .contact-form-inner {
          flex-direction: column !important;
          gap: 32px !important;
        }
        .contact-form-intro {
          flex: none !important;
          width: 100% !important;
        }
      }

      /* Returns page sections headings, colors, and sizes */
      .rr-eligibility-title,
      .rr-side-title,
      .rr-non-returnable-title {
        font-family: 'Inter', sans-serif !important;
        font-size: 28px !important;
        font-weight: 500 !important;
        color: var(--color-primary) !important;
        text-transform: uppercase !important;
        letter-spacing: 0.05em !important;
        text-align: center !important;
      }

      .rr-side-subtitle {
        font-family: 'Inter', sans-serif !important;
        font-size: 15px !important;
        color: #000000 !important;
        margin-top: 6px !important;
        margin-bottom: 0 !important;
        text-align: center !important;
      }

      .rr-eligibility-card-title,
      .rr-side-card-title {
        font-family: 'Inter', sans-serif !important;
        font-size: 18px !important;
        font-weight: 600 !important;
        color: var(--color-primary) !important;
      }

      .rr-non-returnable-card-title {
        font-family: 'Inter', sans-serif !important;
        font-size: 15px !important;
        font-weight: 500 !important;
        color: #2D1F1F !important;
        line-height: 1.5 !important;
      }

      .rr-non-returnable-icon svg path,
      .rr-non-returnable-icon svg {
        stroke: var(--color-primary) !important;
      }
    </style>

    
    <script>
      (function() {
        // Department sync
        var dept = localStorage.getItem('amirivibes_department') || 'women';
        if (dept !== 'women' && dept !== 'men') dept = 'women';
        document.documentElement.classList.add('dept-' + dept);
        document.cookie = 'amirivibes_department=' + dept + '; path=/; max-age=' + (365 * 24 * 60 * 60);

        // Language preference persistence
        var currentLang = "{{ request.locale.iso_code }}".toLowerCase();
        var savedLang = localStorage.getItem('shopify_locale_preference');
        
        if (savedLang && savedLang !== currentLang) {
          var newPath = window.location.pathname;
          if (savedLang === 'ar') {
            if (!newPath.startsWith('/ar')) {
              newPath = '/ar' + (newPath === '/' ? '' : newPath);
              window.location.href = window.location.origin + newPath + window.location.search + window.location.hash;
            }
          } else if (savedLang === 'en') {
            if (newPath.startsWith('/ar/')) {
              newPath = newPath.replace('/ar/', '/');
            } else if (newPath === '/ar') {
              newPath = '/';
            }
            window.location.href = window.location.origin + newPath + window.location.search + window.location.hash;
          }
        }
      })();
    </script>
  </head>

  <body class="template-{{ template | replace: '.', '-' }} dept-women" style="overflow-x:hidden;">

    {%- section 'header' -%}

    <main id="MainContent" class="content-for-layout" role="main" tabindex="-1">
      {{ content_for_layout }}
    </main>

    {%- sections 'footer-group' -%}

    <script>
      document.addEventListener('DOMContentLoaded', function() {
        if ('IntersectionObserver' in window) {
          const observerOptions = {
            root: null,
            rootMargin: '0px 0px -50px 0px',
            threshold: 0.05
          };

          const observer = new IntersectionObserver((entries, observer) => {
            entries.forEach(entry => {
              if (entry.isIntersecting) {
                entry.target.classList.add('in-view');
                observer.unobserve(entry.target);
              }
            });
          }, observerOptions);

          const selectors = [
            '.product-card',
            '.qtr-section',
            '.brands-grid',
            '.above-footer-banner',
            '.product-container',
            '.est-delivery',
            '.breadcrumbs',
            '.luxury-img-area',
            '.luxury-content-area'
          ];

          selectors.forEach(selector => {
            document.querySelectorAll(selector).forEach(el => {
              el.classList.add('scroll-reveal');
              observer.observe(el);
            });
          });
        }
      });
    </script>
  </body>
</html>
