<!doctype html>
<html class="no-js" lang="{{ request.locale.iso_code }}"
      dir="{% if request.locale.iso_code == 'ar' %}rtl{% else %}ltr{% endif %}">
  <head>
    <meta charset="utf-8">
    <meta http-equiv="X-UA-Compatible" content="IE=edge">
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <link rel="canonical" href="{{ canonical_url }}">
    <link rel="preconnect" href="https://cdn.shopify.com" crossorigin>

    {%- if settings.favicon != blank -%}
      <link rel="icon" type="image/png" href="{{ settings.favicon | image_url: width: 32, height: 32 }}">
    {%- endif -%}

    <title>
      {{ page_title }}
      {%- if current_tags %} &ndash; tagged "{{ current_tags | join: ', ' }}"{% endif -%}
      {%- if current_page != 1 %} &ndash; Page {{ current_page }}{% endif -%}
      {%- unless page_title contains shop.name -%} &ndash; {{ shop.name }}{%- endunless -%}
    </title>

    {% if page_description %}
      <meta name="description" content="{{ page_description | escape }}">
    {% endif %}

    {{ content_for_header }}

    
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet">

    
    {{ 'theme.css' | asset_url | stylesheet_tag }}
    {%- if template contains 'customer' -%}
      {{ 'accounts.css' | asset_url | stylesheet_tag }}
    {%- endif -%}

    <style>
      :root {
        --color-bg: {{ settings.color_bg | default: '#faf9f5' }};
        --color-primary: {{ settings.color_primary | default: '#2d1f1f' }};
        --color-accent: {{ settings.color_accent | default: '#f25c5e' }};
        --color-border: {{ settings.color_border | default: '#e0dcd3' }};
        --color-muted: {{ settings.color_muted | default: '#666666' }};
        --color-dark-teal: {{ settings.color_dark_teal | default: '#304854' }};
        --color-green: {{ settings.color_green | default: '#1e3524' }};
      }
    </style>

    
    <script>
      (function() {
        // Department sync
        var dept = localStorage.getItem('qatarshoes_department') || 'women';
        if (dept !== 'women' && dept !== 'men') dept = 'women';
        document.documentElement.classList.add('dept-' + dept);
        document.cookie = 'qatarshoes_department=' + dept + '; path=/; max-age=' + (365 * 24 * 60 * 60);

        // Language preference persistence
        var currentLang = "{{ request.locale.iso_code }}".toLowerCase();
        var savedLang = localStorage.getItem('shopify_locale_preference');
        
        if (savedLang && savedLang !== currentLang) {
          var newPath = window.location.pathname;
          if (savedLang === 'ar') {
            if (!newPath.startsWith('/ar')) {
              newPath = '/ar' + (newPath === '/' ? '' : newPath);
              window.location.href = window.location.origin + newPath + window.location.search + window.location.hash;
            }
          } else if (savedLang === 'en') {
            if (newPath.startsWith('/ar/')) {
              newPath = newPath.replace('/ar/', '/');
            } else if (newPath === '/ar') {
              newPath = '/';
            }
            window.location.href = window.location.origin + newPath + window.location.search + window.location.hash;
          }
        }
      })();
    </script>
  </head>

  <body class="template-{{ template | replace: '.', '-' }} dept-women" style="overflow-x:hidden;">

    {%- section 'header' -%}

    <main id="MainContent" class="content-for-layout" role="main" tabindex="-1">
      {{ content_for_layout }}
    </main>

    {%- sections 'footer-group' -%}

  </body>
</html>
