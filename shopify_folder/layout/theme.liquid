{% comment %}
========================================================================
Theme Name: Qatar Shoes Clean Replica
Developed By: AlgoGuru Technologies (Ritwik Dalmia)
Contact: algogurutechnologies@gmail.com
All rights reserved. Unauthorized duplication or distribution is prohibited.
========================================================================
{% endcomment %}
<!doctype html>
<html class="no-js" lang="{{ request.locale.iso_code }}"
      dir="{% if request.locale.iso_code == 'ar' %}rtl{% else %}ltr{% endif %}">
  <head>
    <meta charset="utf-8">
    <meta http-equiv="X-UA-Compatible" content="IE=edge">
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <link rel="canonical" href="{{ canonical_url }}">
    <link rel="preconnect" href="https://cdn.shopify.com" crossorigin>

    {%- if settings.favicon != blank -%}
      <link rel="icon" type="image/png" href="{{ settings.favicon | image_url: width: 32, height: 32 }}">
    {%- endif -%}

    <title>
      {%- if template contains 'gift_card' -%}
        {%- if request.locale.iso_code == 'ar' -%}بطاقة هدية{%- else -%}Gift Card{%- endif -%} - {{ shop.name }}
      {%- else -%}
        {{ page_title }}
        {%- if current_tags %} &ndash; tagged "{{ current_tags | join: ', ' }}"{% endif -%}
        {%- if current_page != 1 %} &ndash; Page {{ current_page }}{% endif -%}
        {%- unless page_title contains shop.name -%} &ndash; {{ shop.name }}{%- endunless -%}
      {%- endif -%}
    </title>

    {% if page_description %}
      <meta name="description" content="{{ page_description | escape }}">
    {% endif %}

    {{ content_for_header }}

    
    {%- # theme-check-disable RemoteAsset -%}
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet">
    {%- if request.locale.iso_code == 'ar' -%}
    <link href="https://fonts.googleapis.com/css2?family=Cairo:wght@300;400;500;600;700&display=swap" rel="stylesheet">
    {%- endif -%}
    {%- # theme-check-enable RemoteAsset -%}

    
    {{ 'theme.css' | asset_url | stylesheet_tag }}
    {%- if template contains 'customer' -%}
      {{ 'accounts.css' | asset_url | stylesheet_tag }}
    {%- endif -%}

    <style>
      {%- if settings.font_body != blank -%}
        {{ settings.font_body | font_face: font_display: 'swap' }}
        {%- assign font_body_bold = settings.font_body | font_modify: 'weight', 'bold' -%}
        {%- if font_body_bold -%}
          {{ font_body_bold | font_face: font_display: 'swap' }}
        {%- endif -%}
      {%- endif -%}
      {%- if settings.font_heading != blank -%}
        {{ settings.font_heading | font_face: font_display: 'swap' }}
      {%- endif -%}

      @font-face {
        font-family: 'Canela Text';
        font-display: swap;
        src: local('Canela Text'),
             url("{{ 'CanelaText-Regular.woff2' | asset_url }}") format('woff2');
      }
      :root {
        --color-bg: {{ settings.color_bg | default: '#faf9f5' }};
        --color-text: {% if settings.color_text != blank %}{{ settings.color_text }}{% else %}var(--color-primary, #2d1f1f){% endif %};
        --color-primary: {{ settings.color_primary | default: '#2d1f1f' }};
        --color-accent: {% if settings.color_accent != blank %}{{ settings.color_accent }}{% else %}var(--color-primary, #2d1f1f){% endif %};
        --color-border: {{ settings.color_border | default: '#e0dcd3' }};
        --color-muted: {% if settings.color_muted != blank %}{{ settings.color_muted }}{% else %}var(--color-text, #000000){% endif %};
        --color-dark-teal: {% if settings.color_dark_teal != blank %}{{ settings.color_dark_teal }}{% else %}var(--color-primary, #304854){% endif %};
        --color-green: {% if settings.color_green != blank %}{{ settings.color_green }}{% else %}var(--color-primary, #1e3524){% endif %};
        --color-drawer-bg: {% if settings.color_drawer_bg != blank %}{{ settings.color_drawer_bg }}{% else %}var(--color-bg, #ffffff){% endif %};
        --color-drawer-footer-bg: {% if settings.color_drawer_footer_bg != blank %}{{ settings.color_drawer_footer_bg }}{% else %}var(--color-bg, #faf9f5){% endif %};
        --color-white: {{ settings.color_white | default: '#ffffff' }};

        --font-size-small: {{ settings.font_size_small | default: 11 }}px;
        --font-size-body-small: {{ settings.font_size_body_small | default: 13 }}px;
        --font-size-body: {{ settings.font_size_body | default: 15 }}px;
        --font-size-heading-medium: {{ settings.font_size_heading_medium | default: 18 }}px;
        --font-size-heading-large: {{ settings.font_size_heading_large | default: 24 }}px;

        --radius-card: {{ settings.radius_card | default: 12 }}px;
        --radius-large: {{ settings.radius_large | default: 20 }}px;
        --radius-button: {{ settings.radius_button | default: 50 }}px;

        --page-width: {{ settings.page_width | default: 1400 }}px;
        --spacing-sections: {{ settings.spacing_sections | default: 0 }}px;
        --grid-horizontal-space: {{ settings.grid_horizontal_space | default: 8 }}px;
        --grid-vertical-space: {{ settings.grid_vertical_space | default: 8 }}px;

        {%- if settings.font_body != blank -%}
        --font-body: {{ settings.font_body.family }}, {{ settings.font_body.fallback_families }};
        {%- endif -%}
        {%- if settings.font_heading != blank -%}
        --font-serif: {{ settings.font_heading.family }}, {{ settings.font_heading.fallback_families }};
        {%- endif -%}

        /* Buttons Settings */
        --btn-border-thickness: {{ settings.btn_border_thickness | default: 1 }}px;
        --btn-border-opacity: {{ settings.btn_border_opacity | default: 100 | divided_by: 100.0 }};
        --btn-corner-radius: {{ settings.btn_corner_radius | default: 0 }}px;
        --btn-shadow-opacity: {{ settings.btn_shadow_opacity | default: 0 | divided_by: 100.0 }};
        --btn-shadow-horizontal-offset: {{ settings.btn_shadow_horizontal_offset | default: 0 }}px;
        --btn-shadow-vertical-offset: {{ settings.btn_shadow_vertical_offset | default: 4 }}px;
        --btn-shadow-blur: {{ settings.btn_shadow_blur | default: 5 }}px;

        /* Variant Pills Settings */
        --pill-border-thickness: {{ settings.pill_border_thickness | default: 1 }}px;
        --pill-border-opacity: {{ settings.pill_border_opacity | default: 55 | divided_by: 100.0 }};
        --pill-corner-radius: {{ settings.pill_corner_radius | default: 40 }}px;
        --pill-shadow-opacity: {{ settings.pill_shadow_opacity | default: 0 | divided_by: 100.0 }};
        --pill-shadow-horizontal-offset: {{ settings.pill_shadow_horizontal_offset | default: 0 }}px;
        --pill-shadow-vertical-offset: {{ settings.pill_shadow_vertical_offset | default: 4 }}px;
        --pill-shadow-blur: {{ settings.pill_shadow_blur | default: 5 }}px;

        /* Inputs Settings */
        --input-border-thickness: {{ settings.input_border_thickness | default: 1 }}px;
        --input-border-opacity: {{ settings.input_border_opacity | default: 55 | divided_by: 100.0 }};
        --input-corner-radius: {{ settings.input_corner_radius | default: 0 }}px;
        --input-shadow-opacity: {{ settings.input_shadow_opacity | default: 0 | divided_by: 100.0 }};
        --input-shadow-horizontal-offset: {{ settings.input_shadow_horizontal_offset | default: 0 }}px;
        --input-shadow-vertical-offset: {{ settings.input_shadow_vertical_offset | default: 4 }}px;
        --input-shadow-blur: {{ settings.input_shadow_blur | default: 5 }}px;

        /* Product Cards Settings */
        --card-border-thickness: {{ settings.card_border_thickness | default: 0 }}px;
        --card-border-opacity: {{ settings.card_border_opacity | default: 10 | divided_by: 100.0 }};
        --card-corner-radius: {{ settings.card_corner_radius | default: 0 }}px;
        --card-shadow-opacity: {{ settings.card_shadow_opacity | default: 0 | divided_by: 100.0 }};
        --card-shadow-horizontal-offset: {{ settings.card_shadow_horizontal_offset | default: 0 }}px;
        --card-shadow-vertical-offset: {{ settings.card_shadow_vertical_offset | default: 4 }}px;
        --card-shadow-blur: {{ settings.card_shadow_blur | default: 5 }}px;

        /* Collection Cards Settings */
        --col-card-border-thickness: {{ settings.col_card_border_thickness | default: 0 }}px;
        --col-card-border-opacity: {{ settings.col_card_border_opacity | default: 10 | divided_by: 100.0 }};
        --col-card-corner-radius: {{ settings.col_card_corner_radius | default: 14 }}px;
        --col-card-shadow-opacity: {{ settings.col_card_shadow_opacity | default: 0 | divided_by: 100.0 }};
        --col-card-shadow-horizontal-offset: {{ settings.col_card_shadow_horizontal_offset | default: 0 }}px;
        --col-card-shadow-vertical-offset: {{ settings.col_card_shadow_vertical_offset | default: 4 }}px;
        --col-card-shadow-blur: {{ settings.col_card_shadow_blur | default: 5 }}px;

        /* Blog Cards Settings */
        --blog-card-style: {{ settings.blog_card_style | default: 'standard' }};
        --blog-card-image-padding: {{ settings.blog_card_image_padding | default: 0 }}px;
        --blog-card-text-alignment: {{ settings.blog_card_text_alignment | default: 'left' }};
        --blog-card-border-thickness: {{ settings.blog_card_border_thickness | default: 0 }}px;
        --blog-card-border-opacity: {{ settings.blog_card_border_opacity | default: 10 | divided_by: 100.0 }};
        --blog-card-corner-radius: {{ settings.blog_card_corner_radius | default: 0 }}px;
        --blog-card-shadow-opacity: {{ settings.blog_card_shadow_opacity | default: 0 | divided_by: 100.0 }};
        --blog-card-shadow-horizontal-offset: {{ settings.blog_card_shadow_horizontal_offset | default: 0 }}px;
        --blog-card-shadow-vertical-offset: {{ settings.blog_card_shadow_vertical_offset | default: 4 }}px;
        --blog-card-shadow-blur: {{ settings.blog_card_shadow_blur | default: 5 }}px;

        /* Media Settings */
        --media-border-thickness: {{ settings.media_border_thickness | default: 1 }}px;
        --media-border-opacity: {{ settings.media_border_opacity | default: 5 | divided_by: 100.0 }};
        --media-corner-radius: {{ settings.media_corner_radius | default: 0 }}px;
        --media-shadow-opacity: {{ settings.media_shadow_opacity | default: 0 | divided_by: 100.0 }};
        --media-shadow-horizontal-offset: {{ settings.media_shadow_horizontal_offset | default: 0 }}px;
        --media-shadow-vertical-offset: {{ settings.media_shadow_vertical_offset | default: 4 }}px;
        --media-shadow-blur: {{ settings.media_shadow_blur | default: 5 }}px;

        /* Content Containers Settings */
        --container-border-thickness: {{ settings.container_border_thickness | default: 0 }}px;
        --container-border-opacity: {{ settings.container_border_opacity | default: 10 | divided_by: 100.0 }};
        --container-corner-radius: {{ settings.container_corner_radius | default: 0 }}px;
        --container-shadow-opacity: {{ settings.container_shadow_opacity | default: 0 | divided_by: 100.0 }};
        --container-shadow-horizontal-offset: {{ settings.container_shadow_horizontal_offset | default: 0 }}px;
        --container-shadow-vertical-offset: {{ settings.container_shadow_vertical_offset | default: 4 }}px;
        --container-shadow-blur: {{ settings.container_shadow_blur | default: 5 }}px;

        /* Dropdowns and Pop-ups Settings */
        --popup-border-thickness: {{ settings.popup_border_thickness | default: 1 }}px;
        --popup-border-opacity: {{ settings.popup_border_opacity | default: 10 | divided_by: 100.0 }};
        --popup-corner-radius: {{ settings.popup_corner_radius | default: 0 }}px;
        --popup-shadow-opacity: {{ settings.popup_shadow_opacity | default: 5 | divided_by: 100.0 }};
        --popup-shadow-horizontal-offset: {{ settings.popup_shadow_horizontal_offset | default: 0 }}px;
        --popup-shadow-vertical-offset: {{ settings.popup_shadow_vertical_offset | default: 4 }}px;
        --popup-shadow-blur: {{ settings.popup_shadow_blur | default: 5 }}px;

        /* Drawers Settings */
        --drawer-border-thickness: {{ settings.drawer_border_thickness | default: 1 }}px;
        --drawer-border-opacity: {{ settings.drawer_border_opacity | default: 10 | divided_by: 100.0 }};
        --drawer-shadow-opacity: {{ settings.drawer_shadow_opacity | default: 0 | divided_by: 100.0 }};
        --drawer-shadow-horizontal-offset: {{ settings.drawer_shadow_horizontal_offset | default: 0 }}px;
        --drawer-shadow-vertical-offset: {{ settings.drawer_shadow_vertical_offset | default: 4 }}px;
        --drawer-shadow-blur: {{ settings.drawer_shadow_blur | default: 5 }}px;
      }

      /* Global style overrides to enforce client background and accent colors */
      body {
        background-color: var(--color-bg) !important;
      }
      
      .site-footer,
      .site-footer-panel-left,
      .site-footer-panel-right,
      .site-footer-links-area,
      .site-footer-feature-item,
      .site-footer-bottom,
      .contact-form-section,
      .faq-main,
      .faq-sidebar-item,
      .pp-sidebar-item,
      .faq-search-wrap,
      .faq-item,
      .faq-mobile-bar,
      .faq-mobile-overlay-item,
      .pp-mobile-overlay-item,
      .pp-content,
      .contact-card,
      .cc-quick-help-card,
      .sd-hero,
      .sd-services,
      .sd-timeline-card,
      .sd-timelines,
      .rr-hero,
      .rr-eligibility,
      .rr-eligibility-card,
      .rr-side-card,
      .rr-non-returnable,
      .rr-refund,
      .rr-sides,
      .sitemap-main,
      .about-main,
      .contact-main,
      .care-main,
      .payments-main,
      .tos-main,
      .privacy-main,
      .contact-page-wrap,
      .contact-page-card,
      .cc-page,
      .rr-main,
      .sd-main,
      .ps-main,
      .about-main-wrapper,
      .collection-toolbar,
      .filter-pill,
      .cs-trigger,
      .cs-options,
      .filters-clear-btn {
        background-color: var(--color-bg) !important;
      }

      .site-footer-subscribe-form .wpcf7-submit,
      .contact-submit-custom {
        background-color: var(--color-bg) !important;
        border-color: var(--color-primary) !important;
        color: var(--color-primary) !important;
      }

      .wishlist-count,
      .cart-count-badge {
        background-color: var(--color-border) !important;
        color: var(--color-primary) !important;
      }

      .site-footer-subscribe-form .wpcf7-submit:hover,
      .contact-submit-custom:hover {
        background-color: var(--color-primary) !important;
        color: var(--color-bg) !important;
      }

      .site-footer-legal {
        background-color: var(--color-primary) !important;
      }

      /* Home page section borders - use primary color */
      .section-heading-row {
        border: 1.5px solid var(--color-primary) !important;
        border-radius: 12px !important;
        margin-bottom: 20px !important;
      }
      .brands-on-amirivibes .brand-item {
        outline: 1px solid var(--color-primary) !important;
        border: 1px solid var(--color-primary) !important;
      }

      /* Footer border lines -> primary color */
      .site-footer-panel-right {
        border: 1px solid var(--color-primary) !important;
      }
      .site-footer-features {
        border-top: 1px solid var(--color-primary) !important;
      }
      .site-footer-feature-item {
        border-right: 1px solid var(--color-primary) !important;
      }
      @media (max-width: 767px) {
        .site-footer-panel-right {
          border-color: var(--color-primary) !important;
        }
        .site-footer-bottom-inner {
          border-top: 1px solid var(--color-primary) !important;
        }
        .site-footer-feature-item {
          border-bottom: 1px solid var(--color-primary) !important;
        }
      }

      .product-thumbnails img:hover,
      .product-thumbnails img.active {
        border-color: var(--color-primary) !important;
      }
      .size-option {
        border-color: var(--color-primary) !important;
      }
      .quantity-controls {
        border: var(--input-border-thickness) solid color-mix(in srgb, var(--color-primary) {{ settings.input_border_opacity | default: 55 }}%, transparent) !important;
        border-radius: var(--input-corner-radius) !important;
        box-shadow: var(--input-shadow-horizontal-offset) var(--input-shadow-vertical-offset) var(--input-shadow-blur) rgba(0, 0, 0, var(--input-shadow-opacity)) !important;
        overflow: hidden !important;
      }
      .quantity-controls input {
        border-top: none !important;
        border-bottom: none !important;
        border-left: var(--input-border-thickness) solid color-mix(in srgb, var(--color-primary) {{ settings.input_border_opacity | default: 55 }}%, transparent) !important;
        border-right: var(--input-border-thickness) solid color-mix(in srgb, var(--color-primary) {{ settings.input_border_opacity | default: 55 }}%, transparent) !important;
        border-radius: 0 !important;
        box-shadow: none !important;
        background: transparent !important;
      }
      .delivery-info-strip {
        border-top-color: var(--color-primary) !important;
        border-bottom-color: var(--color-primary) !important;
      }
      .product-accordions {
        border-top-color: var(--color-primary) !important;
      }
      .accordion-item {
        border-bottom-color: var(--color-primary) !important;
      }

      /* Department toggle buttons matching the brand theme */
      .dept-toggle .dept-link.active {
        color: #fff !important;
        background: var(--color-primary) !important;
        box-shadow: 0 2px 8px rgba(140, 22, 56, 0.3);
      }
      .dept-toggle .dept-link:hover:not(.active) {
        color: #fff !important;
        background: rgba(255, 255, 255, 0.12) !important;
      }

      /* Contact Us page border overrides */
      .contact-cards {
        border-bottom-color: var(--color-primary) !important;
      }
      .contact-card {
        border-right-color: var(--color-primary) !important;
      }
      .contact-card-link {
        border-color: var(--color-primary) !important;
        color: var(--color-primary) !important;
      }
      .contact-card-link:hover {
        background: var(--color-primary) !important;
        color: #fff !important;
      }
      .contact-field-group label {
        color: var(--color-primary) !important;
        font-family: var(--font-body) !important;
        font-weight: 500 !important;
      }
      .contact-field-group label .required {
        color: var(--color-primary) !important;
      }
      .contact-form-wrapper input[type="text"],
      .contact-form-wrapper input[type="email"],
      .contact-form-wrapper input[type="tel"],
      .contact-form-wrapper textarea {
        background-color: var(--color-bg) !important;
        border: 1.5px solid var(--color-primary) !important;
        border-radius: 8px !important;
        color: var(--color-primary) !important;
        font-family: var(--font-body) !important;
        font-size: 14px !important;
      }
      .contact-form-wrapper input[type="text"]:focus,
      .contact-form-wrapper input[type="email"]:focus,
      .contact-form-wrapper input[type="tel"]:focus,
      .contact-form-wrapper textarea:focus {
        border-color: var(--color-primary) !important;
        outline: none !important;
      }
      .contact-submit-custom {
        border: 1.5px solid var(--color-primary) !important;
        color: var(--color-primary) !important;
        background-color: var(--color-bg) !important;
      }
      .contact-submit-custom:hover {
        background-color: var(--color-primary) !important;
        color: var(--color-bg) !important;
      }
      @media (max-width: 767px) {
        .contact-card {
          border-bottom-color: var(--color-primary) !important;
        }
      }

      /* FAQs / Customer Care page border overrides */
      .faq-sidebar-nav {
        border-color: var(--color-primary) !important;
      }
      .faq-sidebar-item {
        border-bottom-color: var(--color-primary) !important;
      }
      .faq-search {
        border-color: var(--color-primary) !important;
      }
      .faq-items-container {
        background: var(--color-primary) !important;
      }
      .faq-mobile-bar {
        border-color: var(--color-primary) !important;
      }

      /* Internal footer pages borders - update all to theme primary color */
      
      /* Shipping & Delivery */
      .sd-services,
      .sd-services-card,
      .sd-timeline-card,
      .sd-timelines,
      .sd-timeline-card::after,
      .sd-timeline-card::before {
        border-color: var(--color-primary) !important;
      }

      /* Returns & Refunds */
      .rr-eligibility-card,
      .rr-side-card,
      .rr-non-returnable-card,
      .rr-refund,
      .rr-sides,
      .rr-non-returnable {
        border-color: var(--color-primary) !important;
      }
      .rr-eligibility,
      .rr-side-card {
        border-color: var(--color-primary) !important;
      }
      /* Non-returnable grid outer border and column separators */
      .rr-non-returnable-grid {
        border: 1.5px solid var(--color-primary) !important;
      }
      .rr-non-returnable-card {
        border-right: 1.5px solid var(--color-primary) !important;
      }
      @media (max-width: 1023px) {
        .rr-non-returnable-card {
          border-right: none !important;
          border-bottom: 1.5px solid var(--color-primary) !important;
        }
        .rr-non-returnable-card:last-child {
          border-bottom: none !important;
        }
      }
      /* Refund Processing section label bottom border */
      .rr-refund-label {
        border-bottom-color: var(--color-primary) !important;
      }
      /* Contact form section separator line */
      .contact-form-section::before {
        background: var(--color-primary) !important;
      }

      /* Payments & Pricing */
      .payments-main,
      .payments-card,
      .payments-method-card,
      .payments-grid-card {
        border-color: var(--color-primary) !important;
      }

      /* Customer Care page */
      .care-main,
      .cc-quick-help-card,
      .cc-quick-help-card-btn {
        border-color: var(--color-primary) !important;
        color: var(--color-primary) !important;
      }
      .cc-quick-help-card-btn:hover {
        background: var(--color-primary) !important;
        color: #fff !important;
      }

      /* About Us */
      .about-main,
      .about-history-card,
      .about-value-card,
      .about-team-card {
        border-color: var(--color-primary) !important;
      }

      /* Sitemap */
      .sitemap-main,
      .sitemap-card,
      .sitemap-col {
        border-color: var(--color-primary) !important;
      }
      .sitemap-card {
        border-color: var(--color-primary) !important;
      }
      .sitemap-link {
        border-bottom-color: var(--color-primary) !important;
        color: var(--color-primary) !important;
      }
      .sitemap-link:hover {
        opacity: 1 !important;
        color: var(--color-primary) !important;
      }
      .sitemap-link:hover span {
        color: var(--color-primary) !important;
      }
      /* Sitemap nested heading border and hover */
      .sitemap-link-level-1 {
        border-bottom-color: var(--color-primary) !important;
        color: var(--color-primary) !important;
      }
      .sitemap-link-level-1:hover {
        opacity: 1 !important;
        color: var(--color-primary) !important;
      }
      .sitemap-link-level-2:hover {
        opacity: 1 !important;
        color: var(--color-primary) !important;
      }
      .sitemap-link-level-3:hover {
        color: var(--color-primary) !important;
      }
      .sitemap-toggle-btn {
        border-bottom-color: var(--color-primary) !important;
      }
      .sitemap-toggle-btn:hover {
        opacity: 1 !important;
        color: var(--color-primary) !important;
      }

      /* Terms of Service & Privacy Policy */
      .tos-main,
      .privacy-main,
      .pp-content,
      .pp-mobile-overlay-card {
        border-color: var(--color-primary) !important;
      }

      /* Shopify default policy pages styling */
      .shopify-policy__container {
        max-width: 800px !important;
        margin: 80px auto !important;
        padding: 0 24px !important;
        background-color: var(--color-bg) !important;
      }
      .shopify-policy__title {
