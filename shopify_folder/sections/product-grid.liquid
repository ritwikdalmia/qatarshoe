{% comment %}
  Dynamic Department-Aware Product Grid Section
{% endcomment %}

{%- liquid
  assign collection_women = collections[section.settings.collection_women]
  assign collection_men = collections[section.settings.collection_men]
  assign limit = section.settings.limit
-%}

<div class="product-grid-section homepage-section" style="padding: {{ section.settings.padding_vertical }}px 0;">
  <div class="container">
    <div class="section-header-row">
      <h2 class="section-title">
        <span class="women-only">{{ section.settings.title_women }}</span>
        <span class="men-only">{{ section.settings.title_men }}</span>
      </h2>
      <a href="#" class="view-more-link button-outline">
        View More
      </a>
    </div>

    <!-- Women Products Grid -->
    <div class="products-grid-wrapper women-only">
      {%- if collection_women != blank and collection_women.products_count > 0 -%}
        <div class="grid-layout">
          {%- for product in collection_women.products limit: limit -%}
            {% render 'product-card', product: product %}
          {%- endfor -%}
        </div>
      {%- else -%}
        <p class="no-products-msg">No products found in Women's {{ section.settings.title_women }} collection.</p>
      {%- endif -%}
    </div>

    <!-- Men Products Grid -->
    <div class="products-grid-wrapper men-only">
      {%- if collection_men != blank and collection_men.products_count > 0 -%}
        <div class="grid-layout">
          {%- for product in collection_men.products limit: limit -%}
            {% render 'product-card', product: product %}
          {%- endfor -%}
        </div>
      {%- else -%}
        <p class="no-products-msg">No products found in Men's {{ section.settings.title_men }} collection.</p>
      {%- endif -%}
    </div>
  </div>
</div>

<style>
  .section-header-row {
    display: flex;
    justify-content: space-between;
    align-items: center;
    border: 1px solid var(--color-border);
    background-color: var(--color-white);
    padding: 12px 20px;
    margin-bottom: 20px;
    border-radius: 4px 4px 0 0;
  }
  .section-title {
    font-family: var(--font-heading);
    font-size: 20px;
    color: var(--color-text);
  }
  .view-more-link {
    font-size: 13px;
    font-weight: bold;
    text-transform: uppercase;
    border: 1px solid var(--color-border);
    padding: 8px 16px;
    background: var(--color-white);
  }
  .view-more-link:hover {
    background-color: #f5f4ef;
  }
  .grid-layout {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 15px;
  }
  .no-products-msg {
    text-align: center;
    padding: 40px 0;
    color: #666;
    background: var(--color-white);
    border: 1px dashed var(--color-border);
  }

  @media (max-width: 990px) {
    .grid-layout {
      grid-template-columns: repeat(3, 1fr);
    }
  }
  @media (max-width: 768px) {
    .grid-layout {
      grid-template-columns: repeat(2, 1fr);
      gap: 10px;
    }
    .section-header-row {
      border-radius: 0;
    }
  }
</style>

{% schema %}
{
  "name": "Dynamic Product Grid",
  "settings": [
    {
      "type": "text",
      "id": "title_women",
      "label": "Title (Women)",
      "default": "New Arrivals"
    },
    {
      "type": "collection",
      "id": "collection_women",
      "label": "Collection (Women)"
    },
    {
      "type": "text",
      "id": "title_men",
      "label": "Title (Men)",
      "default": "New Arrivals"
    },
    {
      "type": "collection",
      "id": "collection_men",
      "label": "Collection (Men)"
    },
    {
      "type": "range",
      "id": "limit",
      "min": 4,
      "max": 16,
      "step": 4,
      "label": "Product Limit",
      "default": 8
    },
    {
      "type": "range",
      "id": "padding_vertical",
      "min": 10,
      "max": 60,
      "step": 5,
      "unit": "px",
      "label": "Vertical Padding",
      "default": 30
    }
  ],
  "presets": [
    {
      "name": "Dynamic Product Grid"
    }
  ]
}
{% endschema %}
