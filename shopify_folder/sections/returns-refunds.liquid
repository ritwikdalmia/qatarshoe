{%- style -%}
  /* Info section shared styles */
  .pp-content {
    padding: 96px 150px;
    background: #fff;
    display: flex;
    flex-direction: column;
    gap: 56px;
  }

  .pp-content-block {
    display: flex;
    flex-direction: column;
    gap: 32px;
  }

  .pp-block-title {
    font-family: "Inter", sans-serif;
    font-size: 24px;
    font-weight: 400;
    line-height: 100%;
    letter-spacing: 0;
    color: #2d1f1f;
    margin: 0;
  }

  .pp-block-title--upper {
    font-size: 16px;
    font-weight: 500;
    text-transform: uppercase;
  }

  .pp-block-body {
    display: flex;
    flex-direction: column;
    gap: 24px;
  }

  .pp-block-intro {
    font-family: "Inter", sans-serif;
    font-size: 16px;
    font-weight: 400;
    line-height: 150%;
    color: #1a1a1a;
    margin: 0;
  }

  .pp-block-bullets {
    margin: 0;
    padding-inline-start: 40px;
    list-style: none;
    font-family: "Inter", sans-serif;
    font-size: 16px;
    font-weight: 400;
    line-height: 150%;
    color: #1a1a1a;
  }

  .pp-block-bullets li {
    position: relative;
    margin: 0;
    padding-inline-start: 18px;
  }

  .pp-block-bullets li::before {
    content: "";
    position: absolute;
    inset-inline-start: 0;
    top: 9px;
    width: 6px;
    height: 6px;
    background: #1a1a1a;
    border-radius: 50%;
  }

  .pp-block-bullets li + li {
    margin-top: 2px;
  }

  .pp-block-intro + .pp-block-bullets {
    margin-top: -8px;
  }

  /* Returns specific styles */
  .rr-hero {
      padding: 96px 150px 48px;
      background: #fff;
      display: flex;
      flex-direction: column;
      align-items: flex-start;
      gap: 20px;
  }

  .rr-hero-title {
      font-family: 'Inter', sans-serif;
      font-size: 64px;
      font-weight: 400;
      color: #2D1F1F;
      margin: 0;
      line-height: 1.1;
      text-transform: capitalize;
  }

  .rr-hero-subtitle {
      font-family: 'Inter', sans-serif;
      font-size: 16px;
      font-weight: 400;
      color: #666;
      margin: 0;
      line-height: 1.5;
  }

  .rr-eligibility {
      padding: 96px 150px;
      background: #fff;
      display: flex;
      flex-direction: column;
      align-items: center;
      gap: 48px;
  }

  .rr-eligibility-title {
      font-family: 'Inter', sans-serif;
      font-size: 32px;
      font-weight: 600;
      color: #2D1F1F;
      margin: 0;
      text-align: center;
      line-height: 1.2;
  }

  .rr-eligibility-grid {
      display: flex;
      flex-direction: row;
      background: #E0DCD3;
      border-radius: 24px;
      gap: 1px;
      padding: 1px;
      width: 100%;
      box-sizing: border-box;
  }

  .rr-eligibility-card {
      background: #fff;
      padding: 32px;
      display: flex;
      flex-direction: column;
      flex: 1;
      min-width: 0;
  }

  .rr-eligibility-card:first-child {
      border-radius: 23px 0 0 23px;
  }

  .rr-eligibility-card:last-child {
      border-radius: 0 23px 23px 0;
  }

  .rr-eligibility-card-icon {
      width: 48px;
      height: 48px;
      border-radius: 50%;
      border: 1px solid rgba(26, 26, 26, 0.1);
      display: flex;
      align-items: center;
      justify-content: center;
      overflow: hidden;
      box-sizing: border-box;
      flex-shrink: 0;
      position: relative;
      margin-bottom: 36px;
  }

  .rr-eligibility-card-icon svg {
      width: 24px;
      height: 24px;
  }

  .rr-eligibility-card-icon .flag-svg {
      position: absolute;
      width: auto;
      height: 100%;
      top: 0;
  }

  .rr-eligibility-card-icon--plain {
      border: none;
      border-radius: 0;
      overflow: visible;
  }

  .rr-eligibility-card-icon--plain svg {
      width: 100%;
      height: 100%;
  }

  .rr-eligibility-card-title {
      font-family: 'Inter', sans-serif;
      font-size: 24px;
      font-weight: 600;
      color: #2D1F1F;
      margin: 0 0 12px 0;
      line-height: 1.3;
  }

  .rr-eligibility-card-desc {
      font-family: 'Inter', sans-serif;
      font-size: 16px;
      font-weight: 400;
      color: #2D1F1F;
      margin: 0;
      line-height: 1.6;
  }

  .rr-sides {
      padding: 96px 150px;
      background: #fff;
      display: flex;
      gap: 48px;
      align-items: flex-start;
  }

  .rr-side {
      flex: 1;
      display: flex;
      flex-direction: column;
      gap: 24px;
      min-width: 0;
  }

  .rr-side-title {
      font-family: 'Inter', sans-serif;
      font-size: 32px;
      font-weight: 600;
      color: #2D1F1F;
      margin: 0;
      text-align: center;
      line-height: 1.2;
  }

  .rr-side-subtitle {
      font-family: 'Inter', sans-serif;
      font-size: 16px;
      font-weight: 400;
      color: #666;
      margin: 0;
      text-align: center;
      line-height: 1.6;
  }

  .rr-side-card-wrapper {
      background: #E0DCD3;
      border-radius: 24px;
      padding: 1px;
  }

  .rr-side-card {
      background: #fff;
      border-radius: 23px;
      padding: 24px;
      display: flex;
      flex-direction: column;
      gap: 20px;
  }

  .rr-side-card-title {
      font-family: 'Inter', sans-serif;
      font-size: 20px;
      font-weight: 600;
      color: #2D1F1F;
      margin: 0;
      line-height: 1.3;
  }

  .rr-side-card-list {
      margin: 0;
      padding: 0 0 0 20px;
      display: flex;
      flex-direction: column;
      gap: 12px;
  }

  .rr-side-card-list li {
      font-family: 'Inter', sans-serif;
      font-size: 16px;
      font-weight: 400;
      color: #666;
      line-height: 1.6;
  }

  .rr-non-returnable {
      padding: 96px 150px;
      background: #fff;
      display: flex;
      flex-direction: column;
      align-items: center;
      gap: 48px;
  }

  .rr-non-returnable-title {
      font-family: 'Inter', sans-serif;
      font-size: 32px;
      font-weight: 600;
      color: #2D1F1F;
      margin: 0;
      text-align: center;
      line-height: 1.2;
  }

  .rr-non-returnable-grid {
      display: flex;
      flex-direction: row;
      width: 100%;
      border: 1px solid rgba(0, 0, 0, 0.2);
      border-radius: 16px;
      overflow: hidden;
      box-sizing: border-box;
  }

  .rr-non-returnable-card {
      flex: 1;
      padding: 32px;
      display: flex;
      flex-direction: column;
      align-items: flex-start;
      gap: 24px;
      border-right: 1px solid rgba(0, 0, 0, 0.2);
      min-width: 0;
  }

  .rr-non-returnable-card:last-child {
      border-right: none;
  }

  .rr-non-returnable-icon {
      width: 48px;
      height: 48px;
      flex-shrink: 0;
  }

  .rr-non-returnable-card-title {
      font-family: 'Inter', sans-serif;
      font-size: 24px;
      font-weight: 600;
      color: #2D1F1F;
      margin: 0;
      line-height: 1.3;
  }

  .rr-refund {
      padding: 128px 150px;
      background: #fff;
      display: flex;
      flex-direction: column;
      gap: 48px;
  }

  .rr-refund-label {
      font-family: 'Inter', sans-serif;
      font-size: 20px;
      font-weight: 600;
      color: rgba(45, 31, 31, 0.6);
      line-height: 1.2;
      padding-bottom: 20px;
      border-bottom: 1px solid #E0DCD3;
  }

  .rr-refund-body {
      display: flex;
      flex-direction: column;
      gap: 32px;
      max-width: 1174px;
  }

  .rr-refund-text {
      font-family: "Inter", sans-serif;
      font-size: 48px;
      font-weight: 400;
      color: #2D1F1F;
      margin: 0;
      line-height: 136%;
  }

  /* Contact form on the Returns page */
  .contact-form-section {
      background: #fff;
      padding: 96px 150px;
      position: relative;
      width: 100%;
      box-sizing: border-box;
  }

  .contact-form-section::before {
      content: "";
      position: absolute;
      top: 0;
      left: 0;
      right: 0;
      height: 1px;
      background: #e5e5e5;
  }

  .contact-form-inner {
      max-width: 1620px;
      margin: 0 auto;
      display: flex;
      align-items: flex-start;
      gap: 150px;
  }

  .contact-form-intro {
      flex: 0 0 488px;
      display: flex;
      flex-direction: column;
      gap: 16px;
  }

  .contact-form-intro h2 {
      font-family: 'Inter', sans-serif;
      font-size: 38px;
      font-weight: 400;
      line-height: 100%;
      margin: 0;
      color: #2D1F1F;
  }

  .contact-form-intro p {
      font-family: 'Inter', sans-serif;
      font-size: 16px;
      color: rgba(45, 31, 31, 0.7);
      margin: 0;
  }

  .contact-form-wrapper {
      flex: 1;
      display: flex;
      flex-direction: column;
      gap: 12px;
  }

  .contact-form-wrapper .contact-form-text {
      font-family: 'Inter', sans-serif;
      font-size: 14px;
      line-height: 1.6;
      color: #2d1f1f;
      margin-bottom: 24px;
  }

  .contact-form-wrapper .contact-form-text h4 {
      font-size: 18px;
      font-weight: 600;
      margin-top: 24px;
      margin-bottom: 12px;
  }

  .contact-form-wrapper .contact-form-text p {
      margin-bottom: 12px;
  }

  .contact-form-wrapper form {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 20px 12px;
  }

  .contact-field-group {
      display: flex;
      flex-direction: column;
      gap: 6px;
      align-items: flex-start;
  }

  .contact-field-group.full-width {
      grid-column: 1 / -1;
  }

  .contact-field-group label {
      font-family: 'Inter', sans-serif;
      font-size: 14px;
      font-weight: 500;
      color: #2D1F1F;
      margin: 0;
  }

  .contact-field-group label .required {
      color: #FF0000;
      margin-left: 2px;
  }

  .contact-form-wrapper input[type="text"],
  .contact-form-wrapper input[type="email"],
  .contact-form-wrapper input[type="tel"],
  .contact-form-wrapper textarea {
      width: 100%;
      background: #fff;
      border: 1px solid rgba(45, 31, 31, 0.2);
      border-radius: 6px;
      color: #2D1F1F;
      font-family: 'Inter', sans-serif;
      font-size: 14px;
      box-sizing: border-box;
      outline: none;
  }

  .contact-form-wrapper input[type="text"],
  .contact-form-wrapper input[type="email"],
  .contact-form-wrapper input[type="tel"] {
      height: 44px;
      padding: 0 12px;
  }

  .contact-form-wrapper textarea {
      height: 108px;
      padding: 12px;
      resize: vertical;
  }

  .contact-submit-custom {
      width: 100%;
      height: 48px;
      display: inline-flex;
      align-items: center;
      justify-content: center;
      gap: 8px;
      background: #fff;
      color: #2D1F1F;
      border: 1px solid #2D1F1F;
      border-radius: 900px;
      font-family: 'Inter', sans-serif;
      font-size: 16px;
      font-weight: 600;
      cursor: pointer;
  }

  .contact-submit-custom:hover {
      background: #2D1F1F;
      color: #fff;
  }

  .wpcf7-response-output {
      grid-column: 1 / -1;
      margin: 12px 0 0;
      padding: 14px 18px;
      font-size: 14px;
      border-radius: 4px;
      color: #2D1F1F;
      border: 1px solid rgba(45, 31, 31, 0.2);
  }

  .wpcf7-response-output.sent {
      border-color: #28a745;
      color: #1e7a35;
      background-color: rgba(40, 167, 69, 0.05);
  }

  .wpcf7-response-output.invalid {
      border-color: #d93b3d;
      color: #b1282a;
      background-color: rgba(217, 59, 61, 0.05);
  }

  @media (max-width: 1023px) {
      .rr-hero,
      .rr-eligibility,
      .rr-sides,
      .rr-non-returnable,
      .rr-refund,
      .pp-content,
      .contact-form-section {
          padding: 64px 40px;
      }
      .rr-eligibility-grid {
          flex-direction: column;
      }
      .rr-eligibility-card:first-child {
          border-radius: 23px 23px 0 0;
      }
      .rr-eligibility-card:last-child {
          border-radius: 0 0 23px 23px;
      }
      .rr-sides {
          flex-direction: column;
          gap: 32px;
      }
      .rr-non-returnable-grid {
          flex-direction: column;
      }
      .rr-non-returnable-card {
          border-right: none;
          border-bottom: 1px solid rgba(0, 0, 0, 0.2);
      }
      .rr-non-returnable-card:last-child {
          border-bottom: none;
      }
      .contact-form-inner {
          flex-direction: column;
          gap: 40px;
      }
  }

  @media (max-width: 767px) {
      .rr-hero,
      .rr-eligibility,
      .rr-sides,
      .rr-non-returnable,
      .rr-refund,
      .pp-content,
      .contact-form-section {
          padding: 48px 24px;
      }
      .rr-hero-title {
          font-size: 32px;
      }
      .rr-eligibility-title,
      .rr-side-title,
      .rr-non-returnable-title,
      .rr-refund-text {
          font-size: 24px;
      }
      .contact-form-wrapper form {
          grid-template-columns: 1fr;
      }
      .contact-bottom-row {
          flex-direction: column;
          align-items: stretch;
      }
      .contact-toggle {
          justify-content: center;
      }
  }
{%- endstyle -%}

<script>
  document.body.classList.add('returns-refunds-page-body');
</script>

<main class="rr-main">
    <!-- Hero Section -->
    <header class="rr-hero">
        <h1 class="rr-hero-title">{{ section.settings.heading | default: page.title }}</h1>
        <p class="rr-hero-subtitle">{{ section.settings.subheading | default: "At Qtrshoe, we handle returns and refunds in a clear and fair manner. Eligibility depends on the service selected and the condition of the item." }}</p>
    </header>

    <!-- Content Blocks (Text First) -->
    <section class="pp-content">
        {%- for block in section.blocks -%}
            {%- if block.type == 'content_block' -%}
                <div class="pp-content-block" {{ block.shopify_attributes }}>
                    {%- if block.settings.title != blank -%}
                        <h2 class="pp-block-title{% if block.settings.uppercase %} pp-block-title--upper{% endif %}">
                            {{ block.settings.title }}
                        </h2>
                    {%- endif -%}
                    
                    {%- if block.settings.intro != blank or block.settings.bullets != blank -%}
                        <div class="pp-block-body">
                            {%- if block.settings.intro != blank -%}
                                <p class="pp-block-intro">{{ block.settings.intro | newline_to_br }}</p>
                            {%- endif -%}
                            
                            {%- if block.settings.bullets != blank -%}
                                <ul class="pp-block-bullets">
                                    {%- assign bullet_items = block.settings.bullets | split: '||' -%}
                                    {%- for item in bullet_items -%}
                                        {%- if item != blank -%}
                                            <li>{{ item | strip }}</li>
                                        {%- endif -%}
                                    {%- endfor -%}
                                </ul>
                            {%- endif -%}
                        </div>
                    {%- endif -%}
                </div>
            {%- endif -%}
        {%- endfor -%}
    </section>

    <!-- Eligibility Section -->
    {%- assign has_eligibility = false -%}
    {%- for block in section.blocks -%}{%- if block.type == 'eligibility_card' -%}{%- assign has_eligibility = true -%}{%- endif -%}{%- endfor -%}
    
    {%- if has_eligibility -%}
        <section class="rr-eligibility">
            <h2 class="rr-eligibility-title">{{ section.settings.eligibility_heading | default: "Return Eligibility By Service" }}</h2>
            <div class="rr-eligibility-grid">
                {%- for block in section.blocks -%}
                    {%- if block.type == 'eligibility_card' -%}
                        <div class="rr-eligibility-card" {{ block.shopify_attributes }}>
                            <div class="rr-eligibility-card-icon{% if block.settings.icon_type == 'plain_svg' %} rr-eligibility-card-icon--plain{% endif %}">
                                {%- if block.settings.icon_type == 'qatar' -%}
                                    <svg xmlns="http://www.w3.org/2000/svg" viewBox="5 1 26 26" class="flag-svg flag-qatar"><rect width="40" height="28" fill="#fff"/><path d="M12,0 L16,1.556 L12,3.111 L16,4.667 L12,6.222 L16,7.778 L12,9.333 L16,10.889 L12,12.444 L16,14 L12,15.556 L16,17.111 L12,18.667 L16,20.222 L12,21.778 L16,23.333 L12,24.889 L16,26.444 L12,28 L40,28 L40,0Z" fill="#8A1538"/></svg>
                                {%- elsif block.settings.icon_type == 'uae' -%}
                                    <svg xmlns="http://www.w3.org/2000/svg" viewBox="2 0 28 28" class="flag-svg flag-uae"><rect width="40" height="9.333" fill="#00732F"/><rect y="9.333" width="40" height="9.333" fill="#fff"/><rect y="18.667" width="40" height="9.334" fill="#000"/><rect width="10" height="28" fill="#FF0000"/></svg>
                                {%- else -%}
                                    {{ block.settings.icon_svg }}
                                {%- endif -%}
                            </div>
                            <h3 class="rr-eligibility-card-title">{{ block.settings.title }}</h3>
                            <p class="rr-eligibility-card-desc">{{ block.settings.description | newline_to_br }}</p>
                        </div>
                    {%- endif -%}
                {%- endfor -%}
            </div>
        </section>
    {%- endif -%}

    <!-- Sides / Grid Section -->
    {%- assign has_sides = false -%}
    {%- for block in section.blocks -%}{%- if block.type == 'side_card' -%}{%- assign has_sides = true -%}{%- endif -%}{%- endfor -%}
    
    {%- if has_sides -%}
        <section class="rr-sides">
            <!-- Left Side -->
            <div class="rr-side">
                <h2 class="rr-side-title">{{ section.settings.side_left_heading | default: "If the issue is on Qtrshoe's side" }}</h2>
                <p class="rr-side-subtitle">{{ section.settings.side_left_subheading | default: "Wrong item, defect, or order error" }}</p>
                <div class="rr-side-card-wrapper">
                    <div class="rr-side-card">
                        <ul class="rr-side-card-list">
                            {%- for block in section.blocks -%}
                                {%- if block.type == 'side_card' and block.settings.side == 'left' -%}
                                    <li {{ block.shopify_attributes }}>{{ block.settings.text }}</li>
                                {%- endif -%}
                            {%- endfor -%}
                        </ul>
                    </div>
                </div>
            </div>
            
            <!-- Right Side -->
            <div class="rr-side">
                <h2 class="rr-side-title">{{ section.settings.side_right_heading | default: "If the return is from the customer's side" }}</h2>
                <p class="rr-side-subtitle">{{ section.settings.side_right_subheading | default: "Size issue, preference, or change of mind" }}</p>
                <div class="rr-side-card-wrapper">
                    <div class="rr-side-card">
                        <ul class="rr-side-card-list">
                            {%- for block in section.blocks -%}
                                {%- if block.type == 'side_card' and block.settings.side == 'right' -%}
                                    <li {{ block.shopify_attributes }}>{{ block.settings.text }}</li>
                                {%- endif -%}
                            {%- endfor -%}
                        </ul>
                    </div>
                </div>
            </div>
        </section>
    {%- endif -%}

    <!-- Non-Returnable Items Section -->
    {%- assign has_non_returnable = false -%}
    {%- for block in section.blocks -%}{%- if block.type == 'non_returnable_card' -%}{%- assign has_non_returnable = true -%}{%- endif -%}{%- endfor -%}
    
    {%- if has_non_returnable -%}
        <section class="rr-non-returnable">
            <h2 class="rr-non-returnable-title">{{ section.settings.non_returnable_heading | default: "Non-Returnable Items" }}</h2>
            <div class="rr-non-returnable-grid">
                {%- for block in section.blocks -%}
                    {%- if block.type == 'non_returnable_card' -%}
                        <div class="rr-non-returnable-card" {{ block.shopify_attributes }}>
                            <div class="rr-non-returnable-icon">
                                {{ block.settings.icon_svg }}
                            </div>
                            <h3 class="rr-non-returnable-card-title">{{ block.settings.title }}</h3>
                        </div>
                    {%- endif -%}
                {%- endfor -%}
            </div>
        </section>
    {%- endif -%}

    <!-- Refund Processing Section -->
    {%- if section.settings.refund_text != blank -%}
        <section class="rr-refund">
            <div class="rr-refund-label">{{ section.settings.refund_label | default: "Refund Processing" }}</div>
            <div class="rr-refund-body">
                <p class="rr-refund-text">{{ section.settings.refund_text }}</p>
            </div>
        </section>
    {%- endif -%}

    <!-- Contact Form Section -->
    <section class="contact-form-section">
        <div class="contact-form-inner">
            <div class="contact-form-intro">
                <h2>{{ section.settings.form_heading | default: "Send Us A Message" }}</h2>
                <p>{{ section.settings.form_subheading | default: "Fill out the form and we'll get back to you as quickly as possible." }}</p>
            </div>

            <div class="contact-form-wrapper">
                {%- form 'contact', id: 'ContactForm' -%}
                    {%- if form.posted_successfully? -%}
                        <div class="wpcf7-response-output sent" role="status">
                            Thanks for contacting us! We'll get back to you as soon as possible.
                        </div>
                    {%- elsif form.errors -%}
                        <div class="wpcf7-response-output invalid" role="alert">
                            {{ form.errors | default_errors }}
                        </div>
                    {%- endif -%}

                    <div class="contact-field-group">
                        <label for="ContactFormFirstName">First Name <span class="required">*</span></label>
                        <input type="text" id="ContactFormFirstName" name="contact[first_name]" placeholder="First Name" value="{% if form.first_name %}{{ form.first_name }}{% elsif customer %}{{ customer.first_name }}{% endif %}" required aria-required="true" />
                    </div>
                    <div class="contact-field-group">
                        <label for="ContactFormLastName">Last Name <span class="required">*</span></label>
                        <input type="text" id="ContactFormLastName" name="contact[last_name]" placeholder="Last Name" value="{% if form.last_name %}{{ form.last_name }}{% elsif customer %}{{ customer.last_name }}{% endif %}" required aria-required="true" />
                    </div>
                    <div class="contact-field-group">
                        <label for="ContactFormEmail">Email <span class="required">*</span></label>
                        <input type="email" id="ContactFormEmail" name="contact[email]" placeholder="Email" value="{% if form.email %}{{ form.email }}{% elsif customer %}{{ customer.email }}{% endif %}" required aria-required="true" />
                    </div>
                    <div class="contact-field-group">
                        <label for="ContactFormPhone">Phone Number (optional)</label>
                        <input type="tel" id="ContactFormPhone" name="contact[phone]" placeholder="Phone Number (optional)" value="{% if form.phone %}{{ form.phone }}{% elsif customer %}{{ customer.phone }}{% endif %}" pattern="^[34567][0-9]{7}$" title="Please enter a valid 8-digit Qatar phone number (starting with 3, 4, 5, 6, or 7)." />
                    </div>
                    <div class="contact-field-group full-width">
                        <label for="ContactFormMessage">Your Message <span class="required">*</span></label>
                        <textarea cols="40" rows="10" id="ContactFormMessage" name="contact[body]" placeholder="Your Message" required aria-required="true">{% if form.body %}{{ form.body }}{% endif %}</textarea>
                    </div>
                    
                    <div class="contact-field-group full-width" style="margin-top: 12px;">
                        <button type="submit" class="contact-submit-custom">
                            <svg class="contact-submit-icon" width="20" height="20" viewBox="0 0 20 20" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
                                <path d="M17.5 2.5L9.16667 10.8333" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
                                <path d="M17.5 2.5L12.0833 17.5L9.16667 10.8333L2.5 7.91667L17.5 2.5Z" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
                            </svg>
                            <span>Send a Message</span>
                        </button>
                    </div>
                {%- endform -%}
            </div>
        </div>
    </section>
</main>

