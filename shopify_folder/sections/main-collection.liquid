  function initCollectionProductImageSlideshows() {
    const cards = document.querySelectorAll('.product-card-img[data-images]');
    cards.forEach(card => {
      if (card.dataset.slideshowInitialized === 'true') return;
      card.dataset.slideshowInitialized = 'true';

      const imagesAttr = card.getAttribute('data-images');
      if (!imagesAttr) return;
      const images = imagesAttr.split(',').filter(src => src.trim() !== '');
      if (images.length <= 1) return;
      
      let imgEl = card.querySelector('img');
      if (!imgEl) return;
      
      card.style.position = 'relative';
      card.style.overflow = 'hidden';
      
      let currentIndex = 0;
      
      function showNextImage() {
        const nextIndex = (currentIndex + 1) % images.length;
        const nextSrc = images[nextIndex];
        
        const nextImgEl = document.createElement('img');
        const triggerTransition = () => {
          nextImgEl.style.position = 'absolute';
          nextImgEl.style.top = '0';
          nextImgEl.style.left = '-100%';
          nextImgEl.style.width = '100%';
          nextImgEl.style.height = '100%';
          nextImgEl.style.objectFit = 'cover';
          nextImgEl.style.transition = 'transform 0.5s cubic-bezier(0.25, 0.46, 0.45, 0.94)';
          
          card.appendChild(nextImgEl);
          nextImgEl.offsetWidth;
          
          imgEl.style.transition = 'transform 0.5s cubic-bezier(0.25, 0.46, 0.45, 0.94)';
          imgEl.style.transform = 'translateX(100%)';
          nextImgEl.style.transform = 'translateX(100%)';
          
          setTimeout(() => {
            if (imgEl && imgEl.parentNode === card) {
              card.removeChild(imgEl);
            }
            
            nextImgEl.style.transition = 'none';
            nextImgEl.style.position = 'relative';
            nextImgEl.style.left = '0';
            nextImgEl.style.transform = 'none';
            
            imgEl = nextImgEl;
            currentIndex = nextIndex;
            setTimeout(showNextImage, {{ settings.slideshow_interval | default: 5 | times: 1000 }});
          }, 500);
        };
        
        nextImgEl.onload = triggerTransition;
        nextImgEl.onerror = triggerTransition;
        nextImgEl.src = nextSrc;
      }
      
      setTimeout(showNextImage, {{ settings.slideshow_interval | default: 5 | times: 1000 }});
    });
  }

  document.addEventListener('DOMContentLoaded', function() {
    syncFiltersFromURL();
    
    {%- if settings.slideshow_enabled_collections -%}
    initCollectionProductImageSlideshows();
    {%- endif -%}
    
    var savedCurrency = localStorage.getItem('qtr_currency') || 'QAR';
    if (typeof window.applyStoreCurrency === 'function') {
      window.applyStoreCurrency(savedCurrency);
    }
    
    // Add input listener for price fields to update dynamic count
    document.querySelectorAll('.filter-price-input').forEach(input => {
      input.addEventListener('input', updateDrawerResultCount);
    });

    loadAllCollectionPages();
  });
</script>

