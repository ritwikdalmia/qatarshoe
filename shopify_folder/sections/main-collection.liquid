  function initCategoryTypeFilters() {
    const params = new URLSearchParams(window.location.search);
    const activeTypes = params.getAll('filter.p.product_type').map(t => t.trim().toLowerCase());
    const pills = document.querySelectorAll('.filter-pill-category-type');
    
    let activePillFound = false;
    
    if (activeTypes.length > 0) {
      let remainingTypes = [...activeTypes];
      
      const pillData = Array.from(pills).map(pill => {
        const valuesAttr = pill.getAttribute('data-type-values') || '';
        const values = valuesAttr.split(',').map(v => v.trim().toLowerCase()).filter(v => v !== '');
        return { pill, values };
      });
      
      pillData.sort((a, b) => b.values.length - a.values.length);
      
      pillData.forEach(item => {
        if (item.values.length === 0) return;
        
        const isMatch = item.values.every(v => remainingTypes.includes(v));
        if (isMatch) {
          item.pill.classList.add('active');
          activePillFound = true;
          remainingTypes = remainingTypes.filter(v => !item.values.includes(v));
        } else {
          item.pill.classList.remove('active');
        }
      });
    }
    
    const allPill = document.querySelector('.filter-pill[data-is-brand-all="true"]');
    if (allPill) {
      if (activePillFound) {
        allPill.classList.remove('active');
      } else {
        allPill.classList.add('active');
      }
    }
  }

