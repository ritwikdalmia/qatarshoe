{%- style -%}
  /* Shared Info-section CSS */
  .pp-content {
    padding: 96px 150px;
    background: #fff;
    display: flex;
    flex-direction: column;
    gap: 56px;
  }

  .pp-content-block {
    display: flex;
    flex-direction: column;
    gap: 32px;
  }

  .pp-block-title {
    font-family: "Inter", sans-serif;
    font-size: 24px;
    font-weight: 400;
    line-height: 100%;
    letter-spacing: 0;
    color: #2d1f1f;
    margin: 0;
  }

  .pp-block-title--upper {
    font-size: 16px;
    font-weight: 500;
    text-transform: uppercase;
  }

  .pp-block-body {
    display: flex;
    flex-direction: column;
    gap: 24px;
  }

  .pp-block-intro {
    font-family: "Inter", sans-serif;
    font-size: 16px;
    font-weight: 400;
    line-height: 150%;
    color: #1a1a1a;
    margin: 0;
  }

  .pp-block-bullets {
    margin: 0;
    padding-inline-start: 40px;
    list-style: none;
    font-family: "Inter", sans-serif;
    font-size: 16px;
    font-weight: 400;
    line-height: 150%;
    color: #1a1a1a;
  }

  .pp-block-bullets li {
    position: relative;
    margin: 0;
    padding-inline-start: 18px;
  }

  .pp-block-bullets li::before {
    content: "";
    position: absolute;
    inset-inline-start: 0;
    top: 9px;
    width: 6px;
    height: 6px;
    background: #1a1a1a;
    border-radius: 50%;
  }

  .pp-block-bullets li + li {
    margin-top: 2px;
  }

  .pp-block-intro + .pp-block-bullets {
    margin-top: -8px;
  }

  /* Personal Shopping Hero */
  .ps-hero {
      padding: 96px 150px 48px;
      background: #fff;
      display: flex;
      flex-direction: column;
      align-items: flex-start;
      gap: 20px;
  }

  .ps-hero-title {
      font-family: 'Inter', sans-serif;
      font-size: 64px;
      font-weight: 400;
      color: #2D1F1F;
      margin: 0;
      line-height: 1.1;
      text-transform: capitalize;
  }

  .ps-hero-subtitle {
      font-family: 'Inter', sans-serif;
      font-size: 16px;
      font-weight: 400;
      color: #666;
      margin: 0;
      line-height: 1.5;
  }

  /* Contact Form Section */
  .contact-form-section {
      background: #fff;
      padding: 96px 150px;
      position: relative;
      width: 100%;
      box-sizing: border-box;
  }

  .contact-form-section::before {
      content: "";
      position: absolute;
      top: 0;
      left: 0;
      right: 0;
      height: 1px;
      background: #e5e5e5;
  }

  .contact-form-inner {
      max-width: 1620px;
      margin: 0 auto;
      display: flex;
      align-items: flex-start;
      gap: 150px;
  }

  .contact-form-intro {
      flex: 0 0 488px;
      display: flex;
      flex-direction: column;
      gap: 16px;
  }

  .contact-form-intro h2 {
      font-family: 'Inter', sans-serif;
      font-size: 38px;
      font-weight: 400;
      line-height: 100%;
      margin: 0;
      color: #2D1F1F;
  }

  .contact-form-intro p {
      font-family: 'Inter', sans-serif;
      font-size: 16px;
      color: rgba(45, 31, 31, 0.7);
      margin: 0;
  }

  .contact-form-wrapper {
      flex: 1;
      display: flex;
      flex-direction: column;
      gap: 12px;
  }

  .contact-form-wrapper .contact-form-text {
      font-family: 'Inter', sans-serif;
      font-size: 14px;
      line-height: 1.6;
      color: #2d1f1f;
      margin-bottom: 24px;
  }

  .contact-form-wrapper .contact-form-text h4 {
      font-size: 18px;
      font-weight: 600;
      margin-top: 24px;
      margin-bottom: 12px;
  }

  .contact-form-wrapper .contact-form-text p {
      margin-bottom: 12px;
  }

  .contact-form-wrapper form {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 20px 12px;
  }

  .contact-field-group {
      display: flex;
      flex-direction: column;
      gap: 6px;
      align-items: flex-start;
  }

  .contact-field-group.full-width {
      grid-column: 1 / -1;
  }

  .contact-field-group label {
      font-family: 'Inter', sans-serif;
      font-size: 14px;
      font-weight: 500;
      color: #2D1F1F;
      margin: 0;
  }

  .contact-field-group label .required {
      color: #FF0000;
      margin-left: 2px;
  }

  .contact-form-wrapper input[type="text"],
  .contact-form-wrapper input[type="email"],
  .contact-form-wrapper input[type="tel"],
  .contact-form-wrapper textarea {
      width: 100%;
      background: #fff;
      border: 1px solid rgba(45, 31, 31, 0.2);
      border-radius: 6px;
      color: #2D1F1F;
      font-family: 'Inter', sans-serif;
      font-size: 14px;
      box-sizing: border-box;
      outline: none;
  }

  .contact-form-wrapper input[type="text"],
  .contact-form-wrapper input[type="email"],
  .contact-form-wrapper input[type="tel"] {
      height: 44px;
      padding: 0 12px;
  }

  .contact-form-wrapper textarea {
      height: 108px;
      padding: 12px;
      resize: vertical;
  }

  .contact-submit-custom {
      width: 100%;
      height: 48px;
      display: inline-flex;
      align-items: center;
      justify-content: center;
      gap: 8px;
      background: #fff;
      color: #2D1F1F;
      border: 1px solid #2D1F1F;
      border-radius: 900px;
      font-family: 'Inter', sans-serif;
      font-size: 16px;
      font-weight: 600;
      cursor: pointer;
  }

  .contact-submit-custom:hover {
      background: #2D1F1F;
      color: #fff;
  }

  .wpcf7-response-output {
      grid-column: 1 / -1;
      margin: 12px 0 0;
      padding: 14px 18px;
      font-size: 14px;
      border-radius: 4px;
      color: #2D1F1F;
      border: 1px solid rgba(45, 31, 31, 0.2);
  }

  .wpcf7-response-output.sent {
      border-color: #28a745;
      color: #1e7a35;
      background-color: rgba(40, 167, 69, 0.05);
  }

  .wpcf7-response-output.invalid {
      border-color: #d93b3d;
      color: #b1282a;
      background-color: rgba(217, 59, 61, 0.05);
  }

  @media (max-width: 1023px) {
      .ps-hero,
      .pp-content,
      .contact-form-section {
          padding: 64px 40px;
      }
      .contact-form-inner {
          flex-direction: column;
          gap: 40px;
      }
  }

  @media (max-width: 767px) {
      .ps-hero,
      .pp-content,
      .contact-form-section {
          padding: 48px 24px;
      }
      .ps-hero-title {
          font-size: 32px;
      }
      .contact-form-wrapper form {
          grid-template-columns: 1fr;
      }
      .contact-bottom-row {
          flex-direction: column;
          align-items: stretch;
      }
      .contact-toggle {
          justify-content: center;
      }
  }
{%- endstyle -%}

<script>
  document.body.classList.add('personal-shopping-page-body');
</script>

<main class="ps-main">
    <!-- Hero Section -->
    <header class="ps-hero">
        <h1 class="ps-hero-title">{{ section.settings.heading | default: "Personal Shopping" }}</h1>
        <p class="ps-hero-subtitle">{{ section.settings.subheading | default: "Access products sourced specifically on demand for you." }}</p>
    </header>

    <!-- Stacked Content Blocks (Text First) -->
    <section class="pp-content">
        {%- for block in section.blocks -%}
            {%- if block.type == 'content_block' -%}
                <div class="pp-content-block" {{ block.shopify_attributes }}>
                    {%- if block.settings.title != blank -%}
                        <h2 class="pp-block-title{% if block.settings.uppercase %} pp-block-title--upper{% endif %}">
                            {{ block.settings.title }}
                        </h2>
                    {%- endif -%}
                    
                    {%- if block.settings.intro != blank or block.settings.bullets != blank -%}
                        <div class="pp-block-body">
                            {%- if block.settings.intro != blank -%}
                                <p class="pp-block-intro">{{ block.settings.intro | newline_to_br }}</p>
                            {%- endif -%}
                            
                            {%- if block.settings.bullets != blank -%}
                                <ul class="pp-block-bullets">
                                    {%- assign bullet_items = block.settings.bullets | split: '||' -%}
                                    {%- for item in bullet_items -%}
                                        {%- if item != blank -%}
                                            <li>{{ item | strip }}</li>
                                        {%- endif -%}
                                    {%- endfor -%}
                                </ul>
                            {%- endif -%}
                        </div>
                    {%- endif -%}
                </div>
            {%- endif -%}
        {%- endfor -%}
    </section>

    <!-- Contact Form Section -->
    <section class="contact-form-section">
        <div class="contact-form-inner">
            <div class="contact-form-intro">
                <h2>{{ section.settings.form_heading | default: "Send Us A Message" }}</h2>
                <p>{{ section.settings.form_subheading | default: "Fill out the form and we'll get back to you as quickly as possible." }}</p>
            </div>

            <div class="contact-form-wrapper">
                {%- form 'contact', id: 'ContactForm' -%}
                    {%- if form.posted_successfully? -%}
                        <div class="wpcf7-response-output sent" role="status">
                            Thanks for contacting us! We'll get back to you as soon as possible.
                        </div>
                    {%- elsif form.errors -%}
                        <div class="wpcf7-response-output invalid" role="alert">
                            {{ form.errors | default_errors }}
                        </div>
                    {%- endif -%}

                    <div class="contact-field-group">
                        <label for="ContactFormFirstName">First Name <span class="required">*</span></label>
                        <input type="text" id="ContactFormFirstName" name="contact[first_name]" placeholder="First Name" value="{% if form.first_name %}{{ form.first_name }}{% elsif customer %}{{ customer.first_name }}{% endif %}" required aria-required="true" />
                    </div>
                    <div class="contact-field-group">
                        <label for="ContactFormLastName">Last Name <span class="required">*</span></label>
                        <input type="text" id="ContactFormLastName" name="contact[last_name]" placeholder="Last Name" value="{% if form.last_name %}{{ form.last_name }}{% elsif customer %}{{ customer.last_name }}{% endif %}" required aria-required="true" />
                    </div>
                    <div class="contact-field-group">
                        <label for="ContactFormEmail">Email <span class="required">*</span></label>
                        <input type="email" id="ContactFormEmail" name="contact[email]" placeholder="Email" value="{% if form.email %}{{ form.email }}{% elsif customer %}{{ customer.email }}{% endif %}" required aria-required="true" />
                    </div>
                    <div class="contact-field-group">
                        <label for="ContactFormPhone">Phone Number (optional)</label>
                        <input type="tel" id="ContactFormPhone" name="contact[phone]" placeholder="Phone Number (optional)" value="{% if form.phone %}{{ form.phone }}{% elsif customer %}{{ customer.phone }}{% endif %}" />
                    </div>
                    <div class="contact-field-group full-width">
                        <label for="ContactFormMessage">Your Message <span class="required">*</span></label>
                        <textarea cols="40" rows="10" id="ContactFormMessage" name="contact[body]" placeholder="Your Message" required aria-required="true">{% if form.body %}{{ form.body }}{% endif %}</textarea>
                    </div>
                    
                    <div class="contact-field-group full-width" style="margin-top: 12px;">
                        <button type="submit" class="contact-submit-custom">
                            <svg class="contact-submit-icon" width="20" height="20" viewBox="0 0 20 20" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
                                <path d="M17.5 2.5L9.16667 10.8333" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
                                <path d="M17.5 2.5L12.0833 17.5L9.16667 10.8333L2.5 7.91667L17.5 2.5Z" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
                            </svg>
                            <span>Send a Message</span>
                        </button>
                    </div>
                {%- endform -%}
            </div>
        </div>
    </section>
</main>

{% schema %}
{
  "name": "Personal Shopping",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Personal Shopping"
    },
    {
      "type": "textarea",
      "id": "subheading",
      "label": "Subheading",
      "default": "Access products sourced specifically on demand for you."
    },
    {
      "type": "header",
      "content": "Contact Form Settings"
    },
    {
      "type": "text",
      "id": "form_heading",
      "label": "Form Heading",
      "default": "Send Us A Message"
    },
    {
      "type": "text",
      "id": "form_subheading",
      "label": "Form Subheading",
      "default": "Fill out the form and we'll get back to you as quickly as possible."
    },
    {
      "type": "richtext",
      "id": "form_text",
      "label": "Form Descriptive Text"
    }
  ],
  "blocks": [
    {
      "type": "content_block",
      "name": "Content Block",
      "settings": [
        {
          "type": "text",
          "id": "title",
          "label": "Block Title",
          "default": "HOW IT WORKS"
        },
        {
          "type": "checkbox",
          "id": "uppercase",
          "label": "Uppercase Heading",
          "default": true
        },
        {
          "type": "textarea",
          "id": "intro",
          "label": "Intro Paragraph"
        },
        {
          "type": "textarea",
          "id": "bullets",
          "label": "Bullet Items (separated by ||)",
          "default": "Get in touch with our customer care team via WhatsApp and share the product details — style, size, and any preferences||Our team will confirm availability and provide full details before any payment is taken.||Once confirmed, payment is collected in full via Bank Transfer before sourcing begins.||Your item is sourced exclusively for you and dispatched within the confirmed timeframe."
        }
      ]
    }
  ]
}
{% endschema %}
