 <style id="dept-toggle-styles">
/* Department Navigation Switching */
.navigation-menu-wrapper[data-dept] { display: none; }
.navigation-menu-wrapper[data-dept="women"] { display: flex; }
body.dept-women .navigation-menu-wrapper[data-dept="women"] { display: flex !important; }
body.dept-women .navigation-menu-wrapper[data-dept="men"] { display: none !important; }
body.dept-men .navigation-menu-wrapper[data-dept="men"] { display: flex !important; }
body.dept-men .navigation-menu-wrapper[data-dept="women"] { display: none !important; }
/* Toggle styling */
.header-department-box-container a { cursor: pointer !important; user-select: none; }
.header-department-box-container a:hover { text-decoration: none; }

/* Active indicator */
.department-text.jsx-2005615775 { font-weight: bold !important; position: relative; }
.department-text.jsx-2005615775::after { content: ''; position: absolute; bottom: -2px; left: 0; right: 0; height: 2px; background-color: currentColor; }
/* Hide old SVG logo (rendered by React/JS) */
.qatarshoes-logo-container svg, .logo.jsx-f20bdc55fc53c205 svg, #logo-img svg, a[aria-label="qatarshoes logo"] svg, svg[viewbox="0 0 128 47"], svg[viewBox="0 0 128 47"] { display: none !important; visibility: hidden !important; }
/* Show Qatar Shoes logo image */
