      "id": "heading",
      "label": "Heading",
      "default": "FAQs"
    },
    {
      "type": "textarea",
      "id": "subheading",
      "label": "Subheading",
      "default": "Clear answers to common questions about shopping, delivery timelines, payment methods, returns, and product availability."
    },
    {
      "type": "text",
      "id": "form_heading",
      "label": "Form Heading",
      "default": "Send Us A Message"
    },
    {
      "type": "text",
      "id": "form_subheading",
      "label": "Form Subheading",
      "default": "Fill out the form and we'll get back to you as quickly as possible."
    }
  ]
}
{% endschema %}
