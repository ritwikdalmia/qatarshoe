{% comment %}
  QatarShoes — Hero Fullscreen Section
  Full-bleed hero image matching https://qatarshoe.com/ready-to-go/
{% endcomment %}

{%- liquid
  if section.settings.image_desktop != blank
    assign hero_desktop = section.settings.image_desktop | image_url: width: 2000
  else
    assign hero_desktop = 'https://staging3.qatarshoe.com/wp-content/uploads/2026/03/Group-2.png'
  endif

  if section.settings.image_mobile != blank
    assign hero_mobile = section.settings.image_mobile | image_url: width: 800
  else
    assign hero_mobile = 'https://staging3.qatarshoe.com/wp-content/uploads/2026/03/qtr-w-mobile.png'
  endif
-%}

<div class="qtr-hero home-hero-content" style="
  --bg-desktop: url('{{ hero_desktop }}');
  --bg-mobile: url('{{ hero_mobile }}');
  background-image: var(--bg-desktop);
">
  <div class="hero-image-mask"></div>

  {%- if section.settings.fomo_text != blank -%}
    <div class="hero-fomo">
      <span>🔥</span>
      <span class="fomo-message">{{ section.settings.fomo_text }}</span>
    </div>
  {%- endif -%}
</div>

<style>
  @media (max-width: 1023px) {
    .qtr-hero { background-image: var(--bg-mobile) !important; }
  }
  /* Push hero under transparent header on desktop */
  @media (min-width: 1024px) {
    .qtr-hero { margin-top: 0; }
  }
  /* On mobile, push below fixed sticky header */
  @media (max-width: 1023px) {
    .qtr-hero { margin-top: 60px; }
  }
</style>

{% schema %}
{
  "name": "Hero Fullscreen",
  "settings": [
    {
      "type": "image_picker",
      "id": "image_desktop",
      "label": "Desktop Hero Image"
    },
    {
      "type": "image_picker",
      "id": "image_mobile",
      "label": "Mobile Hero Image"
    },
    {
      "type": "text",
      "id": "fomo_text",
      "label": "FOMO Badge Text",
      "default": "🔥 Most loved today"
    }
  ],
  "presets": [
    { "name": "Hero Fullscreen" }
  ]
}
{% endschema %}
