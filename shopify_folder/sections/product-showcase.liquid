{% comment %}
  QatarShoes — Product Showcase Section
  Replicates the showcased collection grids from the home page
{% endcomment %}

{%- liquid
  assign heading = section.settings.heading | default: 'Featured'
  assign view_all_url = section.settings.view_all_url | default: '/collections/all'
  assign collection_handle = section.settings.collection_handle | default: ''
  assign max_products = section.settings.max_products | default: 6

  if collection_handle != blank
    assign col = collections[collection_handle]
  endif
-%}

<div class="qtr-section" id="section-{{ section.id }}">
  <div class="section-heading-row">
    <h2 class="section-heading">{{ heading }}</h2>
    <a href="{{ view_all_url }}" class="view-more-link">
      View more
      <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><polyline points="9 18 15 12 9 6"/></svg>
    </a>
  </div>

  <div class="product-grid">
    {%- if col != blank and col.products.size > 0 -%}
      {%- for product in col.products limit: max_products -%}
        <a href="{{ product.url }}" class="product-card" aria-label="{{ product.title }}">
          <div class="product-card-img">
            {%- if product.featured_image != blank -%}
              <img src="{{ product.featured_image | image_url: width: 600, height: 900, crop: 'center' }}"
                   alt="{{ product.featured_image.alt | escape }}"
                   loading="lazy">
            {%- else -%}
              <div class="product-card-placeholder" style="background:#f9f9f9;display:flex;align-items:center;justify-content:center;">
                <svg width="40" height="40" viewBox="0 0 24 24" fill="none" stroke="#ccc" stroke-width="1"><rect x="3" y="3" width="18" height="18" rx="2"/><circle cx="8.5" cy="8.5" r="1.5"/><polyline points="21 15 16 10 5 21"/></svg>
              </div>
            {%- endif -%}

            <!-- Wishlist Button -->
            <button type="button" class="product-wishlist-btn" aria-label="Add to wishlist"
                    data-id="{{ product.id }}"
                    data-title="{{ product.title | escape }}"
                    data-image="{{ product.featured_image | image_url: width: 300 }}"
                    data-price="{{ product.price }}"
                    data-url="{{ product.url }}"
                    data-vendor="{{ product.vendor | escape }}"
                    data-variant-id="{{ product.selected_or_first_available_variant.id }}"
                    onclick="toggleWishlist(event, '{{ product.id }}')">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                <path d="M19 14c1.49-1.46 3-3.21 3-5.5A5.5 5.5 0 0 0 16.5 3c-1.76 0-3 .5-4.5 2-1.5-1.5-2.74-2-4.5-2A5.5 5.5 0 0 0 2 8.5c0 2.3 1.5 4.05 3 5.5l7 7Z"/>
              </svg>
            </button>
            
            <!-- Badges -->
            {%- if product.compare_at_price > product.price -%}
              <div class="product-badge-sale-new">
                <span class="badge-text">SALE</span>
              </div>
            {%- else -%}
              <div class="product-badge-new">
                <span class="badge-text">NEW</span>
              </div>
            {%- endif -%}
          </div>
          
          <div class="product-card-body">
            <div class="text-wrapper">
              <div class="product-brand">{{ product.vendor }}</div>
              <div class="product-model">{{ product.title }}</div>
            </div>
            <div class="product-price-row">
              {%- if product.compare_at_price > product.price -%}
                <span class="product-price-compare">{{ product.compare_at_price | money }}</span>
                <span class="product-price sale-price">{{ product.price | money }}</span>
              {%- else -%}
                <span class="product-price">{{ product.price | money }}</span>
              {%- endif -%}
            </div>
          </div>
        </a>
      {%- endfor -%}
    {%- else -%}
    {%- comment %} Dummy placeholder products when no collection is set {%- endcomment %}
      {%- assign dummy_products = "GCC Diana small tote bag,GCC Jackie 1961 Small Bag Red,DR Lady Micro Bag Black Cannage Lambskin,DR Lady Micro Bag Beige Cannage Lambskin,BVG Mini Andiamo Brown" | split: "," -%}
      {%- assign dummy_brands   = "GCC,GCC,DR,DR,BVG" | split: "," -%}
      {%- assign dummy_images = "https://images.unsplash.com/photo-1584917865442-de89df76afd3?q=80&w=800&auto=format&fit=crop,https://images.unsplash.com/photo-1590874103328-eac38a683ce7?q=80&w=600&auto=format&fit=crop,https://images.unsplash.com/photo-1594223274512-ad4803739b7c?q=80&w=600&auto=format&fit=crop,https://images.unsplash.com/photo-1591561954557-26941169b49e?q=80&w=600&auto=format&fit=crop,https://images.unsplash.com/photo-1548036328-c9fa89d128fa?q=80&w=600&auto=format&fit=crop" | split: "," -%}
      {%- assign dummy_has_sale = "true,false,true,false,true" | split: "," -%}

      {%- comment %}
        PRICING: Currently QAR only.
        To add another currency later, simply add data-price-usd / data-compare-usd attributes
        (and the corresponding compare attrs for sale items) — no other code changes needed.
        Example: data-price-usd="$ 521" data-compare-usd="$ 685"
      {%- endcomment %}
      {%- assign dummy_prices_qar   = "2000,1800,1900,1900,2300" | split: "," -%}
      {%- assign dummy_compare_qar  = "2500,,2400,,2800" | split: "," -%}

      {%- assign dummy_prices_usd   = "549,495,522,522,632" | split: "," -%}
      {%- assign dummy_compare_usd  = "687,,659,,769" | split: "," -%}
      {%- assign dummy_prices_eur   = "506,456,481,481,582" | split: "," -%}
      {%- assign dummy_compare_eur  = "633,,608,,709" | split: "," -%}
      {%- assign dummy_prices_aed   = "2006,1805,1906,1906,2307" | split: "," -%}
      {%- assign dummy_compare_aed  = "2508,,2407,,2808" | split: "," -%}

      {%- for i in (0..4) -%}
        {%- assign has_sale = dummy_has_sale[i] -%}
        <a href="/collections/all" class="product-card" aria-label="{{ dummy_products[i] }}">
          <div class="product-card-img">
            <img src="{{ dummy_images[i] }}" alt="{{ dummy_products[i] }}" loading="lazy">

            <!-- Wishlist Button -->
            <button type="button" class="product-wishlist-btn" aria-label="Add to wishlist"
                    data-id="dummy-{{ i }}"
                    data-title="{{ dummy_products[i] | escape }}"
                    data-image="{{ dummy_images[i] }}"
                    data-price="{{ dummy_prices_qar[i] | times: 100 }}"
                    data-url="/collections/all"
                    data-vendor="{{ dummy_brands[i] | escape }}"
                    data-variant-id="dummy-{{ i }}"
                    onclick="toggleWishlist(event, 'dummy-{{ i }}')">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                <path d="M19 14c1.49-1.46 3-3.21 3-5.5A5.5 5.5 0 0 0 16.5 3c-1.76 0-3 .5-4.5 2-1.5-1.5-2.74-2-4.5-2A5.5 5.5 0 0 0 2 8.5c0 2.3 1.5 4.05 3 5.5l7 7Z"/>
              </svg>
            </button>
            
            <!-- Badges -->
            {%- if has_sale == "true" -%}
              <div class="product-badge-sale-new"><span class="badge-text">SALE</span></div>
            {%- else -%}
              <div class="product-badge-new"><span class="badge-text">NEW</span></div>
            {%- endif -%}
          </div>
          
          <div class="product-card-body">
            <div class="text-wrapper">
              <div class="product-brand">{{ dummy_brands[i] }}</div>
              <div class="product-model">{{ dummy_products[i] }}</div>
            </div>
            <!--
              Multi-currency ready: data-price-usd / data-price-eur / data-price-aed
              are populated and processed automatically by window.applyStoreCurrency().
            -->
            <div class="product-price-row"
              data-price-qar="QAR {{ dummy_prices_qar[i] }}"
              data-price-usd="$ {{ dummy_prices_usd[i] }}"
              data-price-eur="€ {{ dummy_prices_eur[i] }}"
              data-price-aed="AED {{ dummy_prices_aed[i] }}"
              {%- if has_sale == "true" %}
              data-compare-qar="QAR {{ dummy_compare_qar[i] }}"
              data-compare-usd="$ {{ dummy_compare_usd[i] }}"
              data-compare-eur="€ {{ dummy_compare_eur[i] }}"
              data-compare-aed="AED {{ dummy_compare_aed[i] }}"
              {%- endif %}>
              {%- if has_sale == "true" -%}
                <span class="product-price-compare">QAR {{ dummy_compare_qar[i] }}</span>
                <span class="product-price sale-price">QAR {{ dummy_prices_qar[i] }}</span>
              {%- else -%}
                <span class="product-price">QAR {{ dummy_prices_qar[i] }}</span>
              {%- endif -%}
            </div>
          </div>
        </a>
      {%- endfor -%}
    {%- endif -%}
  </div>
</div>

<script>
  /* =================================================================
     GLOBAL: applyStoreCurrency(currency)
     ─────────────────────────────────────────────────────────────────
     • Called by the header currency selector.
     • Prices are PRE-SET per currency (NO conversion math).
     • FALLBACK: if no price exists for the selected currency, the
       QAR price is shown (so the store always looks correct even
       before multi-currency prices are entered).
     ─────────────────────────────────────────────────────────────────
     HOW TO ADD A NEW CURRENCY (e.g. USD):
       On each product card's .product-price-row add:
         data-price-usd="$ 521"
         data-compare-usd="$ 685"   ← only for sale items
       That's it — no other code changes needed.
     ================================================================= */
  // Using global window.applyStoreCurrency defined in header.liquid to avoid conflicts.




  document.addEventListener('DOMContentLoaded', function() {
    /* Sync wishlist heart states */
    function syncWishlistUI() {
      var wishlist = JSON.parse(localStorage.getItem('qtr_wishlist') || '[]');
      document.querySelectorAll('.product-wishlist-btn').forEach(function(btn) {
        var match = (btn.getAttribute('onclick') || '').match(/'([^']+)'/);
        if (match && match[1]) {
          var heartSvg = btn.querySelector('svg');
          var inList   = wishlist.indexOf(match[1]) > -1;
          heartSvg.setAttribute('fill',   inList ? '#e74c3c' : 'none');
          heartSvg.setAttribute('stroke', inList ? '#e74c3c' : 'currentColor');
          btn.classList.toggle('active', inList);
        }
      });
    }
    syncWishlistUI();
    window.addEventListener('wishlistChanged', syncWishlistUI);

    /* Restore saved currency — falls back to QAR if nothing saved */
    var savedCurrency = localStorage.getItem('qtr_currency') || 'QAR';
    if (typeof window.applyStoreCurrency === 'function') {
      window.applyStoreCurrency(savedCurrency);
    }
  });
</script>
{% schema %}
{
  "name": "Product Showcase",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Section Heading",
      "default": "Featured"
    },
    {
      "type": "collection",
      "id": "collection_handle",
      "label": "Collection"
    },
    {
      "type": "url",
      "id": "view_all_url",
      "label": "View All Link"
    },
    {
      "type": "range",
      "id": "max_products",
      "label": "Max Products",
      "min": 2,
      "max": 12,
      "step": 1,
      "default": 6
    }
  ],
  "presets": [
    { "name": "Product Showcase" }
  ]
}
{% endschema %}
