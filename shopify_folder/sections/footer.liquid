<style>
.site-footer {
    background: var(--color-white) !important;
    max-width: 1360px;
    width: 90%;
    margin: 40px auto 40px auto;
    border: 1px solid rgba(0, 0, 0, 0.16);
    border-radius: 16px;
    overflow: hidden;
    box-shadow: 0 4px 20px rgba(0, 0, 0, 0.04);
    box-sizing: border-box;
    display: block !important;
}

/* 1. Features Bar */
.site-footer-features-bar {
    background: var(--color-white);
    border-top: none;
    border-bottom: 1px solid rgba(0, 0, 0, 0.15);
    width: 100%;
    padding: 24px 40px;
    box-sizing: border-box;
}

.site-footer-features-inner {
    max-width: 1360px;
    margin: 0 auto;
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 30px;
}

.site-footer-feature-card {
    display: flex;
    align-items: center;
    gap: 16px;
    padding: 12px 18px;
    background: var(--color-bg, #faf9f5);
    border-radius: 12px;
    border: 1px solid rgba(0, 0, 0, 0.04);
}

.site-footer-feature-icon-wrapper {
    width: 44px;
    height: 44px;
    border-radius: 50%;
    background: var(--color-white);
    border: 1px solid rgba(45, 31, 31, 0.12);
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
    color: var(--color-primary);
}

.site-footer-feature-icon-wrapper svg {
    width: 20px;
    height: 20px;
}

.site-footer-feature-icon-wrapper svg path {
    stroke: var(--color-primary) !important;
}

.site-footer-feature-text {
    font-family: var(--font-body);
    font-weight: 600;
    font-size: 14px;
    color: var(--color-primary);
    line-height: 1.3;
}

/* 2. Main Footer Layout */
.site-footer-main {
    max-width: 1360px;
    margin: 0 auto;
    padding: 60px 40px;
    display: grid;
    grid-template-columns: 32% 1fr;
    gap: 60px;
    box-sizing: border-box;
}

/* Left Brand/Subscribe Area */
.site-footer-brand-col {
    display: flex;
    flex-direction: column;
    gap: 28px;
}

.footer-brand-title {
    font-family: var(--font-serif);
    font-size: 32px;
    font-weight: 400;
    color: var(--color-primary);
    margin: 0;
    letter-spacing: 0.5px;
}

.footer-logo {
    max-height: 60px;
    width: auto;
    object-fit: contain;
}

.footer-brand-tagline {
    font-family: var(--font-body);
    font-weight: 400;
    font-size: 14px;
    line-height: 1.5;
    color: #444444;
    margin: 0;
}

.footer-subscribe-box {
    display: flex;
    flex-direction: column;
    gap: 12px;
    max-width: 360px;
}

.footer-subscribe-box form {
    display: flex;
    align-items: center;
    gap: 6px;
    width: 100%;
}

.footer-subscribe-input-wrap {
    flex: 1;
    height: 46px;
    padding: 0 16px;
    border-radius: 24px;
    border: 1px solid rgba(45, 31, 31, 0.25);
    background: transparent;
    display: flex;
    align-items: center;
    box-sizing: border-box;
    transition: border-color 0.2s ease;
}

.footer-subscribe-input-wrap:focus-within {
    border-color: var(--color-primary);
}

.footer-subscribe-input-wrap input[type="email"] {
    width: 100%;
    border: none;
    outline: none;
    background: transparent;
    font-family: var(--font-body);
    font-size: 13px;
    color: var(--color-primary);
}

.footer-subscribe-input-wrap input[type="email"]::placeholder {
    color: var(--color-primary);
    opacity: 0.5;
}

.footer-subscribe-submit {
    height: 46px;
    padding: 0 22px;
    background: var(--color-primary);
    border: 1px solid var(--color-primary);
    border-radius: 24px;
    font-family: var(--font-body);
    font-weight: 600;
    font-size: 13px;
    color: var(--color-white);
    cursor: pointer;
    white-space: nowrap;
    transition: all 0.2s ease;
}

.footer-subscribe-submit:hover {
    background: var(--color-white);
    color: var(--color-primary);
}

.footer-subscribe-disclaimer {
    font-family: var(--font-body);
    font-size: 11px;
    color: #777777;
    line-height: 1.4;
    margin: 0;
}

.footer-social-section {
    display: flex;
    flex-direction: column;
    gap: 10px;
}

.footer-social-title {
    font-family: var(--font-body);
    font-weight: 600;
    font-size: 12px;
    text-transform: uppercase;
    letter-spacing: 1px;
    color: var(--color-primary);
}

.footer-social-icons-row {
    display: flex;
    align-items: center;
    gap: 10px;
}

.footer-social-icon-link {
    width: 36px;
    height: 36px;
    border-radius: 50%;
    border: 1px solid rgba(45, 31, 31, 0.15);
    display: inline-flex;
    align-items: center;
    justify-content: center;
    color: var(--color-primary);
    transition: all 0.25s cubic-bezier(0.4, 0, 0.2, 1);
    background: transparent;
}

.footer-social-icon-link:hover {
    background: var(--color-primary);
    color: var(--color-white);
    border-color: var(--color-primary);
    transform: translateY(-2px);
}

.footer-social-icon-link svg {
    width: 16px;
    height: 16px;
}

/* Right Links Grid */
.site-footer-links-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(140px, 1fr));
    gap: 40px 30px;
}

.footer-links-col {
    display: flex;
    flex-direction: column;
    gap: 16px;
}

.footer-links-col h4 {
    font-family: var(--font-body);
    font-size: 15px;
    font-weight: 700;
    color: var(--color-primary);
    margin: 0;
    text-transform: uppercase;
    letter-spacing: 0.8px;
}

.footer-links-col ul {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 10px;
}

.footer-links-col a {
    font-family: var(--font-body);
    font-weight: 400;
    font-size: 13.5px;
    color: #333333;
    text-decoration: none;
    transition: all 0.2s ease;
    display: inline-block;
    position: relative;
    padding-bottom: 2px;
}

.footer-links-col a::after {
    content: '';
    position: absolute;
    bottom: 0;
    left: 0;
    width: 0;
    height: 1px;
    background-color: var(--color-primary);
    transition: width 0.2s ease;
}

.footer-links-col a:hover {
    color: var(--color-primary);
}

.footer-links-col a:hover::after {
    width: 100%;
}

/* 3. Bottom Legal / Copyright Bar */
.site-footer .site-footer-bottom {
    background-color: var(--color-primary) !important;
    padding: 24px 40px;
    width: 100%;
    box-sizing: border-box;
}

.site-footer-bottom-inner {
    max-width: 1360px;
    margin: 0 auto;
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: 20px;
}

.site-footer-copyright-text {
    font-family: Georgia, 'Canela Text', serif;
    font-size: 13px;
    line-height: 1.6;
    color: rgba(255, 255, 255, 0.65);
    margin: 0;
    letter-spacing: 0.2px;
}

.site-footer-copyright-text span {
    color: rgba(255, 255, 255, 0.9);
}

.site-footer-bottom-payments {
    display: flex;
    align-items: center;
    gap: 10px;
}

.site-footer-bottom-payments svg {
    width: 38px;
    height: 24px;
}

/* 4. Responsive Styling (Mobile & Tablet) */
@media (max-width: 768px) {
    .site-footer {
        max-width: 750px;
        margin: 30px auto 30px auto;
    }

    .site-footer-features-bar {
        padding: 20px 16px;
        background: var(--color-white);
        border-top: none;
        border-bottom: 1px solid rgba(0, 0, 0, 0.1);
    }

    .site-footer-features-inner {
        grid-template-columns: repeat(2, 1fr);
        gap: 16px 12px;
    }

    .site-footer-feature-card {
        flex-direction: column;
        align-items: center;
        text-align: center;
        gap: 8px;
        padding: 10px 4px;
    }

    .site-footer-feature-icon-wrapper {
        width: 38px;
        height: 38px;
        background: var(--color-white);
    }

    .site-footer-feature-icon-wrapper svg {
        width: 18px;
        height: 18px;
    }

    .site-footer-feature-text {
        font-size: 12px;
    }

    .site-footer-main {
        background: var(--color-white);
        padding: 30px 20px;
        grid-template-columns: 1fr;
        gap: 40px;
    }

    .site-footer-brand-col {
        align-items: center;
        text-align: center;
        gap: 20px;
    }

    .footer-brand-title {
        font-size: 28px;
    }

    .footer-subscribe-box {
        max-width: 100%;
        width: 100%;
    }

    .site-footer-links-grid {
        grid-template-columns: repeat(2, 1fr);
        gap: 30px 16px;
    }

    .footer-links-col {
        align-items: center;
        text-align: center;
    }

    .footer-links-col h4 {
        font-size: 13.5px;
        margin-bottom: 4px;
    }

    .footer-links-col ul {
        align-items: center;
    }

    .footer-links-col a {
        font-size: 12.5px;
    }

    .site-footer-bottom {
        padding: 24px 20px;
    }

    .site-footer-bottom-inner {
        flex-direction: column;
        text-align: center;
        gap: 16px;
    }

    .site-footer-copyright-text {
        font-size: 12px;
    }

    .site-footer-bottom-payments {
        justify-content: center;
    }
}

@media (max-width: 480px) {
    .site-footer-features-inner {
        grid-template-columns: 1fr;
        gap: 10px;
    }

    .site-footer-feature-card {
        flex-direction: row;
        text-align: left;
        align-items: center;
        padding: 12px 16px;
    }

    .site-footer-links-grid {
        grid-template-columns: 1fr;
        gap: 24px;
    }
}
</style>

