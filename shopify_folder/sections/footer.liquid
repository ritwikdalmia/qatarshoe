                    {%- if section.settings.snapchat_url != blank -%}
                        <a href="{{ section.settings.snapchat_url }}" target="_blank" rel="noopener" class="footer-social-icon-link" aria-label="Snapchat">
                            <svg viewBox="0 0 512 512" fill="currentColor"><path d="M411.3 358.4c-6.8-6.1-11.8-13.8-15.3-22.1-4.8-11.3-7.2-23.4-7.2-35.6 0-3.3.4-6.6 1.1-9.9 2-8.9 5.6-17.5 10.7-25.2 7.7-11.7 13.9-24.9 18.5-38.9 4.3-13.3 5.4-27.4 3.2-41.2-3-19-12.7-36.4-27.1-49-18.7-16.3-43.1-26-68.5-27.1-8.5-.4-17.1-1.5-25.5-3.3-12.7-2.7-25.6-4.1-38.5-4.1s-25.8 1.4-38.5 4.1c-8.4 1.8-16.9 2.9-25.5 3.3-25.4 1.1-49.8 10.8-68.5 27.1-14.4 12.6-24.1 30-27.1 49-2.2 13.8-1.1 27.9 3.2 41.2 4.6 14 10.8 27.2 18.5 38.9 5.1 7.7 8.7 16.3 10.7 25.2.7 3.3 1.1 6.6 1.1 9.9 0 12.2-2.4 24.3-7.2 35.6-3.5 8.3-8.5 16-15.3 22.1-12.6 11.3-28.7 17.6-45.3 17.6-3.8 0-7.6-.3-11.3-1-12.8-2.3-23.1 7.5-23.1 19.5 0 9.1 6 17 14.8 19.2 11.1 2.8 22.5 4.2 34 4.1 7.4.1 14.8-.4 22.2-1.5 10.4-1.6 20.8-1.9 31.3-.9 11.5 1.1 22.8 3.8 33.9 8.1 26.6 10.2 55 15.6 83.6 15.7 28.6-.1 57-5.5 83.6-15.7 11.1-4.3 22.4-7 33.9-8.1 10.5-1 20.9-.7 31.3.9 7.4 1.1 14.8 1.6 22.2 1.5 11.5.1 22.9-1.3 34-4.1 8.8-2.2 14.8-10.1 14.8-19.2 0-12-10.3-21.8-23.1-19.5-3.7.7-7.5 1-11.3 1-16.6 0-32.7-6.3-45.3-17.6z"/></svg>
                        </a>
                    {%- endif -%}
                </div>
            </div>
        </div>

        <!-- Links columns grid -->
        <div class="site-footer-links-grid">
            {%- assign footer_blocks = section.blocks | where: "type", "footer_column" -%}
            {%- if footer_blocks.size > 0 -%}
                {%- for block in footer_blocks -%}
                    {%- assign menu = block.settings.menu -%}
                    {%- if menu != blank and linklists[menu] != blank -%}
                        {%- assign has_submenus = false -%}
                        {%- for link in linklists[menu].links -%}
                            {%- if link.links.size > 0 -%}
                                {%- assign has_submenus = true -%}
                                {%- break -%}
                            {%- endif -%}
                        {%- endfor -%}

                        {%- if has_submenus -%}
                            {%- for link in linklists[menu].links -%}
                                <div class="footer-links-col" {{ block.shopify_attributes }}>
                                    <h4>{{ link.title }}</h4>
                                    <ul>
                                        {%- for child_link in link.links -%}
                                            <li><a href="{{ child_link.url }}">{{ child_link.title }}</a></li>
                                        {%- endfor -%}
                                    </ul>
                                </div>
                            {%- endfor -%}
                        {%- else -%}
                            <div class="footer-links-col" {{ block.shopify_attributes }}>
                                <h4>{{ block.settings.title | default: linklists[menu].title }}</h4>
                                <ul>
                                    {%- for link in linklists[menu].links -%}
                                        <li><a href="{{ link.url }}">{{ link.title }}</a></li>
                                    {%- endfor -%}
                                </ul>
                            </div>
                        {%- endif -%}
                    {%- endif -%}
                {%- endfor -%}
            {%- else -%}
                <div class="footer-links-col">
                    <h4>Customer Care</h4>
                    <ul>
                        <li><a href="/pages/contact">Contact Us</a></li>
                        <li><a href="/pages/customer-care">Customer Care</a></li>
                        <li><a href="/pages/faqs">FAQs</a></li>
                    </ul>
                </div>

                <div class="footer-links-col">
                    <h4>Shipping & Returns</h4>
                    <ul>
                        <li><a href="/pages/shipping-delivery">Shipping & Delivery</a></li>
                        <li><a href="/pages/returns-and-refunds">Returns & Refunds</a></li>
                    </ul>
                </div>

                <div class="footer-links-col">
                    <h4>Payments</h4>
                    <ul>
                        <li><a href="/pages/payments-pricing">Payments & Pricing</a></li>
                    </ul>
                </div>

                <div class="footer-links-col">
                    <h4>Policies</h4>
                    <ul>
                        <li><a href="/policies/privacy-policy">Privacy Policy</a></li>
                        <li><a href="/policies/terms-of-service">Terms Of Service</a></li>
                    </ul>
                </div>

                <div class="footer-links-col">
                    <h4>Services</h4>
                    <ul>
                        <li><a href="{{ routes.collections_url }}/qatar-collection">Qatar</a></li>
                        <li><a href="/pages/pre-orders">Personal Shopping</a></li>
                    </ul>
                </div>

                <div class="footer-links-col">
                    <h4>About</h4>
                    <ul>
                        <li><a href="/pages/about-us">About Us</a></li>
                        <li><a href="/pages/sitemap">Sitemap</a></li>
                    </ul>
                </div>
            {%- endif -%}
        </div>
    </div>

    <!-- 3. Bottom Legal / Copyright Bar -->
    <div class="site-footer-bottom">
        <div class="site-footer-bottom-inner">
            <p class="site-footer-copyright-text">
                {{ section.settings.legal_text | default: "AmiriVibes is not affiliated with the brand we sell. Authentication is performed independently." }}
                <span class="site-footer-copyright-year">&copy; {{ 'now' | date: '%Y' }}</span>
                <span>{{ shop.name }}</span>
                &ndash; All Rights Reserved.
            </p>

            <div class="site-footer-bottom-payments">
                <svg viewBox="0 0 38 24" fill="none" xmlns="http://www.w3.org/2000/svg">
                    <rect width="38" height="24" rx="3" fill="var(--color-white)" fill-opacity="0.12"/>
                    <path d="M19 5L8 10V11H30V10L19 5Z" fill="var(--color-white)"/>
                    <rect x="10" y="12" width="3" height="6" fill="var(--color-white)"/>
                    <rect x="14.5" y="12" width="3" height="6" fill="var(--color-white)"/>
                    <rect x="20.5" y="12" width="3" height="6" fill="var(--color-white)"/>
                    <rect x="25" y="12" width="3" height="6" fill="var(--color-white)"/>
                    <rect x="8" y="18" width="22" height="2" fill="var(--color-white)"/>
                </svg>
                
                <svg viewBox="0 0 38 24" fill="none" xmlns="http://www.w3.org/2000/svg">
                    <rect width="38" height="24" rx="3" fill="var(--color-white)" fill-opacity="0.12"/>
                    <rect x="6" y="7" width="16" height="10" rx="1" fill="var(--color-white)"/>
                    <circle cx="14" cy="12" r="3" fill="var(--color-primary, #2d1f1f)"/>
                    <path d="M13 11.5C13 11.2 13.2 11 13.5 11H14.5C14.8 11 15 11.2 15 11.5V12.5C15 12.8 14.8 13 14.5 13H13.5C13.2 13 13 12.8 13 12.5V11.5Z" fill="var(--color-white)"/>
                    <rect x="24" y="9" width="8" height="10" rx="1" fill="var(--color-white)"/>
                    <rect x="25" y="15" width="6" height="3" rx="0.5" fill="var(--color-primary, #2d1f1f)"/>
                    <circle cx="28" cy="12" r="1.5" fill="var(--color-primary, #2d1f1f)"/>
                </svg>
            </div>
        </div>
    </div>

</footer>

{% schema %}
{
  "name": "Footer",
  "settings": [
    {
      "type": "image_picker",
      "id": "logo_image",
      "label": "Footer Logo"
    },
    {
      "type": "textarea",
      "id": "subscribe_heading",
      "label": "Subscribe Heading",
      "default": "Subscribe Now<br>And Don't Miss Out On New Products!"
    },
    {
      "type": "text",
      "id": "tiktok_url",
      "label": "TikTok URL",
      "default": "https://www.tiktok.com/@amirivibes"
    },
    {
      "type": "text",
      "id": "instagram_url",
      "label": "Instagram URL",
      "default": "https://www.instagram.com/@amirivibes"
    },
    {
      "type": "text",
      "id": "pinterest_url",
      "label": "Pinterest URL",
      "default": "https://www.pinterest.com/amirivibes/"
    },
    {
      "type": "text",
      "id": "snapchat_url",
      "label": "Snapchat URL",
      "default": "http://snapchat.com/@amirivibes"
    },
    {
      "type": "textarea",
      "id": "legal_text",
      "label": "Legal Disclaimer Text",
      "default": "AmiriVibes is not affiliated with the brand we sell. Authentication is performed independently."
    }
  ],
  "blocks": [
    {
      "type": "footer_column",
      "name": "Footer Column",
      "settings": [
        {
          "type": "text",
          "id": "title",
          "label": "Column Title",
          "default": "Customer Care"
        },
        {
          "type": "link_list",
          "id": "menu",
          "label": "Column Menu"
        }
      ]
    }
  ]
}
{% endschema %}
