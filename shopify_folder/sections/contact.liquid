{%- style -%}
  body.contact-page-body {
      background: #F5F5F5;
  }

  .contact-page-wrap {
      padding: 96px 150px 96px;
      background: #F5F5F5;
  }

  .contact-page-header {
      display: flex;
      flex-direction: column;
      gap: 20px;
      padding-bottom: 56px;
  }

  .contact-page-header h1 {
      font-family: 'Inter', sans-serif;
      font-size: 64px;
      font-weight: 400;
      line-height: 100%;
      letter-spacing: -2%;
      color: #2D1F1F;
      margin: 0;
      text-transform: none;
  }

  .contact-page-header p {
      font-family: 'Inter', sans-serif;
      font-size: 16px;
      font-weight: 400;
      line-height: 150%;
      color: rgba(45, 31, 31, 0.7);
      margin: 0;
  }

  .contact-page-card {
      background: #fff;
  }

  .contact-mobile-br {
      display: none;
  }

  .contact-info-section {
      padding: 0;
      background: transparent;
  }

  .contact-cards {
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      border-bottom: 1px solid #E5E5E5;
  }

  .contact-card {
      display: flex;
      flex-direction: column;
      justify-content: space-between;
      padding: 42px;
      gap: 104px;
      background: #fff;
      border-right: 1px solid #E5E5E5;
  }

  .contact-card:last-child {
      border-right: none;
  }

  .contact-card-text {
      display: flex;
      flex-direction: column;
      gap: 16px;
  }

  .contact-card-title {
      font-family: 'Inter', sans-serif;
      font-size: 20px;
      font-weight: 600;
      line-height: 100%;
      letter-spacing: -2%;
      color: #2D1F1F;
      margin: 0;
  }

  .contact-card-desc {
      font-family: 'Inter', sans-serif;
      font-size: 16px;
      font-weight: 400;
      line-height: 150%;
      letter-spacing: 0;
      color: rgba(45, 31, 31, 0.7);
      margin: 0;
  }

  .contact-card-link {
      display: inline-flex;
      align-items: center;
      justify-content: center;
      gap: 8px;
      width: 100%;
      height: 48px;
      padding: 0 18px;
      background: #fff;
      color: #2D1F1F;
      border: 1px solid #2D1F1F;
      border-radius: 900px;
      font-family: 'Inter', sans-serif;
      font-size: 16px;
      font-weight: 500;
      line-height: 100%;
      letter-spacing: 0;
      text-transform: none;
      text-decoration: none;
      box-sizing: border-box;
      transition: background 0.2s ease, color 0.2s ease;
  }

  .contact-card-link:hover {
      background: #2D1F1F;
      color: #fff;
  }

  .contact-card-link-icon {
      flex-shrink: 0;
      width: 20px;
      height: 20px;
      display: block;
  }

  .contact-form-section {
      background: #fff;
      padding: 42px 0;
  }

  .contact-form-inner {
      max-width: 1620px;
      margin: 0 auto;
      padding: 0 150px;
      display: flex;
      align-items: flex-start;
      gap: 150px;
  }

  .contact-form-intro {
      flex: 0 0 488px;
      display: flex;
      flex-direction: column;
      gap: 16px;
      min-width: 0;
  }

  .contact-form-intro-text {
      display: flex;
      flex-direction: column;
      gap: 16px;
  }

  .contact-form-intro h2 {
      font-family: 'Inter', sans-serif;
      font-size: 20.5px;
      font-weight: 600;
      line-height: 100%;
      letter-spacing: -2%;
      margin: 0;
      color: #2D1F1F;
      text-transform: none;
  }

  .contact-form-intro-text p {
      font-family: 'Inter', sans-serif;
      font-size: 15.5px;
      font-weight: 400;
      line-height: 150%;
      color: rgba(45, 31, 31, 0.7);
      margin: 0;
  }

  .contact-form-wrapper {
      flex: 1 1 0;
      min-width: 0;
      display: flex;
      flex-direction: column;
      gap: 12px;
  }

  .contact-form-wrapper form {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 12px;
  }

  .contact-form-wrapper form p {
      display: contents;
      margin: 0;
  }

  .contact-form-wrapper form br {
      display: none;
  }

  .contact-field-group {
      display: flex;
      flex-direction: column;
      gap: 6px;
      align-items: flex-start;
  }

  .contact-field-group.full-width {
      grid-column: 1 / -1;
  }

  .contact-field-group label {
      font-family: 'Inter', sans-serif;
      font-size: 14px;
      font-weight: 500;
      color: #2D1F1F;
      margin: 0;
  }

  .contact-field-group label .required {
      color: #FF0000;
      margin-left: 2px;
  }

  .contact-form-wrapper input[type="text"],
  .contact-form-wrapper input[type="email"],
  .contact-form-wrapper input[type="tel"],
  .contact-form-wrapper textarea {
      width: 100%;
      background: #fff;
      border: 1px solid rgba(45, 31, 31, 0.2);
      border-radius: 6px;
      color: #2D1F1F;
      font-family: 'Inter', sans-serif;
      font-size: 14px;
      line-height: 100%;
      box-sizing: border-box;
      outline: none;
      transition: border-color 0.2s ease;
  }

  .contact-form-wrapper input[type="text"],
  .contact-form-wrapper input[type="email"],
  .contact-form-wrapper input[type="tel"] {
      height: 44px;
      padding: 0 12px;
  }

  .contact-form-wrapper textarea {
      height: 108px;
      padding: 12px;
      resize: vertical;
      line-height: 1.5;
  }

  .contact-form-wrapper input[type="text"]:focus,
  .contact-form-wrapper input[type="email"]:focus,
  .contact-form-wrapper input[type="tel"]:focus,
  .contact-form-wrapper textarea:focus {
      border-color: #2D1F1F;
  }

  .contact-form-wrapper input::placeholder,
  .contact-form-wrapper textarea::placeholder {
      color: rgba(0, 0, 0, 0.5);
      opacity: 1;
  }

  .contact-bottom-row {
      display: flex;
      align-items: stretch;
      justify-content: stretch;
  }

  .contact-submit-custom {
      flex: 1;
      width: 100%;
      height: 48px;
      display: inline-flex;
      align-items: center;
      justify-content: center;
      gap: 8px;
      padding: 0 18px;
      background: #fff;
      color: #2D1F1F;
      border: 1px solid #2D1F1F;
      border-radius: 900px;
      font-family: 'Inter', sans-serif;
      cursor: pointer;
      transition: background 0.2s ease, color 0.2s ease;
  }

  .contact-submit-custom span {
      font-size: 16px;
      font-weight: 600;
      line-height: 24px;
      letter-spacing: 0;
      text-transform: none;
  }

  .contact-submit-icon {
      width: 20px;
      height: 20px;
      flex-shrink: 0;
      display: block;
  }

  .contact-submit-custom:hover {
      background: #2D1F1F;
      color: #fff;
  }

  .wpcf7-response-output {
      grid-column: 1 / -1;
      margin: 12px 0 0;
      padding: 14px 18px;
      font-size: 14px;
      border-radius: 4px;
      color: #2D1F1F;
      border: 1px solid rgba(45, 31, 31, 0.2);
  }

  .wpcf7-response-output.sent {
      border-color: #28a745;
      color: #1e7a35;
      background-color: rgba(40, 167, 69, 0.05);
  }

  .wpcf7-response-output.invalid {
      border-color: #d93b3d;
      color: #b1282a;
      background-color: rgba(217, 59, 61, 0.05);
  }

  body.contact-page-body .contact-form-section {
      padding: 0;
  }

  body.contact-page-body .contact-form-inner {
      padding: 42px;
      margin: 0;
      max-width: none;
      gap: 290px;
  }

  @media (max-width: 1023px) {
      .contact-page-wrap {
          padding: 48px 40px 64px;
      }
      body.contact-page-body .contact-form-inner {
          gap: 100px;
      }
  }

  @media (max-width: 767px) {
      .contact-page-wrap {
          padding: 48px 24px;
      }

      .contact-page-header {
          padding-bottom: 32px;
          gap: 12px;
      }

      .contact-page-header h1 {
          font-size: 32px;
      }

      .contact-mobile-br {
          display: inline;
      }

      .contact-cards {
          grid-template-columns: 1fr;
      }

      .contact-card {
          border-right: none;
          border-bottom: 1px solid #E5E5E5;
          padding: 20px;
          gap: 60px;
      }

      .contact-card:last-child {
          border-bottom: none;
      }

      body.contact-page-body .contact-form-inner {
          padding: 32px 24px 48px;
          gap: 32px;
          flex-direction: column;
      }

      body.contact-page-body .contact-form-intro {
          flex: none;
          width: 100%;
      }

      body.contact-page-body .contact-form-intro h2 {
          font-size: 20px;
      }

      .contact-card-desc {
          font-size: 13px;
          line-height: 20px;
      }

      .contact-form-section {
          padding: 32px 0;
          padding-bottom: 0px;
          margin-bottom: -8px;
      }

      .contact-form-intro h2 {
          font-size: 32px;
          line-height: 100%;
      }

      .contact-form-intro-text p {
          font-size: 13.5px;
          line-height: 150%;
      }

      .contact-form-wrapper {
          flex: none;
          width: 100%;
      }

      .contact-form-wrapper form {
          grid-template-columns: 1fr;
          gap: 8px;
      }

      .contact-form-wrapper form span.full-width {
          grid-column: 1;
      }

      .contact-form-wrapper textarea {
          height: 132px;
      }

      .contact-submit-custom {
          width: 100%;
      }

      .contact-card-link {
          font-size: 14px;
      }
      .contact-page-header p{
          font-size: 14px;
      }
  }
{%- endstyle -%}

<script>
  // Add body class for contact page
  document.body.classList.add('contact-page-body');
</script>

<main class="contact-page-wrap">
    <!-- Page header -->
    <header class="contact-page-header">
        <h1>{{ section.settings.heading | default: page.title }}</h1>
        <p>{{ section.settings.subheading | default: "We're here to help. Choose the option that fits you best." }}</p>
    </header>

    <!-- White card container -->
    <div class="contact-page-card">
        <!-- Section 1 — Contact Info Cards -->
        <section class="contact-info-section">
            <div class="contact-cards">
                <!-- Card 1: Qatar -->
                <div class="contact-card">
                    <div class="contact-card-text">
                        <h3 class="contact-card-title">{{ section.settings.card_1_title | default: "Qatar" }}</h3>
                        <p class="contact-card-desc">{{ section.settings.card_1_desc | default: "For all orders within Qatar" }}</p>
                    </div>
                    <a class="contact-card-link" href="https://wa.me/{{ section.settings.card_1_phone_raw | default: "97455289397" }}" target="_blank" rel="noopener">
                        <svg class="contact-card-link-icon" width="20" height="20" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/></svg>
                        <span>{{ section.settings.card_1_phone | default: "+974 5528 9397" }}</span>
                    </a>
                </div>

                <!-- Card 2: International -->
                <div class="contact-card">
                    <div class="contact-card-text">
                        <h3 class="contact-card-title">{{ section.settings.card_2_title | default: "International" }}</h3>
                        <p class="contact-card-desc">{{ section.settings.card_2_desc | default: "For all orders outside Qatar" }}</p>
                    </div>
                    <a class="contact-card-link" href="https://wa.me/{{ section.settings.card_2_phone_raw | default: "97433903967" }}" target="_blank" rel="noopener">
                        <svg class="contact-card-link-icon" width="20" height="20" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/></svg>
                        <span>{{ section.settings.card_2_phone | default: "+974 3390 3967" }}</span>
                    </a>
                </div>

                <!-- Card 3: Email Us -->
                <div class="contact-card">
                    <div class="contact-card-text">
                        <h3 class="contact-card-title">{{ section.settings.card_3_title | default: "Email Us" }}</h3>
                        <p class="contact-card-desc">{{ section.settings.card_3_desc | default: "General inquiries, documentation & follow-ups" }}</p>
                    </div>
                    <a class="contact-card-link" href="mailto:{{ section.settings.card_3_email | default: "info@qtrshoe.com" }}">
                        <svg class="contact-card-link-icon" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><rect x="2" y="4" width="20" height="16" rx="2"/><path d="M22 4l-10 8L2 4"/></svg>
                        <span>{{ section.settings.card_3_email | default: "info@qtrshoe.com" }}</span>
                    </a>
                </div>
            </div>
        </section>

        <!-- Section 2 — Send Us A Message form -->
        <section class="contact-form-section">
            <div class="contact-form-inner">
                <div class="contact-form-intro">
                    <div class="contact-form-intro-text">
                        <h2>{{ section.settings.form_heading | default: "Send Us A Message" }}</h2>
                        <p>{{ section.settings.form_subheading | default: "Fill out the form and we'll get back to you as quickly as possible." }}</p>
                    </div>
                </div>

                <div class="contact-form-wrapper">
                    {%- form 'contact', id: 'ContactForm' -%}
                        {%- if form.posted_successfully? -%}
                            <div class="wpcf7-response-output sent" role="status">
                                Thanks for contacting us! We'll get back to you as soon as possible.
                            </div>
                        {%- elsif form.errors -%}
                            <div class="wpcf7-response-output invalid" role="alert">
                                {{ form.errors | default_errors }}
                            </div>
                        {%- endif -%}

                        <p>
                    <div class="contact-field-group">
                        <label for="ContactFormFirstName">First Name <span class="required">*</span></label>
                        <input type="text" id="ContactFormFirstName" name="contact[first_name]" placeholder="First Name" value="{% if form.first_name %}{{ form.first_name }}{% elsif customer %}{{ customer.first_name }}{% endif %}" required aria-required="true" />
                    </div>
                    <div class="contact-field-group">
                        <label for="ContactFormLastName">Last Name <span class="required">*</span></label>
                        <input type="text" id="ContactFormLastName" name="contact[last_name]" placeholder="Last Name" value="{% if form.last_name %}{{ form.last_name }}{% elsif customer %}{{ customer.last_name }}{% endif %}" required aria-required="true" />
                    </div>
                    <div class="contact-field-group">
                        <label for="ContactFormEmail">Email <span class="required">*</span></label>
                        <input type="email" id="ContactFormEmail" name="contact[email]" placeholder="Email" value="{% if form.email %}{{ form.email }}{% elsif customer %}{{ customer.email }}{% endif %}" required aria-required="true" />
                    </div>
                    <div class="contact-field-group">
                        <label for="ContactFormPhone">Phone Number <span class="required">*</span></label>
                        <input type="tel" id="ContactFormPhone" name="contact[phone]" placeholder="Phone Number" value="{% if form.phone %}{{ form.phone }}{% elsif customer %}{{ customer.phone }}{% endif %}" required aria-required="true" pattern="^[34567][0-9]{7}$" title="Please enter a valid 8-digit Qatar phone number (starting with 3, 4, 5, 6, or 7)." />
                    </div>
                    <div class="contact-field-group full-width">
                        <label for="ContactFormMessage">Your Message <span class="required">*</span></label>
                        <textarea cols="40" rows="10" id="ContactFormMessage" name="contact[body]" placeholder="Your Message" required aria-required="true">{% if form.body %}{{ form.body }}{% endif %}</textarea>
                    </div>
                    <input type="hidden" name="contact[customer_type]" value="qatar" id="contact-customer-type" />
                    <input type="submit" class="wpcf7-submit" id="RealContactSubmit" value="Send Message" style="display:none;" />
                </p>
                    {%- endform -%}

                    <div class="contact-bottom-row">
                        <button type="button" class="contact-submit-custom" onclick="document.getElementById('RealContactSubmit').click();">
                            <svg class="contact-submit-icon" width="20" height="20" viewBox="0 0 20 20" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
                                <path d="M17.5 2.5L9.16667 10.8333" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
                                <path d="M17.5 2.5L12.0833 17.5L9.16667 10.8333L2.5 7.91667L17.5 2.5Z" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
                            </svg>
                            <span>Send a Message</span>
                        </button>
                    </div>
                </div>
            </div>
        </section>
    </div>
</main>


{% schema %}
