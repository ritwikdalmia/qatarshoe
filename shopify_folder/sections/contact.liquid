    },
    {
      "type": "text",
      "id": "card_2_desc",
      "label": "International Card Description",
      "default": "For all orders outside Qatar"
    },
    {
      "type": "text",
      "id": "card_2_phone",
      "label": "International Display Phone",
      "default": "+974 3390 3967"
    },
    {
      "type": "text",
      "id": "card_2_phone_raw",
      "label": "International Raw Phone (for WhatsApp link)",
      "default": "97433903967"
    },
    {
      "type": "header",
      "content": "Email Card"
    },
    {
      "type": "text",
      "id": "card_3_title",
      "label": "Email Card Title",
      "default": "Email Us"
    },
    {
      "type": "text",
      "id": "card_3_desc",
      "label": "Email Card Description",
      "default": "General inquiries, documentation & follow-ups"
    },
    {
      "type": "text",
      "id": "card_3_email",
      "label": "Email Address",
      "default": "info@qtrshoe.com"
    },
    {
      "type": "header",
      "content": "Form Settings"
    },
    {
      "type": "text",
      "id": "form_heading",
      "label": "Form Heading",
      "default": "Send Us A Message"
    },
    {
      "type": "text",
      "id": "form_subheading",
      "label": "Form Subheading",
      "default": "Fill out the form and we'll get back to you as quickly as possible."
    }
  ]
}
{% endschema %}
