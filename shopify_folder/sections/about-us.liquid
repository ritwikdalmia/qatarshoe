{%- style -%}
  /* Section 1 — Hero Banner */
  .about-hero {
      position: relative;
      background: #fff;
      padding: 56px 150px 0;
      display: flex;
      flex-direction: column;
      gap: 32px;
  }

  .about-hero-hands-container {
      display: flex;
      justify-content: space-between;
      align-items: center;
      width: 100%;
      margin-top: 24px;
      gap: 20px;
  }

  .about-hero-hand-img {
      max-height: 250px;
      object-fit: contain;
      width: 45%;
  }

  .about-hero-content {
      display: flex;
      flex-direction: column;
      gap: 32px;
  }

  .about-hero-content h1 {
      font-family: 'Inter', sans-serif;
      font-size: 24px;
      font-weight: 400;
      color: #2D1F1F;
      margin: 0;
      line-height: 100%;
  }

  .about-hero-content p {
      font-family: 'Inter', sans-serif;
      font-size: 16px;
      font-weight: 400;
      color: #1A1A1A;
      margin: 0;
      line-height: 150%;
  }

  /* Section 2 — About Intro */
  .about-intro {
      padding: 56px 150px 32px;
      background: #fff;
      display: flex;
      flex-direction: column;
      gap: 32px;
  }

  .about-intro-block {
      display: flex;
      flex-direction: column;
      gap: 12px;
  }

  .about-intro-label {
      font-family: 'Inter', sans-serif;
      font-size: 16px;
      font-weight: 500;
      color: #2D1F1F;
      line-height: 100%;
      text-transform: uppercase;
      letter-spacing: 0;
      margin: 0;
  }

  .about-intro-text {
      font-family: 'Inter', sans-serif;
      font-size: 16px;
      font-weight: 400;
      color: #1A1A1A;
      margin: 0;
      line-height: 150%;
  }

  /* Section 3 — What We Offer */
  .about-offer {
      padding: 96px 150px;
      background: #fff;
      display: flex;
      flex-direction: column;
      gap: 48px;
  }

  .about-offer-header {
      display: flex;
      align-items: center;
      justify-content: space-between;
  }

  .about-offer-header h2 {
      font-family: 'Inter', sans-serif;
      font-size: 24px;
      font-weight: 600;
      color: #2D1F1F;
      margin: 0;
      line-height: 28px;
  }

  .about-offer-explore {
      display: inline-flex;
      align-items: center;
      justify-content: center;
      height: 48px;
      padding: 0 24px;
      background: #fff;
      color: #2D1F1F;
      border: 1px solid #2D1F1F;
      border-radius: 900px;
      font-family: 'Inter', sans-serif;
      font-size: 14px;
      font-weight: 500;
      line-height: 100%;
      letter-spacing: 0;
      text-transform: none;
      text-decoration: none;
      transition: background 0.2s ease, color 0.2s ease;
  }

  .about-offer-explore:hover {
      background: #2D1F1F;
      color: #fff;
  }

  .about-offer-cards {
      display: flex;
      gap: 24px;
  }

  .about-offer-card {
      flex: 1 1 0;
      display: flex;
      flex-direction: column;
      align-items: center;
      gap: 32px;
      min-width: 0;
      text-decoration: none;
  }

  .about-offer-card-name {
      font-family: 'Inter', sans-serif;
      font-size: 16px;
      font-weight: 400;
      color: #1A1A1A;
      text-align: center;
  }

  .about-offer-card img {
      width: 100%;
      max-width: 200px;
      height: 200px;
      object-fit: contain;
  }

  /* Section 4 — House of Brands */
  .about-brands-section {
      padding: 128px 40px;
      background: #fff;
      max-width: 100%;
      display: flex;
      flex-direction: column;
      align-items: center;
      gap: 32px;
      position: relative;
      z-index: 1;
  }

  .about-brands-section .brands-header {
      display: flex;
      justify-content: center;
      align-items: center;
      margin: 0;
      padding: 0;
  }

  .about-brands-section .brands-header h2 {
      font-size: 32px;
      font-weight: 600;
      margin: 0;
      color: #2D1F1F;
      font-family: 'Inter', sans-serif;
      text-transform: capitalize;
      line-height: 28px;
      text-align: center;
  }

  .about-brands-section .brands-grid {
      align-self: stretch;
      padding: 1px;
      display: flex;
      align-items: flex-start;
      gap: 24px;
      flex-wrap: wrap;
      justify-content: center;
  }

  .about-brands-section .brand-item {
      flex: 1 1 0;
      aspect-ratio: 1/1;
      background: white;
      overflow: hidden;
      border-radius: 16px;
      outline: 1px solid #E0DCD3;
      outline-offset: -1px;
      display: flex;
      align-items: center;
      justify-content: center;
      text-decoration: none;
      transition: background-color 0.2s ease;
      min-width: 110px;
      max-width: 160px;
  }

  .about-brands-section .brand-item:hover {
      background: #f9f9f9;
  }

  .about-brands-section .brand-image-container {
      width: 100%;
      height: 100%;
      padding: 5px;
      display: flex;
      align-items: center;
      justify-content: center;
      box-sizing: border-box;
  }

  .about-brands-section .brand-image-container img {
      max-width: 120%;
      max-height: 120%;
      object-fit: contain;
  }

  .about-brands-section .brand-name-text {
      font-size: 14px;
      font-weight: 500;
      color: #333;
      text-align: center;
      text-transform: uppercase;
      letter-spacing: 1px;
  }

  @media (max-width: 1023px) {
      .about-hero,
      .about-intro,
      .about-offer {
          padding-left: 40px;
          padding-right: 40px;
      }
      .about-brands-section {
          padding: 80px 24px;
      }
      .about-brands-section .brands-grid {
          display: grid;
          grid-template-columns: repeat(4, 1fr);
          gap: 16px;
      }
      .about-brands-section .brand-item {
          flex: unset;
          height: auto;
          aspect-ratio: 1/1;
          max-width: none;
      }
  }

  @media (max-width: 767px) {
      .about-hero,
      .about-intro,
      .about-offer {
          padding-left: 24px;
          padding-right: 24px;
      }
      .about-hero {
          padding-top: 32px;
      }
      .about-hero-content {
          gap: 20px;
      }
      .about-intro {
          padding-top: 32px;
          padding-bottom: 64px;
          gap: 20px;
      }
      .about-offer {
          padding-top: 64px;
          padding-bottom: 64px;
          gap: 24px;
      }
      .about-offer-header h2 {
          font-size: 24px;
          line-height: 100%;
      }
      .about-offer-cards {
          overflow-x: auto;
          -webkit-overflow-scrolling: touch;
          scroll-snap-type: x mandatory;
          gap: 12px;
          padding-bottom: 8px;
          scrollbar-width: none;
      }
      .about-offer-cards::-webkit-scrollbar {
          display: none;
      }
      .about-offer-card {
          flex: 0 0 160px;
          scroll-snap-align: start;
          gap: 16px;
      }
      .about-offer-card img {
          max-width: 150px;
          height: 150px;
      }
      .about-brands-section {
          padding: 40px 15px;
          gap: 20px;
      }
      .about-brands-section .brands-header h2 {
          font-size: 24px;
          line-height: 28px;
      }
      .about-brands-section .brands-grid {
          grid-template-columns: repeat(4, 1fr);
          gap: 8px;
      }
      .about-brands-section .brand-item {
          border-radius: 7.48px;
          outline: none;
          border: 0.47px solid #E5E5E5;
      }
  }
{%- endstyle -%}

<main class="about-main-wrapper">
    <!-- Section 1 — Hero Banner -->
    <section class="about-hero">
        <div class="about-hero-content">
            <h1>{{ section.settings.hero_heading | default: "About US" }}</h1>
            <p>{{ section.settings.hero_subheading | default: "At the heart of our brand is a single commitment — to make every luxury purchase effortless, trusted, and genuinely satisfying." }}</p>
        </div>
        
        {%- if section.settings.show_hero_hands -%}
            <div class="about-hero-hands-container">
                {%- if section.settings.left_hand_image != blank -%}
                    <img class="about-hero-hand-img" src="{{ section.settings.left_hand_image | image_url: width: 600 }}" alt="" loading="lazy" />
                {%- else -%}
                    <img class="about-hero-hand-img" src="{{ 'Qtr-w-h.png' | asset_url }}" alt="" loading="lazy" />
                {%- endif -%}

                {%- if section.settings.right_hand_image != blank -%}
                    <img class="about-hero-hand-img" src="{{ section.settings.right_hand_image | image_url: width: 600 }}" alt="" loading="lazy" />
                {%- else -%}
                    <img class="about-hero-hand-img" src="{{ 'Dub-m-h.png' | asset_url }}" alt="" loading="lazy" />
                {%- endif -%}
            </div>
        {%- endif -%}
    </section>

    <!-- Section 2 — About Intro -->
    <section class="about-intro">
        {%- for block in section.blocks -%}
            {%- if block.type == 'intro_block' -%}
                <div class="about-intro-block" {{ block.shopify_attributes }}>
                    {%- if block.settings.label != blank -%}
                        <span class="about-intro-label">{{ block.settings.label }}</span>
                    {%- endif -%}
                    {%- if block.settings.text != blank -%}
                        <p class="about-intro-text">{{ block.settings.text | newline_to_br }}</p>
                    {%- endif -%}
                </div>
            {%- endif -%}
        {%- endfor -%}
    </section>

    <!-- Section 3 — What We Offer -->
    <section class="about-offer">
        <div class="about-offer-header">
            <h2>{{ section.settings.offer_heading | default: "What We Offer:" }}</h2>
            {%- if section.settings.explore_url != blank -%}
                <a href="{{ section.settings.explore_url }}" class="about-offer-explore">
                    {{ section.settings.explore_label | default: "explore" }}
                </a>
            {%- endif -%}
        </div>
        
        <div class="about-offer-cards">
            {%- for block in section.blocks -%}
                {%- if block.type == 'offer_card' -%}
                    <a href="{{ block.settings.url | default: '#' }}" class="about-offer-card" {{ block.shopify_attributes }}>
                        {%- if block.settings.image != blank -%}
                            <img src="{{ block.settings.image | image_url: width: 400 }}" alt="{{ block.settings.name | escape }}" loading="lazy" />
                        {%- else -%}
                            {{ 'image' | placeholder_svg_tag: 'placeholder-svg' }}
                        {%- endif -%}
                        <span class="about-offer-card-name">{{ block.settings.name }}</span>
                    </a>
                {%- endif -%}
            {%- endfor -%}
        </div>
    </section>

    <!-- Section 4 — House of Brands -->
    <section class="about-brands-section">
        <div class="brands-header">
            <h2>{{ section.settings.brands_heading | default: "House Of Brands" }}</h2>
        </div>
        
        <div class="brands-grid">
            {%- for block in section.blocks -%}
                {%- if block.type == 'brand' -%}
                    {%- liquid
                      assign col = collections[block.settings.collection_handle]
                      assign brand_name = block.settings.custom_name | default: col.title
                      assign brand_url = block.settings.custom_url | default: col.url | default: "#"
                      assign brand_class = brand_name | downcase | replace: ' ', '-' | prepend: 'brand-font-'
                    -%}
                    <a href="{{ brand_url }}" class="brand-item" {{ block.shopify_attributes }}>
                        <div class="brand-image-container">
                            {%- if block.settings.image != blank -%}
                                <img src="{{ block.settings.image | image_url: width: 300 }}" alt="{{ brand_name | escape }}" loading="lazy" />
                            {%- elsif col.image != blank -%}
                                <img src="{{ col.image | image_url: width: 300 }}" alt="{{ brand_name | escape }}" loading="lazy" />
                            {%- else -%}
                                <span class="brand-name-text {{ brand_class }}">{{ brand_name }}</span>
                            {%- endif -%}
                        </div>
                    </a>
                {%- endif -%}
            {%- endfor -%}
        </div>
    </section>
</main>

{% schema %}
{
  "name": "About Us Page",
  "settings": [
    {
      "type": "header",
