{% comment %}
  Mock Product Card Snippet for Sandbox/Dummy Layout
{% endcomment %}

<div class="product-card">
  <div class="product-card-link">
    <!-- Image Wrapper -->
    <div class="product-card-image-wrapper">
      <img class="product-card-img main-img" src="{{ image_url }}" alt="{{ title }}">
      {%- if hover_image_url != blank -%}
        <img class="product-card-img hover-img" src="{{ hover_image_url }}" alt="{{ title }}">
      {%- endif -%}
    </div>

    <!-- Details -->
    <div class="product-card-info">
      <div class="product-brand">{{ brand }}</div>
      <div class="product-title font-small">{{ title }}</div>
      <div class="product-prices">
        <span class="price-current">{{ price }}</span>
      </div>
    </div>
  </div>
</div>
