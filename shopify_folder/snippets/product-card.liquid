{% comment %}
  Product Card Snippet for QatarShoes Theme
{% endcomment %}

<div class="product-card" data-id="{{ product.id }}">
  <a href="{{ product.url }}" class="product-card-link">
    <!-- Image Wrapper with hover second image or zoom -->
    <div class="product-card-image-wrapper">
      {%- if product.featured_media != blank -%}
        <img class="product-card-img main-img" src="{{ product.featured_media | image_url: width: 400 }}" alt="{{ product.title }}">
        {%- if product.media[1] != blank -%}
          <img class="product-card-img hover-img" src="{{ product.media[1] | image_url: width: 400 }}" alt="{{ product.title }}">
        {%- endif -%}
      {%- else -%}
        {{ 'product-1' | placeholder_svg_tag: 'placeholder-svg' }}
      {%- endif -%}
      
      <!-- Badges -->
      {%- if product.compare_at_price > product.price -%}
        <span class="badge sale-badge">Sale</span>
      {%- endif -%}
    </div>

    <!-- Product Text Details -->
    <div class="product-card-info">
      <div class="product-brand">{{ product.vendor }}</div>
      <div class="product-title font-small">{{ product.title }}</div>
      
      <div class="product-prices">
        {%- if product.compare_at_price > product.price -%}
          <span class="price-old">{{ product.compare_at_price | money }}</span>
        {%- endif -%}
        <span class="price-current">{{ product.price | money }}</span>
      </div>
    </div>
  </a>
</div>

<style>
  .product-card {
    background-color: var(--color-white);
    border: 1px solid var(--color-border);
    transition: box-shadow 0.3s;
    overflow: hidden;
  }
  .product-card:hover {
    box-shadow: 0 4px 15px rgba(0,0,0,0.05);
  }
  .product-card-image-wrapper {
    position: relative;
    width: 100%;
    padding-top: 130%; /* Aspect ratio */
    overflow: hidden;
    background: #fff;
  }
  .product-card-img {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: opacity 0.4s ease, transform 0.4s ease;
  }
  .product-card-img.hover-img {
    opacity: 0;
  }
  .product-card-image-wrapper:hover .main-img {
    {%- if product.media[1] != blank -%}
      opacity: 0;
    {%- else -%}
      transform: scale(1.05);
    {%- endif -%}
  }
  .product-card-image-wrapper:hover .hover-img {
    opacity: 1;
    transform: scale(1.03);
  }
  .badge {
    position: absolute;
    top: 10px;
    left: 10px;
    background: var(--color-accent);
    color: var(--color-white);
    font-size: 11px;
    text-transform: uppercase;
    font-weight: bold;
    padding: 3px 8px;
    border-radius: 2px;
    z-index: 2;
  }
  .product-card-info {
    padding: 15px;
    background: var(--color-white);
  }
  .product-brand {
    font-family: var(--font-heading);
    font-size: 16px;
    color: var(--color-text);
    margin-bottom: 4px;
    font-weight: 500;
  }
  .product-title {
    font-size: 12px;
    color: #666;
    margin-bottom: 8px;
    text-overflow: ellipsis;
    overflow: hidden;
    white-space: nowrap;
  }
  .product-prices {
    display: flex;
    gap: 8px;
    align-items: center;
    font-weight: bold;
    font-size: 14px;
  }
  .price-old {
    text-decoration: line-through;
    color: #999;
    font-size: 12px;
  }
  .price-current {
    color: var(--color-primary);
  }
</style>
