{% layout 'theme' %}

{{ 'gift-card.css' | asset_url | stylesheet_tag }}

{%- assign is_arabic = false -%}
{%- if request.locale.iso_code == 'ar' -%}
  {%- assign is_arabic = true -%}
{%- endif -%}

<script src="{{ 'vendor/qrcode.js' | shopify_asset_url }}" defer></script>
<script src="https://cdnjs.cloudflare.com/ajax/libs/html2canvas/1.4.1/html2canvas.min.js" defer></script>

<div class="gift-card-page-wrapper">
  <div class="gift-card-container" id="GiftCardContainer">
    
    <!-- Header -->
    <div class="gift-card-header">
      <h1 class="gift-card-title">
        {%- if is_arabic -%}
          بطاقة هدية - {{ shop.name }}
        {%- else -%}
          Gift Card - {{ shop.name }}
        {%- endif -%}
      </h1>
      <p class="gift-card-subtitle">
        {%- if is_arabic -%}
          إليك بطاقة الهدية الخاصة بك! يمكنك استخدامها لشراء أي منتج من متجرنا.
        {%- else -%}
          Here is your gift card! You can use it to purchase any product from our store.
        {%- endif -%}
      </p>
    </div>

    <!-- Status Badges / Expiration -->
    {%- if gift_card.enabled == false or gift_card.expired -%}
      <div class="gift-card-status-badge status-expired">
        {%- if is_arabic -%}
          هذه البطاقة غير نشطة أو انتهت صلاحيتها
        {%- else -%}
          This gift card is inactive or has expired
        {%- endif -%}
      </div>
    {%- elsif gift_card.expires_on -%}
      <div class="gift-card-status-badge status-active">
        {%- if is_arabic -%}
          تنتهي صلاحية هذه البطاقة في {{ gift_card.expires_on | date: "%d/%m/%Y" }}
        {%- else -%}
          This gift card expires on {{ gift_card.expires_on | date: "%d/%m/%Y" }}
        {%- endif -%}
      </div>
    {%- endif -%}

    <!-- Luxury Virtual Gift Card -->
    <div class="gift-card-visual" id="GiftCardVisual">
      <div class="gift-card-visual-header">
        <span class="gift-card-visual-logo">{{ shop.name }}</span>
        <span class="gift-card-visual-tag">
          {%- if is_arabic -%}بطاقة هدية{%- else -%}Gift Card{%- endif -%}
        </span>
      </div>
      
      <div class="gift-card-visual-body">
        <div class="gift-card-visual-label">
          {%- if is_arabic -%}الرصيد المتبقي{%- else -%}Remaining Balance{%- endif -%}
        </div>
        <div class="gift-card-visual-amount {% if gift_card.enabled == false or gift_card.expired %}gift-card-disabled{% endif %}">
          {{ gift_card.balance | money }}
        </div>
        {%- if gift_card.balance != gift_card.initial_value -%}
          <div style="font-size:12px; color:rgba(255,255,255,0.6); margin-top: 4px;">
            {%- if is_arabic -%}
              من أصل {{ gift_card.initial_value | money }}
            {%- else -%}
              out of {{ gift_card.initial_value | money }}
            {%- endif -%}
          </div>
        {%- endif -%}
      </div>
      
      <div class="gift-card-visual-footer">
        <div class="gift-card-visual-code-wrap" onclick="copyGiftCardCode()" title="{% if is_arabic %}انقر لنسخ الرمز{% else %}Click to copy code{% endif %}">
          <span class="gift-card-visual-code" id="GiftCardCode">{{ gift_card.code | format_code }}</span>
          <svg class="gift-card-copy-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <rect x="9" y="9" width="13" height="13" rx="2" ry="2"></rect>
            <path d="M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1"></path>
          </svg>
        </div>
      </div>
    </div>

    <!-- Instructions -->
    <div class="gift-card-instructions">
      <p>
        {%- if is_arabic -%}
          استخدم الرمز الموضح أعلاه عند الدفع لتطبيق قيمة بطاقة الهدية على طلبك.
        {%- else -%}
          Use the code shown above at checkout to apply this gift card's value to your order.
        {%- endif -%}
      </p>
    </div>

    <!-- QR Code Dynamic Section -->
    {%- if gift_card.qr_identifier -%}
      <div class="gift-card-qr-section">
        <div class="gift-card-qr-container" id="QrCode"></div>
        <div class="gift-card-qr-text">
          {%- if is_arabic -%}
            امسح رمز الاستجابة السريعة للمسح الضوئي عند الدفع
          {%- else -%}
            Scan the QR code at checkout to redeem
          {%- endif -%}
        </div>
      </div>
    {%- endif -%}

    <!-- Apple Wallet Integration -->
    {%- if gift_card.pass_url -%}
      <div class="gift-card-apple-wallet">
        <a href="{{ gift_card.pass_url }}" class="gift-card-apple-wallet-btn" aria-label="{% if is_arabic %}أضف إلى Apple Wallet{% else %}Add to Apple Wallet{% endif %}">
          <img src="https://cdn.shopify.com/s/assets/admin/open-in-apple-wallet-en-96f21529a2bdfd311857993e50ea4bc2b588402c0c3aae719bd00c8b0907a3c3.svg" width="120" height="40" alt="Add to Apple Wallet" loading="lazy">
        </a>
      </div>
    {%- endif -%}

    <!-- Utilities / Action Buttons -->
    <div class="gift-card-buttons" data-html2canvas-ignore="true">
      <button type="button" class="gift-card-btn gift-card-btn-primary" onclick="copyGiftCardCode()">
        <svg viewBox="0 0 24 24"><rect x="9" y="9" width="13" height="13" rx="2" ry="2"></rect><path d="M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1"></path></svg>
        <span>
          {%- if is_arabic -%}نسخ الرمز{%- else -%}Copy Code{%- endif -%}
        </span>
      </button>
      
      <button type="button" class="gift-card-btn gift-card-btn-secondary" onclick="downloadGiftCard();">
        <svg viewBox="0 0 24 24"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"></path><polyline points="7 10 12 15 17 10"></polyline><line x1="12" y1="15" x2="12" y2="3"></line></svg>
        <span>
          {%- if is_arabic -%}تنزيل البطاقة{%- else -%}Download Card{%- endif -%}
        </span>
      </button>
      
      <a href="{{ shop.url }}" class="gift-card-btn gift-card-btn-secondary">
        <svg viewBox="0 0 24 24"><path d="M6 2L3 6v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2V6l-3-4z"></path><line x1="3" y1="6" x2="21" y2="6"></line><path d="M16 10a4 4 0 0 1-8 0"></path></svg>
        <span>
          {%- if is_arabic -%}بدء التسوق{%- else -%}Start Shopping{%- endif -%}
        </span>
      </a>
    </div>

  </div>
</div>

<!-- Success Toast Dialog -->
<div class="gift-card-toast" id="GiftCardToast">
  <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
    <polyline points="20 6 9 17 4 12"></polyline>
  </svg>
  <span>
    {%- if is_arabic -%}
      تم نسخ الرمز إلى الحافظة!
    {%- else -%}
      Code copied to clipboard!
    {%- endif -%}
  </span>
</div>

<script>
  document.addEventListener('DOMContentLoaded', function() {
    // Dynamically generate QR code
    var qrElement = document.getElementById('QrCode');
    if (qrElement && typeof QRCode !== 'undefined') {
      new QRCode(qrElement, {
        text: '{{ gift_card.qr_identifier }}',
        width: 120,
        height: 120,
        colorDark: '#2d1f1f',
        colorLight: 'var(--color-white)',
        correctLevel: QRCode.CorrectLevel.H
      });
    }
  });

  // Clipboard copy code with fallback
  function copyGiftCardCode() {
    var codeElement = document.getElementById('GiftCardCode');
    if (!codeElement) return;
    
    var codeText = codeElement.innerText.replace(/\s+/g, '');
    var success = false;
    
    if (navigator.clipboard && navigator.clipboard.writeText) {
      navigator.clipboard.writeText(codeText).then(showCopyToast);
    } else {
      // Fallback method
      var textArea = document.createElement("textarea");
      textArea.value = codeText;
      textArea.style.position = "fixed";  // Avoid scrolling to bottom
      document.body.appendChild(textArea);
      textArea.focus();
      textArea.select();
      try {
        document.execCommand('copy');
        success = true;
      } catch (err) {
        console.error('Fallback copy failed', err);
      }
      document.body.removeChild(textArea);
      if (success) {
        showCopyToast();
      }
    }
  }

  function showCopyToast() {
    var toast = document.getElementById('GiftCardToast');
    if (toast) {
      toast.classList.add('show');
      setTimeout(function() {
        toast.classList.remove('show');
      }, 3000);
    }
  }

  // Download full card container as image using html2canvas
  function downloadGiftCard() {
    var element = document.getElementById('GiftCardContainer');
    if (!element || typeof html2canvas === 'undefined') {
      console.error('Download failed: gift card container element or html2canvas library is missing.');
      return;
    }
    
    // Scale up for high quality image and set background color to match the cream styling
    html2canvas(element, {
      scale: 3,
      backgroundColor: 'var(--color-bg)',
      useCORS: true,
      logging: false
    }).then(function(canvas) {
      var link = document.createElement('a');
      link.download = 'gift-card-' + '{{ gift_card.code }}'.replace(/\s+/g, '') + '.png';
      link.href = canvas.toDataURL('image/png');
      link.click();
    }).catch(function(error) {
      console.error('Error generating image for gift card:', error);
    });
  }
</script>
