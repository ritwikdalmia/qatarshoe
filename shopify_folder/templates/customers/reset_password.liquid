<div class="customer-auth-container">
  
  <div class="auth-card">
    <h1 class="auth-title">Reset Account Password</h1>
    <p class="auth-subtitle">Enter a new password for your account.</p>

    {%- form 'reset_customer_password', class: 'auth-form' -%}
      {%- if form.errors -%}
        <div class="errors">
          {{ form.errors | default_errors }}
        </div>
      {%- endif -%}

      <div class="form-field">
        <label for="ResetPassword">Password</label>
        <input type="password" 
               name="customer[password]" 
               id="ResetPassword" 
               autocomplete="new-password" 
               placeholder="New password"
               required>
      </div>

      <div class="form-field">
        <label for="ResetPasswordConfirmation">Confirm Password</label>
        <input type="password" 
               name="customer[password_confirmation]" 
               id="ResetPasswordConfirmation" 
               autocomplete="new-password" 
               placeholder="Confirm new password"
               required>
      </div>

      <button type="submit" class="auth-submit-btn">Reset Password</button>
    {%- endform -%}
  </div>

</div>
