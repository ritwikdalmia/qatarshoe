<div class="account-page-container">
  
  <!-- Account Header -->
  <div class="account-header">
    <h1>My Account</h1>
    <p>Welcome back,, <strong>{{ customer.name }}</strong></p>
  </div>

  <!-- Tab Bar -->
  <div class="account-tabs-wrapper">
    <div class="account-tabs">
      <button class="account-tab active" onclick="switchTab('overview')">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round">
          <rect x="3" y="3" width="7" height="7"></rect><rect x="14" y="3" width="7" height="7"></rect>
          <rect x="14" y="14" width="7" height="7"></rect><rect x="3" y="14" width="7" height="7"></rect>
        </svg>
        Overview
      </button>
      <button class="account-tab" onclick="switchTab('orders')">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round">
          <path d="M6 2L3 6v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2V6l-3-4z"></path>
          <line x1="3" y1="6" x2="21" y2="6"></line><path d="M16 10a4 4 0 0 1-8 0"></path>
        </svg>
        Orders
      </button>
      <button class="account-tab" onclick="switchTab('wishlist')">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round">
          <path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z"></path>
        </svg>
        Wishlist
      </button>
      <button class="account-tab" onclick="switchTab('addresses')">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round">
          <path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"></path><circle cx="12" cy="10" r="3"></circle>
        </svg>
        Addresses
      </button>
      <button class="account-tab" onclick="switchTab('settings')">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round">
          <circle cx="12" cy="12" r="3"></circle>
          <path d="M19.4 15a1.65 1.65 0 0 0 .33 1.82l.06.06a2 2 0 1 1-2.83 2.83l-.06-.06a1.65 1.65 0 0 0-1.82-.33 1.65 1.65 0 0 0-1 1.51V21a2 2 0 0 1-4 0v-.09A1.65 1.65 0 0 0 9 19.4a1.65 1.65 0 0 0-1.82.33l-.06.06a2 2 0 1 1-2.83-2.83l.06-.06a1.65 1.65 0 0 0 .33-1.82 1.65 1.65 0 0 0-1.51-1H3a2 2 0 0 1 0-4h.09A1.65 1.65 0 0 0 4.6 9a1.65 1.65 0 0 0-.33-1.82l-.06-.06a2 2 0 1 1 2.83-2.83l.06.06a1.65 1.65 0 0 0 1.82.33H9a1.65 1.65 0 0 0 1-1.51V3a2 2 0 0 1 4 0v.09a1.65 1.65 0 0 0 1 1.51 1.65 1.65 0 0 0 1.82-.33l.06-.06a2 2 0 1 1 2.83 2.83l-.06.06a1.65 1.65 0 0 0-.33 1.82V9a1.65 1.65 0 0 0 1.51 1H21a2 2 0 0 1 0 4h-.09a1.65 1.65 0 0 0-1.51 1z"></path>
        </svg>
        Settings
      </button>
    </div>
  </div>

  <!-- ==========================================
       TAB: OVERVIEW
       ========================================== -->
  <div class="account-tab-content active" id="tab-overview">
    <div class="overview-cards">
      
      <!-- Card: Orders -->
      <div class="overview-card">
        <div class="card-icon-wrapper">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round">
            <path d="M6 2L3 6v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2V6l-3-4z"></path>
            <line x1="3" y1="6" x2="21" y2="6"></line><path d="M16 10a4 4 0 0 1-8 0"></path>
          </svg>
        </div>
        <div class="card-stats">
          <span class="card-number">{{ customer.orders_count }}</span>
          <span class="card-label">Orders</span>
        </div>
        <a href="javascript:void(0)" class="card-link" onclick="switchTab('orders')">View More</a>
      </div>

      <!-- Card: Wishlist -->
      <div class="overview-card">
        <div class="card-icon-wrapper">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round">
            <path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z"></path>
          </svg>
        </div>
        <div class="card-stats">
          <span class="card-number" id="overview-wishlist-count">0</span>
          <span class="card-label">Wishlist Items</span>
        </div>
        <a href="javascript:void(0)" class="card-link" onclick="switchTab('wishlist')">View More</a>
      </div>

      <!-- Card: Addresses -->
      <div class="overview-card">
        <div class="card-icon-wrapper">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round">
            <path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"></path><circle cx="12" cy="10" r="3"></circle>
          </svg>
        </div>
        <div class="card-stats">
          <span class="card-number">{{ customer.addresses_count }}</span>
          <span class="card-label">Saved Addresses</span>
        </div>
        <a href="javascript:void(0)" class="card-link" onclick="switchTab('addresses')">Manage</a>
      </div>

    </div>

    <!-- Recent Orders Section -->
    <div class="section-title-bar">
      <h2>Recent Orders</h2>
      {%- if customer.orders_count > 0 -%}
        <a href="javascript:void(0)" class="card-link" onclick="switchTab('orders')">View More</a>
      {%- endif -%}
    </div>

    {%- if customer.orders_count == 0 -%}
      <div class="empty-state" style="margin-bottom: 40px;">
        <div class="empty-state-icon">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round">
            <path d="M6 2L3 6v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2V6l-3-4z"></path>
          </svg>
        </div>
        <h3>No orders yet</h3>
        <p>You haven't placed any orders yet.</p>
        <a href="/collections/all" class="empty-state-btn">Start Shopping</a>
      </div>
    {%- else -%}
      <div class="table-responsive">
        <table class="data-table">
          <thead>
            <tr>
              <th>Order</th>
              <th>Date</th>
              <th>Payment Status</th>
              <th>Fulfillment Status</th>
              <th>Total</th>
            </tr>
          </thead>
          <tbody>
            {%- for order in customer.orders limit: 3 -%}
              <tr>
                <td><a href="{{ order.customer_url }}" class="form-link" style="font-weight: 600;">{{ order.name }}</a></td>
                <td>{{ order.created_at | date: "%d %B, %Y" }}</td>
                <td>
                  <span class="badge {% if order.financial_status == 'paid' %}badge-success{% else %}badge-neutral{% endif %}">
                    {{ order.financial_status_label }}
                  </span>
                </td>
                <td>
                  <span class="badge {% if order.fulfillment_status == 'fulfilled' %}badge-success{% else %}badge-neutral{% endif %}">
                    {{ order.fulfillment_status_label }}
                  </span>
                </td>
                <td>{{ order.total_price | money }}</td>
              </tr>
            {%- endfor -%}
          </tbody>
        </table>
      </div>
    {%- endif -%}

    <!-- Account Details Section -->
    <div class="section-title-bar">
      <h2>Account Details</h2>
      <a href="javascript:void(0)" class="card-link" onclick="switchTab('settings')">Edit</a>
    </div>

    <div class="details-card">
      <div class="details-row">
        <span class="details-label">Name</span>
        <span class="details-value">{{ customer.name }}</span>
      </div>
      <div class="details-row">
        <span class="details-label">Email</span>
        <span class="details-value">{{ customer.email }}</span>
      </div>
      <div class="details-row">
        <span class="details-label">Member Since</span>
        <span class="details-value">
          {%- if customer.orders.size > 0 -%}
            {{ customer.orders.last.created_at | date: "%B %Y" }}
          {%- else -%}
            {{ 'now' | date: "%B %Y" }}
          {%- endif -%}
        </span>
      </div>
    </div>

    <a href="/account/logout" class="sign-out-btn">
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
        <path d="M9 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h4"></path><polyline points="16 17 21 12 16 7"></polyline><line x1="21" y1="12" x2="9" y2="12"></line>
      </svg>
      Sign Out
    </a>
  </div>

  <!-- ==========================================
       TAB: ORDERS
       ========================================== -->
  <div class="account-tab-content" id="tab-orders">
    <div class="section-title-bar">
      <h2>Order History</h2>
    </div>

    {%- if customer.orders_count == 0 -%}
      <div class="empty-state">
        <div class="empty-state-icon">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round">
            <path d="M6 2L3 6v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2V6l-3-4z"></path>
          </svg>
        </div>
        <h3>No orders yet</h3>
        <p>When you place orders, they will appear here.</p>
        <a href="/collections/all" class="empty-state-btn">Start Shopping</a>
      </div>
    {%- else -%}
      <div class="table-responsive">
        <table class="data-table">
          <thead>
            <tr>
              <th>Order</th>
              <th>Date</th>
              <th>Payment Status</th>
              <th>Fulfillment Status</th>
              <th>Total</th>
            </tr>
          </thead>
          <tbody>
            {%- for order in customer.orders -%}
              <tr>
                <td><a href="{{ order.customer_url }}" class="form-link" style="font-weight: 600;">{{ order.name }}</a></td>
                <td>{{ order.created_at | date: "%d %B, %Y" }}</td>
                <td>
                  <span class="badge {% if order.financial_status == 'paid' %}badge-success{% else %}badge-neutral{% endif %}">
                    {{ order.financial_status_label }}
                  </span>
                </td>
                <td>
                  <span class="badge {% if order.fulfillment_status == 'fulfilled' %}badge-success{% else %}badge-neutral{% endif %}">
                    {{ order.fulfillment_status_label }}
                  </span>
                </td>
                <td>{{ order.total_price | money }}</td>
              </tr>
            {%- endfor -%}
          </tbody>
        </table>
      </div>
    {%- endif -%}

    <div style="margin-top: 40px;">
      <a href="/account/logout" class="sign-out-btn">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <path d="M9 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h4"></path><polyline points="16 17 21 12 16 7"></polyline><line x1="21" y1="12" x2="9" y2="12"></line>
        </svg>
        Sign Out
      </a>
    </div>
  </div>

  <!-- ==========================================
       TAB: WISHLIST
       ========================================== -->
  <div class="account-tab-content" id="tab-wishlist">
    <div class="section-title-bar">
      <h2>Wishlist</h2>
    </div>

    <!-- Empty State -->
    <div class="empty-state" id="wishlist-empty-state" style="display: none;">
      <div class="empty-state-icon">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round">
          <path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z"></path>
        </svg>
      </div>
      <h3>Your wishlist is empty</h3>
      <p>Save items you love by clicking the heart icon.</p>
      <a href="/collections/all" class="empty-state-btn">Browse Products</a>
    </div>

    <!-- Dynamic Grid -->
    <div class="wishlist-grid" id="wishlist-tab-grid"></div>

    <div style="margin-top: 40px;">
      <a href="/account/logout" class="sign-out-btn">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <path d="M9 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h4"></path><polyline points="16 17 21 12 16 7"></polyline><line x1="21" y1="12" x2="9" y2="12"></line>
        </svg>
        Sign Out
      </a>
    </div>
  </div>

  <!-- ==========================================
       TAB: ADDRESSES
       ========================================== -->
  <div class="account-tab-content" id="tab-addresses">
    <div class="section-title-bar">
      <h2>Saved Addresses</h2>
      <button class="empty-state-btn" style="height: 36px; border-radius: 4px;" onclick="openAddressModal('new-address-modal')">
        + Add Address
      </button>
    </div>

    {%- if customer.addresses_count == 0 -%}
      <div class="empty-state">
        <div class="empty-state-icon">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round">
            <path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"></path><circle cx="12" cy="10" r="3"></circle>
          </svg>
        </div>
        <h3>No saved addresses</h3>
        <p>Add an address to make checkout faster.</p>
      </div>
    {%- else -%}
      <div class="address-grid">
        {%- for address in customer.addresses -%}
          <div class="address-card {% if address == customer.default_address %}default{% endif %}">
            
            {%- if address == customer.default_address -%}
              <span class="address-badge">Default</span>
            {%- endif -%}

            <div class="address-name">{{ address.name }}</div>

            <div class="address-details-list">
              {%- if address.company != blank -%}<div>{{ address.company }}</div>{%- endif -%}
              <div>{{ address.address1 }}</div>
              {%- if address.address2 != blank -%}<div>{{ address.address2 }}</div>{%- endif -%}
              <div>{{ address.city }}{% if address.province_code != blank %}, {{ address.province_code }}{% endif %} {{ address.zip | upcase }}</div>
              <div>{{ address.country }}</div>
              {%- if address.phone != blank -%}
                <div style="margin-top: 8px;"><strong>Phone:</strong> {{ address.phone }}</div>
              {%- endif -%}
            </div>

            <div class="address-actions">
              <button class="form-link" onclick="openAddressModal('edit-address-modal-{{ address.id }}')" style="font-weight: 600;">Edit</button>
              
              <!-- Native Delete address form -->
              <form method="post" action="/account/addresses/{{ address.id }}" onsubmit="return confirm('Are you sure you want to delete this address?');" style="display:inline;">
                <input type="hidden" name="_method" value="delete">
                <button type="submit" class="form-link" style="color: var(--color-accent); font-weight: 600;">Delete</button>
              </form>
            </div>
          </div>

          <!-- Overlay Form: Edit Address -->
          <div class="address-form-overlay" id="edit-address-modal-{{ address.id }}">
            <div class="address-form-card" onclick="event.stopPropagation()">
              <div class="address-form-title-bar">
                <h3>Edit Address</h3>
                <button class="close-overlay-btn" onclick="closeAddressModal('edit-address-modal-{{ address.id }}')">&times;</button>
              </div>

              {%- form 'customer_address', address, class: 'auth-form' -%}
                <div class="address-form-row">
                  <div class="form-field">
                    <label for="AddressFirstName_{{ form.id }}">First Name</label>
                    <input type="text" name="address[first_name]" id="AddressFirstName_{{ form.id }}" value="{{ form.first_name }}" required>
                  </div>
                  <div class="form-field">
                    <label for="AddressLastName_{{ form.id }}">Last Name</label>
                    <input type="text" name="address[last_name]" id="AddressLastName_{{ form.id }}" value="{{ form.last_name }}" required>
                  </div>
                </div>

                <div class="form-field">
                  <label for="AddressCompany_{{ form.id }}">Company</label>
                  <input type="text" name="address[company]" id="AddressCompany_{{ form.id }}" value="{{ form.company }}">
                </div>

                <div class="form-field">
                  <label for="AddressAddress1_{{ form.id }}">Address 1</label>
                  <input type="text" name="address[address1]" id="AddressAddress1_{{ form.id }}" value="{{ form.address1 }}" required>
                </div>

                <div class="form-field">
                  <label for="AddressAddress2_{{ form.id }}">Address 2</label>
                  <input type="text" name="address[address2]" id="AddressAddress2_{{ form.id }}" value="{{ form.address2 }}">
                </div>

                <div class="address-form-row">
                  <div class="form-field">
                    <label for="AddressCity_{{ form.id }}">City</label>
                    <input type="text" name="address[city]" id="AddressCity_{{ form.id }}" value="{{ form.city }}" required>
                  </div>
                  <div class="form-field">
                    <label for="AddressCountry_{{ form.id }}">Country</label>
                    <select name="address[country]" id="AddressCountry_{{ form.id }}" data-default="{{ form.country }}" required>
                      {{ all_country_option_tags }}
                    </select>
                  </div>
                </div>

                <div class="address-form-row">
                  <div class="form-field">
                    <label for="AddressZip_{{ form.id }}">Zip Code</label>
                    <input type="text" name="address[zip]" id="AddressZip_{{ form.id }}" value="{{ form.zip }}" required>
                  </div>
                  <div class="form-field">
                    <label for="AddressPhone_{{ form.id }}">Phone</label>
                    <input type="tel" name="address[phone]" id="AddressPhone_{{ form.id }}" value="{{ form.phone }}">
                  </div>
                </div>

                <div class="form-field checkbox-field">
                  {{ form.set_as_default_checkbox }}
                  <label for="address_default_address_{{ form.id }}">Set as default address</label>
                </div>

                <div class="address-form-actions">
                  <button type="submit" class="auth-submit-btn">Update Address</button>
                  <button type="button" class="sign-out-btn" style="height: 48px; border-radius: 24px;" onclick="closeAddressModal('edit-address-modal-{{ address.id }}')">Cancel</button>
                </div>
              {%- endform -%}
            </div>
          </div>
        {%- endfor -%}
      </div>
    {%- endif -%}

    <!-- Overlay Form: Add New Address -->
    <div class="address-form-overlay" id="new-address-modal">
      <div class="address-form-card" onclick="event.stopPropagation()">
        <div class="address-form-title-bar">
          <h3>Add New Address</h3>
          <button class="close-overlay-btn" onclick="closeAddressModal('new-address-modal')">&times;</button>
        </div>

        {%- form 'customer_address', customer.new_address, class: 'auth-form' -%}
          <div class="address-form-row">
            <div class="form-field">
              <label for="AddressFirstNameNew">First Name</label>
              <input type="text" name="address[first_name]" id="AddressFirstNameNew" value="{{ form.first_name }}" required>
            </div>
            <div class="form-field">
              <label for="AddressLastNameNew">Last Name</label>
              <input type="text" name="address[last_name]" id="AddressLastNameNew" value="{{ form.last_name }}" required>
            </div>
          </div>

          <div class="form-field">
            <label for="AddressCompanyNew">Company</label>
            <input type="text" name="address[company]" id="AddressCompanyNew" value="{{ form.company }}">
          </div>

          <div class="form-field">
            <label for="AddressAddress1New">Address 1</label>
            <input type="text" name="address[address1]" id="AddressAddress1New" value="{{ form.address1 }}" required>
          </div>

          <div class="form-field">
            <label for="AddressAddress2New">Address 2</label>
            <input type="text" name="address[address2]" id="AddressAddress2New" value="{{ form.address2 }}">
          </div>

          <div class="address-form-row">
            <div class="form-field">
              <label for="AddressCityNew">City</label>
              <input type="text" name="address[city]" id="AddressCityNew" value="{{ form.city }}" required>
            </div>
            <div class="form-field">
              <label for="AddressCountryNew">Country</label>
              <select name="address[country]" id="AddressCountryNew" data-default="{{ form.country }}" required>
                {{ all_country_option_tags }}
              </select>
            </div>
          </div>

          <div class="address-form-row">
            <div class="form-field">
              <label for="AddressZipNew">Zip Code</label>
              <input type="text" name="address[zip]" id="AddressZipNew" value="{{ form.zip }}" required>
            </div>
            <div class="form-field">
              <label for="AddressPhoneNew">Phone</label>
              <input type="tel" name="address[phone]" id="AddressPhoneNew" value="{{ form.phone }}">
            </div>
          </div>

          <div class="form-field checkbox-field">
            {{ form.set_as_default_checkbox }}
            <label for="address_default_address_new">Set as default address</label>
          </div>

          <div class="address-form-actions">
            <button type="submit" class="auth-submit-btn">Add Address</button>
            <button type="button" class="sign-out-btn" style="height: 48px; border-radius: 24px;" onclick="closeAddressModal('new-address-modal')">Cancel</button>
          </div>
        {%- endform -%}
      </div>
    </div>

    <div style="margin-top: 40px;">
      <a href="/account/logout" class="sign-out-btn">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <path d="M9 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h4"></path><polyline points="16 17 21 12 16 7"></polyline><line x1="21" y1="12" x2="9" y2="12"></line>
        </svg>
        Sign Out
      </a>
    </div>
  </div>

  <!-- ==========================================
       TAB: SETTINGS
       ========================================== -->
  <div class="account-tab-content" id="tab-settings">
    <div class="section-title-bar">
      <h2>Account Settings</h2>
    </div>

    <div class="settings-form-wrapper">
      <div class="details-card" style="margin-bottom: 24px;">
        <h3 style="font-size: 14px; font-weight: 700; text-transform: uppercase; letter-spacing: 0.05em; margin-bottom: 16px; color: var(--color-primary);">Profile Details</h3>
        <div class="details-row">
          <span class="details-label">Name</span>
          <span class="details-value">{{ customer.name }}</span>
        </div>
        <div class="details-row">
          <span class="details-label">Email</span>
          <span class="details-value">{{ customer.email }}</span>
        </div>
        <div class="details-row">
          <span class="details-label">Default Address</span>
          <span class="details-value">
            {%- if customer.default_address -%}
              {{ customer.default_address.city }}, {{ customer.default_address.country }}
            {%- else -%}
              Not set
            {%- endif -%}
          </span>
        </div>
      </div>

      <div class="details-card">
        <h3 style="font-size: 14px; font-weight: 700; text-transform: uppercase; letter-spacing: 0.05em; margin-bottom: 8px; color: var(--color-primary);">Account Password</h3>
        <p style="font-size: 13px; color: var(--color-muted, #666); margin-bottom: 20px; line-height: 1.5;">To change your account password, click the button below to initiate a secure recovery email.</p>
        
        {%- form 'recover_customer_password', class: 'auth-form' -%}
          <input type="hidden" name="email" value="{{ customer.email }}">
          <button type="submit" class="auth-submit-btn" style="max-width: 200px; margin-top: 0;">Reset Password</button>
        {%- endform -%}
      </div>
    </div>

    <div style="margin-top: 40px;">
      <a href="/account/logout" class="sign-out-btn">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <path d="M9 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h4"></path><polyline points="16 17 21 12 16 7"></polyline><line x1="21" y1="12" x2="9" y2="12"></line>
        </svg>
        Sign Out
      </a>
    </div>
  </div>

</div>

<!-- ==========================================
     DASHBOARD JAVASCRIPT
     ========================================== -->
<script>
  // Global tab switching logic
  function switchTab(tabName) {
    // Update active tab buttons
    document.querySelectorAll('.account-tab').forEach(function(btn) {
      const isMatch = btn.textContent.toLowerCase().includes(tabName);
      btn.classList.toggle('active', isMatch);
    });

    // Update active content blocks
    document.querySelectorAll('.account-tab-content').forEach(function(content) {
      const isMatch = content.id === 'tab-' + tabName;
      content.classList.toggle('active', isMatch);
    });

    // Handle initializations per tab
    if (tabName === 'wishlist') {
      renderWishlistTab();
    }

    // Save current active tab in URL hash for refreshing
    window.location.hash = tabName;
  }

  // Address modal controls
  function openAddressModal(id) {
    const modal = document.getElementById(id);
    if (modal) {
      modal.classList.add('active');
      document.body.style.overflow = 'hidden';
    }
  }

  function closeAddressModal(id) {
    const modal = document.getElementById(id);
    if (modal) {
      modal.classList.remove('active');
      document.body.style.overflow = '';
    }
  }

  // Close modals on clicking overlay background
  document.querySelectorAll('.address-form-overlay').forEach(function(overlay) {
    overlay.addEventListener('click', function(e) {
      if (e.target === overlay) {
        closeAddressModal(overlay.id);
      }
    });
  });

  // Price formatting helper for wishlist items
  function formatStorePrice(cents, currency) {
    var val = cents / 100;
    var symbol = 'QAR';
    if (currency === 'USD') {
      val = Math.round(val * 0.2747);
      symbol = '$';
    } else if (currency === 'EUR') {
      val = Math.round(val * 0.253);
      symbol = '€';
    } else if (currency === 'AED') {
      val = Math.round(val * 1.003);
      symbol = 'AED';
    } else {
      symbol = 'QAR';
    }
    return symbol + ' ' + val.toLocaleString();
  }

  // Render wishlist tab dynamically from localStorage
  function renderWishlistTab() {
    const grid = document.getElementById('wishlist-tab-grid');
    const emptyState = document.getElementById('wishlist-empty-state');
    const items = JSON.parse(localStorage.getItem('qtr_wishlist_items') || '[]');
    const countSpan = document.getElementById('overview-wishlist-count');
    
    if (countSpan) countSpan.textContent = items.length;
    
    if (items.length === 0) {
      if (grid) grid.style.display = 'none';
      if (emptyState) emptyState.style.display = 'flex';
    } else {
      if (emptyState) emptyState.style.display = 'none';
      if (grid) {
        grid.style.display = 'grid';
        let html = '';
        items.forEach(item => {
          let curCurrency = localStorage.getItem('qtr_currency') || 'QAR';
          let formattedPrice = formatStorePrice(item.price, curCurrency);
          html += `
            <div class="wishlist-card-item" data-id="${item.id}">
              <button class="wishlist-remove-icon-btn" onclick="removeWishlistItemFromPage('${item.id}')" aria-label="Remove from wishlist">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
                  <line x1="18" y1="6" x2="6" y2="18"></line>
                  <line x1="6" y1="6" x2="18" y2="18"></line>
                </svg>
              </button>
              <a href="${item.url}" class="wishlist-card-img-link">
                <img src="${item.image}" class="wishlist-card-img" alt="${item.title}">
              </a>
              <div class="wishlist-card-details">
                <div class="wishlist-card-vendor">${item.vendor}</div>
                <a href="${item.url}" class="wishlist-card-title">${item.title}</a>
                <div class="wishlist-card-price">${formattedPrice}</div>
                <button class="wishlist-card-atc" onclick="addWishlistToCartFromPage('${item.id}', '${item.variant_id || item.id}')">Add to Cart</button>
              </div>
            </div>
          `;
        });
        grid.innerHTML = html;
      }
    }
  }

  // Remove item from wishlist page handler
  window.removeWishlistItemFromPage = function(productId) {
    if (typeof window.removeWishlistItem === 'function') {
      window.removeWishlistItem(productId);
      renderWishlistTab();
    }
  };

  // Add item from wishlist to cart handler
  window.addWishlistToCartFromPage = function(productId, variantId) {
    if (typeof window.addWishlistToCart === 'function') {
      window.addWishlistToCart(productId, variantId);
    }
  };

  // On load: restore active tab or load overview count
  document.addEventListener('DOMContentLoaded', function() {
    var initialTab = window.location.hash.replace('#', '') || 'overview';
    switchTab(initialTab);

    // Initial counter load for overview page
    const items = JSON.parse(localStorage.getItem('qtr_wishlist_items') || '[]');
    const countSpan = document.getElementById('overview-wishlist-count');
    if (countSpan) countSpan.textContent = items.length;
  });

  // Re-sync values if localStorage wishlist is updated elsewhere
  window.addEventListener('wishlistChanged', function() {
    const items = JSON.parse(localStorage.getItem('qtr_wishlist_items') || '[]');
    const countSpan = document.getElementById('overview-wishlist-count');
    if (countSpan) countSpan.textContent = items.length;
    if (window.location.hash === '#wishlist') {
      renderWishlistTab();
    }
  });
</script>
